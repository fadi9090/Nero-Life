{% comment %}
  Simple Cart Template - No AJAX, just form submits
{% endcomment %}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  
  {% if cart.item_count > 0 %}
    
    <form action="{{ routes.cart_url }}" method="post" id="cart-form">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Cart Items -->
        <div class="lg:col-span-2 space-y-6">
          {% for item in cart.items %}
            <div class="border-b pb-6 flex items-start gap-4">
              <!-- Product Image -->
              <div class="w-24 h-24 flex-shrink-0 bg-gray-100 rounded-lg overflow-hidden">
                <a href="{{ item.url }}">
                  <img src="{{ item.image | image_url: width: 200 }}" 
                       loading="lazy" 
                       alt="{{ item.image.alt | escape }}"
                       width="200"
                       height="200"
                       class="w-full h-full object-cover">
                </a>
              </div>

              <!-- Product Details -->
              <div class="flex-grow">
                <div class="flex justify-between">
                  <div>
                    <h3 class="text-lg font-medium">
                      <a href="{{ item.url }}">{{ item.product.title }}</a>
                    </h3>
                    {% unless item.product.has_only_default_variant %}
                      <p class="text-sm text-gray-500">{{ item.variant.title }}</p>
                    {% endunless %}
                  </div>
                  <div class="text-lg font-medium">
                    {{ item.final_line_price | money }}
                  </div>
                </div>

                <!-- Quantity Controls - Simple links that reload the page -->
                <div class="flex items-center mt-3">
                  <div class="inline-flex border border-gray-300 rounded-md">
                    <a href="/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | minus: 1 }}" 
                       class="p-2 text-gray-600 hover:text-gray-900 px-3">−</a>
                    
                    <span class="w-12 text-center py-2 border-l border-r border-gray-300">
                      {{ item.quantity }}
                    </span>
                    
                    <a href="/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | plus: 1 }}" 
                       class="p-2 text-gray-600 hover:text-gray-900 px-3">+</a>
                  </div>
                  
                  <a href="/cart/change?line={{ forloop.index }}&quantity=0" 
                     class="ml-4 text-sm text-red-600 hover:text-red-800">
                    Remove
                  </a>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>

        <!-- Order Summary -->
        <div class="lg:col-span-1 bg-gray-50 p-6 rounded-xl h-fit">
          <h2 class="text-xl font-bold mb-4">Order Summary</h2>
          
          <div class="space-y-3 border-b pb-4">
            <div class="flex justify-between">
              <span>Subtotal</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
          </div>
          
          <div class="flex justify-between text-xl font-bold pt-4">
            <span>Total</span>
            <span>{{ cart.total_price | money }}</span>
          </div>

          <button type="submit" name="checkout" 
                  class="w-full mt-6 py-3 px-6 bg-black text-white rounded-md hover:bg-gray-800">
            Checkout
          </button>
        </div>
      </div>
    </form>

  {% else %}
    <!-- Empty Cart -->
    <div class="text-center py-20">
      <h2 class="text-2xl font-bold mb-4">Your Cart is Empty</h2>
      <a href="/collections/all" class="inline-block bg-black text-white px-8 py-3 rounded-md">
        Continue Shopping
      </a>
    </div>
  {% endif %}
</div>