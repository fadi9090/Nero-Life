{% comment %}
  Cart Template - Fully customizable through Shopify editor
  Features: Simple cart with quantity controls, order summary, and responsive design
{% endcomment %}

{% comment %} Get the single product URL for continue shopping - CHANGE THIS TO YOUR PRODUCT HANDLE {% endcomment %}
{% assign product_handle = section.settings.product_handle | default: '14-silicone-face-neck-photon-mask' %}
{% assign single_product = all_products[product_handle] %}

<style>
  #cart-{{ section.id }} {
    --cart-max-width: {{ section.settings.max_width | default: '1280' }}px;
    --cart-padding-y: {{ section.settings.padding_y | default: '48' }}px;
    --cart-padding-x: {{ section.settings.padding_x | default: '16' }}px;
    --cart-bg: {{ section.settings.cart_bg | default: '#FFFFFF' }};
    
    /* Text Colors - Fixed */
    --heading-color: {{ section.settings.heading_color | default: '#111827' }};
    --title-color: {{ section.settings.title_color | default: '#111827' }};
    --body-text-color: {{ section.settings.body_text_color | default: '#4B5563' }};
    --light-text-color: {{ section.settings.light_text_color | default: '#6B7280' }};
    --border-color: {{ section.settings.border_color | default: '#E5E7EB' }};
    
    /* Item Colors */
    --item-bg: {{ section.settings.item_bg | default: '#F9FAFB' }};
    --price-color: {{ section.settings.price_color | default: '#111827' }};
    
    /* Interactive Colors */
    --link-color: {{ section.settings.link_color | default: '#2563EB' }};
    --link-hover: {{ section.settings.link_hover | default: '#1D4ED8' }};
    --quantity-btn-color: {{ section.settings.quantity_btn_color | default: '#4B5563' }};
    --quantity-btn-hover: {{ section.settings.quantity_btn_hover | default: '#111827' }};
    --remove-color: {{ section.settings.remove_color | default: '#DC2626' }};
    --remove-hover: {{ section.settings.remove_hover | default: '#B91C1C' }};
    
    /* Summary Colors */
    --summary-bg: {{ section.settings.summary_bg | default: '#F9FAFB' }};
    --summary-text: {{ section.settings.summary_text | default: '#4B5563' }};
    --summary-heading: {{ section.settings.summary_heading | default: '#111827' }};
    --discount-color: {{ section.settings.discount_color | default: '#059669' }};
    --total-color: {{ section.settings.total_color | default: '#111827' }};
    
    /* Button Colors */
    --checkout-bg: {{ section.settings.checkout_bg | default: '#000000' }};
    --checkout-hover: {{ section.settings.checkout_hover | default: '#1F2937' }};
    --checkout-text: {{ section.settings.checkout_text | default: '#FFFFFF' }};
    
    /* Empty Cart Colors */
    --empty-cart-bg: {{ section.settings.empty_cart_bg | default: '#F9FAFB' }};
    --empty-title-color: {{ section.settings.empty_title_color | default: '#111827' }};
    --empty-text-color: {{ section.settings.empty_text_color | default: '#6B7280' }};
    --empty-icon-color: {{ section.settings.empty_icon_color | default: '#9CA3AF' }};
    
    /* Continue Button Colors */
    --continue-bg: {{ section.settings.continue_bg | default: '#000000' }};
    --continue-hover: {{ section.settings.continue_hover | default: '#1F2937' }};
    --continue-text: {{ section.settings.continue_text | default: '#FFFFFF' }};
    
    /* Sizes */
    --summary-radius: {{ section.settings.summary_radius | default: '12' }}px;
    --image-radius: {{ section.settings.image_radius | default: '8' }}px;
    --button-radius: {{ section.settings.button_radius | default: '6' }}px;
  }

  @media (min-width: 640px) {
    #cart-{{ section.id }} {
      --cart-padding-x: {{ section.settings.padding_x_sm | default: '24' }}px;
    }
  }

  @media (min-width: 1024px) {
    #cart-{{ section.id }} {
      --cart-padding-x: {{ section.settings.padding_x_lg | default: '32' }}px;
    }
  }

  .cart-section-{{ section.id }} {
    max-width: var(--cart-max-width);
    margin: 0 auto;
    padding: var(--cart-padding-y) var(--cart-padding-x);
    background-color: var(--cart-bg);
  }

  /* Text Colors */
  .cart-heading-{{ section.id }} {
    color: var(--heading-color);
    font-size: {{ section.settings.heading_size | default: '30' }}px;
    font-weight: {{ section.settings.heading_weight | default: '700' }};
    margin-bottom: {{ section.settings.heading_margin | default: '32' }}px;
  }

  .cart-title-{{ section.id }} {
    color: var(--title-color);
    font-size: {{ section.settings.title_size | default: '18' }}px;
    font-weight: {{ section.settings.title_weight | default: '500' }};
  }

  .cart-title-{{ section.id }} a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .cart-title-{{ section.id }} a:hover {
    color: var(--link-hover);
  }

  .cart-text-{{ section.id }} {
    color: var(--body-text-color);
    font-size: {{ section.settings.body_size | default: '16' }}px;
  }

  .cart-light-text-{{ section.id }} {
    color: var(--light-text-color);
    font-size: {{ section.settings.light_size | default: '14' }}px;
  }

  .cart-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ section.settings.grid_gap | default: '32' }}px;
  }

  @media (min-width: 1024px) {
    .cart-grid-{{ section.id }} {
      grid-template-columns: {{ section.settings.items_column_width | default: '2fr' }} {{ section.settings.summary_column_width | default: '1fr' }};
    }
  }

  .cart-items-{{ section.id }} {
    space-y: {{ section.settings.items_spacing | default: '24' }}px;
  }

  .cart-item-{{ section.id }} {
    display: flex;
    gap: {{ section.settings.item_gap | default: '16' }}px;
    padding-bottom: {{ section.settings.item_padding | default: '24' }}px;
    border-bottom: 1px solid var(--border-color);
  }

  .item-image-{{ section.id }} {
    width: {{ section.settings.image_size | default: '96' }}px;
    height: {{ section.settings.image_size | default: '96' }}px;
    flex-shrink: 0;
    background-color: var(--item-bg);
    border-radius: var(--image-radius);
    overflow: hidden;
  }

  .item-image-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .item-details-{{ section.id }} {
    flex: 1;
  }

  .item-price-{{ section.id }} {
    color: var(--price-color);
    font-size: {{ section.settings.price_size | default: '18' }}px;
    font-weight: {{ section.settings.price_weight | default: '500' }};
  }

  .item-controls-{{ section.id }} {
    display: flex;
    align-items: center;
    margin-top: {{ section.settings.controls_margin | default: '12' }}px;
  }

  .quantity-control-{{ section.id }} {
    display: inline-flex;
    border: 1px solid var(--border-color);
    border-radius: {{ section.settings.quantity_radius | default: '6' }}px;
    overflow: hidden;
  }

  .quantity-btn-{{ section.id }} {
    padding: {{ section.settings.quantity_padding | default: '8' }}px {{ section.settings.quantity_padding_x | default: '12' }}px;
    color: var(--quantity-btn-color);
    background: transparent;
    border: none;
    cursor: pointer;
    transition: all {{ section.settings.transition_speed | default: '200' }}ms ease;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  .quantity-btn-{{ section.id }}:hover {
    color: var(--quantity-btn-hover);
    background-color: var(--item-bg);
  }

  .quantity-display-{{ section.id }} {
    width: {{ section.settings.quantity_width | default: '48' }}px;
    text-align: center;
    padding: {{ section.settings.quantity_padding | default: '8' }}px 0;
    border-left: 1px solid var(--border-color);
    border-right: 1px solid var(--border-color);
    color: var(--body-text-color);
  }

  .remove-link-{{ section.id }} {
    margin-left: {{ section.settings.remove_spacing | default: '16' }}px;
    color: var(--remove-color);
    font-size: {{ section.settings.remove_size | default: '14' }}px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: {{ section.settings.remove_icon_gap | default: '4' }}px;
    transition: color {{ section.settings.transition_speed | default: '200' }}ms ease;
  }

  .remove-link-{{ section.id }}:hover {
    color: var(--remove-hover);
  }

  .summary-card-{{ section.id }} {
    background-color: var(--summary-bg);
    border-radius: var(--summary-radius);
    padding: {{ section.settings.summary_padding | default: '24' }}px;
    position: sticky;
    top: {{ section.settings.summary_sticky_offset | default: '24' }}px;
  }

  .summary-title-{{ section.id }} {
    color: var(--summary-heading);
    font-size: {{ section.settings.summary_title_size | default: '20' }}px;
    font-weight: {{ section.settings.summary_title_weight | default: '700' }};
    margin-bottom: {{ section.settings.summary_title_margin | default: '16' }}px;
  }

  .summary-row-{{ section.id }} {
    display: flex;
    justify-content: space-between;
    color: var(--summary-text);
    font-size: {{ section.settings.summary_text_size | default: '16' }}px;
    margin-bottom: {{ section.settings.summary_row_spacing | default: '12' }}px;
  }

  .summary-divider-{{ section.id }} {
    height: 1px;
    background-color: var(--border-color);
    margin: {{ section.settings.summary_divider_margin | default: '16' }}px 0;
  }

  .summary-total-{{ section.id }} {
    display: flex;
    justify-content: space-between;
    color: var(--total-color);
    font-size: {{ section.settings.total_size | default: '20' }}px;
    font-weight: {{ section.settings.total_weight | default: '700' }};
    margin-bottom: {{ section.settings.total_margin | default: '24' }}px;
  }

  .checkout-btn-{{ section.id }} {
    width: 100%;
    background-color: var(--checkout-bg);
    color: var(--checkout-text);
    font-weight: {{ section.settings.checkout_weight | default: '500' }};
    padding: {{ section.settings.checkout_padding | default: '12' }}px {{ section.settings.checkout_padding_x | default: '24' }}px;
    border-radius: var(--button-radius);
    border: none;
    cursor: pointer;
    transition: all {{ section.settings.transition_speed | default: '200' }}ms ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: {{ section.settings.checkout_icon_gap | default: '8' }}px;
    text-decoration: none;
  }

  .checkout-btn-{{ section.id }}:hover {
    background-color: var(--checkout-hover);
  }

  .empty-cart-{{ section.id }} {
    text-align: center;
    padding: {{ section.settings.empty_padding | default: '80' }}px {{ section.settings.empty_padding_x | default: '20' }}px;
    background-color: var(--empty-cart-bg);
    border-radius: {{ section.settings.empty_radius | default: '12' }}px;
  }

  .empty-title-{{ section.id }} {
    color: var(--empty-title-color);
    font-size: {{ section.settings.empty_title_size | default: '24' }}px;
    font-weight: {{ section.settings.empty_title_weight | default: '700' }};
    margin: {{ section.settings.empty_title_margin | default: '16' }}px 0 {{ section.settings.empty_text_margin | default: '8' }}px;
  }

  .empty-text-{{ section.id }} {
    color: var(--empty-text-color);
    font-size: {{ section.settings.empty_text_size | default: '16' }}px;
    margin-bottom: {{ section.settings.empty_text_bottom_margin | default: '24' }}px;
  }

  .continue-btn-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: {{ section.settings.continue_icon_gap | default: '8' }}px;
    background-color: var(--continue-bg);
    color: var(--continue-text);
    font-weight: {{ section.settings.continue_weight | default: '500' }};
    padding: {{ section.settings.continue_padding | default: '12' }}px {{ section.settings.continue_padding_x | default: '32' }}px;
    border-radius: var(--button-radius);
    text-decoration: none;
    transition: all {{ section.settings.transition_speed | default: '200' }}ms ease;
  }

  .continue-btn-{{ section.id }}:hover {
    background-color: var(--continue-hover);
  }

  @media (max-width: 640px) {
    .cart-item-{{ section.id }} {
      flex-direction: column;
    }

    .item-controls-{{ section.id }} {
      flex-wrap: wrap;
    }

    .summary-card-{{ section.id }} {
      position: static;
    }
  }
</style>

<div id="cart-{{ section.id }}" class="cart-section-{{ section.id }}" {{ section.shopify_attributes }}>
  {% if cart.item_count > 0 %}
    
    <!-- Cart Title -->
    <h1 class="cart-heading-{{ section.id }}">
      {{ section.settings.cart_title | default: 'Your Shopping Cart' }}
    </h1>

    <form action="{{ routes.cart_url }}" method="post" id="cart-form">
      <div class="cart-grid-{{ section.id }}">
        
        <!-- Cart Items -->
        <div class="cart-items-{{ section.id }}">
          {% for item in cart.items %}
            <div class="cart-item-{{ section.id }}">
              
              <!-- Product Image -->
              <div class="item-image-{{ section.id }}">
                <a href="{{ item.url }}">
                  <img src="{{ item.image | image_url: width: 200 }}" 
                       loading="lazy" 
                       alt="{{ item.image.alt | escape }}"
                       width="200"
                       height="200">
                </a>
              </div>

              <!-- Product Details -->
              <div class="item-details-{{ section.id }}">
                <div class="flex justify-between items-start">
                  <div>
                    <h3 class="cart-title-{{ section.id }}">
                      <a href="{{ item.url }}">{{ item.product.title }}</a>
                    </h3>
                    {% unless item.product.has_only_default_variant %}
                      <p class="cart-light-text-{{ section.id }}">{{ item.variant.title }}</p>
                    {% endunless %}
                  </div>
                  <div class="item-price-{{ section.id }}">
                    {{ item.final_line_price | money }}
                  </div>
                </div>

                <!-- Quantity Controls -->
                <div class="item-controls-{{ section.id }}">
                  <div class="quantity-control-{{ section.id }}">
                    <a href="/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | minus: 1 }}" 
                       class="quantity-btn-{{ section.id }}"
                       aria-label="Decrease quantity">
                      {% render 'icon-minus', 
                        size: section.settings.icon_size | default: 4, 
                        color: 'currentColor' 
                      %}
                    </a>
                    
                    <span class="quantity-display-{{ section.id }}">
                      {{ item.quantity }}
                    </span>
                    
                    <a href="/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | plus: 1 }}" 
                       class="quantity-btn-{{ section.id }}"
                       aria-label="Increase quantity">
                      {% render 'icon-plus', 
                        size: section.settings.icon_size | default: 4, 
                        color: 'currentColor' 
                      %}
                    </a>
                  </div>
                  
                  <a href="/cart/change?line={{ forloop.index }}&quantity=0" 
                     class="remove-link-{{ section.id }}">
                    {% render 'icon-remove', 
                      size: section.settings.icon_size_small | default: 4, 
                      color: 'currentColor' 
                    %}
                    {{ section.settings.remove_text | default: 'Remove' }}
                  </a>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>

        <!-- Order Summary -->
        <div>
          <div class="summary-card-{{ section.id }}">
            <h2 class="summary-title-{{ section.id }}">
              {{ section.settings.summary_title | default: 'Order Summary' }}
            </h2>
            
            <div class="summary-row-{{ section.id }}">
              <span>{{ section.settings.subtotal_text | default: 'Subtotal' }}</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
            
            {% if cart.total_discounts > 0 %}
              <div class="summary-row-{{ section.id }}" style="color: var(--discount-color);">
                <span>{{ section.settings.discount_text | default: 'Discounts' }}</span>
                <span>-{{ cart.total_discounts | money }}</span>
              </div>
            {% endif %}
            
            <div class="summary-divider-{{ section.id }}"></div>
            
            <div class="summary-total-{{ section.id }}">
              <span>{{ section.settings.total_text | default: 'Total' }}</span>
              <span>{{ cart.total_price | money }}</span>
            </div>

            <button type="submit" name="checkout" class="checkout-btn-{{ section.id }}">
              {{ section.settings.checkout_text | default: 'Proceed to Checkout' }}
              {% render 'icon-arrow-right', 
                size: section.settings.icon_size | default: 5, 
                color: 'currentColor' 
              %}
            </button>
          </div>
        </div>
      </div>
    </form>

  {% else %}
    <!-- Empty Cart -->
    <div class="empty-cart-{{ section.id }}">
      {% render 'icon-shopping-bag', 
        size: section.settings.empty_icon_size | default: 16, 
        color: section.settings.empty_icon_color | default: '#9CA3AF',
        class: 'mx-auto mb-4'
      %}
      
      <h2 class="empty-title-{{ section.id }}">
        {{ section.settings.empty_title | default: 'Your Cart is Empty' }}
      </h2>
      
      <p class="empty-text-{{ section.id }}">
        {{ section.settings.empty_message | default: 'Looks like you haven\'t added anything to your cart yet.' }}
      </p>
      
      <!-- Redirect to specific product page -->
      <a href="{% if single_product.url != blank %}{{ single_product.url }}{% else %}{{ section.settings.fallback_url | default: '/collections/all' }}{% endif %}" 
         class="continue-btn-{{ section.id }}">
        {% render 'icon-arrow-left', 
          size: section.settings.icon_size | default: 5, 
          color: 'currentColor' 
        %}
        {{ section.settings.continue_text | default: 'Continue Shopping' }}
      </a>
    </div>
  {% endif %}
</div>