{% comment %}
  Contact Page - Fully customizable through Shopify editor
  Features: Contact form with validation, success/error messages, and responsive design
{% endcomment %}

<style>
  #contact-page-{{ section.id }} {
    --contact-max-width: {{ section.settings.max_width | default: '768' }}px;
    --contact-padding-y: {{ section.settings.padding_y | default: '32' }}px;
    --contact-padding-x: {{ section.settings.padding_x | default: '16' }}px;
    --contact-bg: {{ section.settings.contact_bg | default: '#FFFFFF' }};
    --contact-radius: {{ section.settings.contact_radius | default: '8' }}px;
    --contact-shadow: {{ section.settings.contact_shadow | default: '0 10px 15px -3px rgb(0 0 0 / 0.1)' }};
    
    /* Title Colors */
    --title-color: {{ section.settings.title_color | default: '#1F2937' }};
    --title-size: {{ section.settings.title_size | default: '30' }}px;
    
    /* Form Colors */
    --label-color: {{ section.settings.label_color | default: '#374151' }};
    --label-size: {{ section.settings.label_size | default: '14' }}px;
    --input-bg: {{ section.settings.input_bg | default: '#FFFFFF' }};
    --input-border: {{ section.settings.input_border | default: '#D1D5DB' }};
    --input-focus-ring: {{ section.settings.input_focus_ring | default: '#3B82F6' }};
    --input-text: {{ section.settings.input_text | default: '#111827' }};
    --input-placeholder: {{ section.settings.input_placeholder | default: '#9CA3AF' }};
    --input-radius: {{ section.settings.input_radius | default: '6' }}px;
    --input-padding-y: {{ section.settings.input_padding_y | default: '8' }}px;
    --input-padding-x: {{ section.settings.input_padding_x | default: '16' }}px;
    
    /* Button Colors */
    --button-bg: {{ section.settings.button_bg | default: '#2563EB' }};
    --button-hover: {{ section.settings.button_hover | default: '#1D4ED8' }};
    --button-text: {{ section.settings.button_text | default: '#FFFFFF' }};
    --button-weight: {{ section.settings.button_weight | default: '600' }};
    --button-radius: {{ section.settings.button_radius | default: '6' }}px;
    --button-padding-y: {{ section.settings.button_padding_y | default: '12' }}px;
    --button-padding-x: {{ section.settings.button_padding_x | default: '16' }}px;
    
    /* Success Message Colors */
    --success-bg: {{ section.settings.success_bg | default: '#D1FAE5' }};
    --success-border: {{ section.settings.success_border | default: '#10B981' }};
    --success-text: {{ section.settings.success_text | default: '#065F46' }};
    --success-radius: {{ section.settings.success_radius | default: '8' }}px;
    
    /* Error Message Colors */
    --error-bg: {{ section.settings.error_bg | default: '#FEE2E2' }};
    --error-border: {{ section.settings.error_border | default: '#EF4444' }};
    --error-text: {{ section.settings.error_text | default: '#B91C1C' }};
    --error-radius: {{ section.settings.error_radius | default: '8' }}px;
    
    /* Icon Colors */
    --icon-color: {{ section.settings.icon_color | default: '#6B7280' }};
    --icon-size: {{ section.settings.icon_size | default: '5' }};
  }

  @media (min-width: 640px) {
    #contact-page-{{ section.id }} {
      --contact-padding-x: {{ section.settings.padding_x_sm | default: '24' }}px;
      --contact-padding-y: {{ section.settings.padding_y_sm | default: '48' }}px;
    }
  }

  .contact-section-{{ section.id }} {
    max-width: var(--contact-max-width);
    margin: 0 auto;
    padding: var(--contact-padding-y) var(--contact-padding-x);
  }

  .contact-card-{{ section.id }} {
    background-color: var(--contact-bg);
    border-radius: var(--contact-radius);
    box-shadow: var(--contact-shadow);
    padding: {{ section.settings.card_padding | default: '32' }}px;
  }

  .contact-title-{{ section.id }} {
    color: var(--title-color);
    font-size: var(--title-size);
    font-weight: {{ section.settings.title_weight | default: '700' }};
    text-align: {{ section.settings.title_align | default: 'center' }};
    margin-bottom: {{ section.settings.title_margin | default: '24' }}px;
  }

  .form-group-{{ section.id }} {
    margin-bottom: {{ section.settings.field_spacing | default: '20' }}px;
  }

  .form-label-{{ section.id }} {
    display: block;
    margin-bottom: {{ section.settings.label_margin | default: '8' }}px;
    color: var(--label-color);
    font-size: var(--label-size);
    font-weight: {{ section.settings.label_weight | default: '500' }};
  }

  .input-wrapper-{{ section.id }} {
    position: relative;
    display: flex;
    align-items: center;
  }

  .input-icon-{{ section.id }} {
    position: absolute;
    left: {{ section.settings.input_padding_x | default: '16' }}px;
    color: var(--icon-color);
    pointer-events: none;
    z-index: 10;
  }

  .form-input-{{ section.id }} {
    width: 100%;
    padding: var(--input-padding-y) var(--input-padding-x);
    {% if section.settings.show_icons %}
      padding-left: calc({{ section.settings.input_padding_x | default: '16' }}px + {{ section.settings.icon_size | default: '5' }} * 4px + 8px);
    {% endif %}
    background-color: var(--input-bg);
    border: 1px solid var(--input-border);
    border-radius: var(--input-radius);
    color: var(--input-text);
    font-size: {{ section.settings.input_font_size | default: '16' }}px;
    transition: all {{ section.settings.transition_speed | default: '150' }}ms ease;
  }

  .form-input-{{ section.id }}:focus {
    outline: none;
    border-color: var(--input-focus-ring);
    box-shadow: 0 0 0 3px {{ section.settings.input_focus_ring | default: '#3B82F6' }}20;
  }

  .form-input-{{ section.id }}::placeholder {
    color: var(--input-placeholder);
    font-size: {{ section.settings.placeholder_size | default: '14' }}px;
  }

  textarea.form-input-{{ section.id }} {
    resize: {{ section.settings.textarea_resize | default: 'vertical' }};
    min-height: {{ section.settings.textarea_height | default: '120' }}px;
  }

  .submit-btn-{{ section.id }} {
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: {{ section.settings.button_icon_gap | default: '8' }}px;
    background-color: var(--button-bg);
    color: var(--button-text);
    font-weight: var(--button-weight);
    font-size: {{ section.settings.button_font_size | default: '16' }}px;
    padding: var(--button-padding-y) var(--button-padding-x);
    border: none;
    border-radius: var(--button-radius);
    cursor: pointer;
    transition: all {{ section.settings.transition_speed | default: '150' }}ms ease;
  }

  .submit-btn-{{ section.id }}:hover {
    background-color: var(--button-hover);
    transform: translateY(-1px);
    box-shadow: {{ section.settings.button_shadow | default: '0 4px 6px -1px rgb(0 0 0 / 0.1)' }};
  }

  .submit-btn-{{ section.id }}:active {
    transform: translateY(0);
  }

  .success-message-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: {{ section.settings.message_icon_gap | default: '8' }}px;
    padding: {{ section.settings.message_padding | default: '12' }}px {{ section.settings.message_padding_x | default: '16' }}px;
    margin-bottom: {{ section.settings.message_margin | default: '16' }}px;
    background-color: var(--success-bg);
    border: 1px solid var(--success-border);
    border-radius: var(--success-radius);
    color: var(--success-text);
    font-size: {{ section.settings.message_font_size | default: '14' }}px;
  }

  .error-message-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: {{ section.settings.message_icon_gap | default: '8' }}px;
    padding: {{ section.settings.message_padding | default: '12' }}px {{ section.settings.message_padding_x | default: '16' }}px;
    margin-bottom: {{ section.settings.message_margin | default: '16' }}px;
    background-color: var(--error-bg);
    border: 1px solid var(--error-border);
    border-radius: var(--error-radius);
    color: var(--error-text);
    font-size: {{ section.settings.message_font_size | default: '14' }}px;
  }

  .required-badge-{{ section.id }} {
    color: {{ section.settings.required_color | default: '#DC2626' }};
    margin-left: 2px;
  }

  @media (max-width: 640px) {
    .contact-card-{{ section.id }} {
      padding: {{ section.settings.card_padding_mobile | default: '20' }}px;
    }
  }
</style>

<div id="contact-page-{{ section.id }}" class="contact-section-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="contact-card-{{ section.id }}">
    
    <!-- Page Title -->
    <h1 class="contact-title-{{ section.id }}">
      {{ page.title | default: section.settings.default_title | default: 'Contact Us' }}
    </h1>

    {% form 'contact' %}

      <!-- Success Message -->
      {% if form.posted_successfully? %}
        <div class="success-message-{{ section.id }}" role="alert">
          {% render 'icon-success', 
            size: section.settings.message_icon_size | default: 5,
            color: section.settings.success_text
          %}
          <span>
            <span class="font-medium">{{ section.settings.success_title | default: 'Success!' }}</span>
            {{ section.settings.success_message | default: 'Thank you for your message. We\'ll get back to you soon.' }}
          </span>
        </div>
      {% endif %}

      <!-- Error Message -->
      {% if form.errors %}
        <div class="error-message-{{ section.id }}" role="alert">
          {% render 'icon-error', 
            size: section.settings.message_icon_size | default: 5,
            color: section.settings.error_text
          %}
          <span>
            <span class="font-medium">{{ section.settings.error_title | default: 'Error:' }}</span>
            {{ form.errors | default_errors }}
          </span>
        </div>
      {% endif %}

      <!-- Name Field -->
      <div class="form-group-{{ section.id }}">
        <label for="ContactFormName" class="form-label-{{ section.id }}">
          {{ section.settings.name_label | default: 'Name' }}
          {% if section.settings.name_required %}<span class="required-badge-{{ section.id }}">*</span>{% endif %}
        </label>
        <div class="input-wrapper-{{ section.id }}">
          {% if section.settings.show_icons %}
            <span class="input-icon-{{ section.id }}">
              {% render 'icon-user', 
                size: section.settings.icon_size | default: 5,
                color: section.settings.icon_color
              %}
            </span>
          {% endif %}
          <input 
            type="text" 
            id="ContactFormName" 
            name="contact[name]" 
            class="form-input-{{ section.id }}"
            placeholder="{{ section.settings.name_placeholder | default: 'Your name' }}"
            {% if section.settings.name_required %}required{% endif %}
            value="{% if form.name %}{{ form.name }}{% endif %}"
          >
        </div>
      </div>

      <!-- Email Field -->
      <div class="form-group-{{ section.id }}">
        <label for="ContactFormEmail" class="form-label-{{ section.id }}">
          {{ section.settings.email_label | default: 'Email' }}
          <span class="required-badge-{{ section.id }}">*</span>
        </label>
        <div class="input-wrapper-{{ section.id }}">
          {% if section.settings.show_icons %}
            <span class="input-icon-{{ section.id }}">
              {% render 'icon-mail', 
                size: section.settings.icon_size | default: 5,
                color: section.settings.icon_color
              %}
            </span>
          {% endif %}
          <input 
            type="email" 
            id="ContactFormEmail" 
            name="contact[email]" 
            class="form-input-{{ section.id }}"
            placeholder="{{ section.settings.email_placeholder | default: 'you@example.com' }}"
            required
            value="{% if form.email %}{{ form.email }}{% endif %}"
          >
        </div>
      </div>

      <!-- Phone Field -->
      {% if section.settings.show_phone %}
        <div class="form-group-{{ section.id }}">
          <label for="ContactFormPhone" class="form-label-{{ section.id }}">
            {{ section.settings.phone_label | default: 'Phone' }}
            {% if section.settings.phone_required %}<span class="required-badge-{{ section.id }}">*</span>{% endif %}
          </label>
          <div class="input-wrapper-{{ section.id }}">
            {% if section.settings.show_icons %}
              <span class="input-icon-{{ section.id }}">
                {% render 'icon-phone', 
                  size: section.settings.icon_size | default: 5,
                  color: section.settings.icon_color
                %}
              </span>
            {% endif %}
            <input 
              type="tel" 
              id="ContactFormPhone" 
              name="contact[phone]" 
              class="form-input-{{ section.id }}"
              placeholder="{{ section.settings.phone_placeholder | default: '(123) 456-7890' }}"
              {% if section.settings.phone_required %}required{% endif %}
              value="{% if form.phone %}{{ form.phone }}{% endif %}"
            >
          </div>
        </div>
      {% endif %}

      <!-- Message Field -->
      <div class="form-group-{{ section.id }}">
        <label for="ContactFormMessage" class="form-label-{{ section.id }}">
          {{ section.settings.message_label | default: 'Message' }}
          <span class="required-badge-{{ section.id }}">*</span>
        </label>
        <div class="input-wrapper-{{ section.id }}">
          {% if section.settings.show_icons %}
            <span class="input-icon-{{ section.id }}" style="top: {{ section.settings.input_padding_y | default: '8' }}px;">
              {% render 'icon-message', 
                size: section.settings.icon_size | default: 5,
                color: section.settings.icon_color
              %}
            </span>
          {% endif %}
          <textarea 
            rows="{{ section.settings.textarea_rows | default: '6' }}" 
            id="ContactFormMessage" 
            name="contact[body]" 
            class="form-input-{{ section.id }}"
            placeholder="{{ section.settings.message_placeholder | default: 'Write your message here...' }}"
            required
          >{% if form.body %}{{ form.body }}{% endif %}</textarea>
        </div>
      </div>

      <!-- Submit Button -->
      <button type="submit" class="submit-btn-{{ section.id }}">
        {{ section.settings.button_text | default: 'Send Message' }}
        {% render 'icon-send', 
          size: section.settings.button_icon_size | default: 5,
          color: section.settings.button_text
        %}
      </button>

    {% endform %}
  </div>
</div>

{% schema %}
{
  "name": "Contact Page",
  "settings": [
    {
      "type": "header",
