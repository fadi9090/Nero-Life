      "options": [
        { "value": "none", "label": "None" },
        { "value": "0 4px 6px -1px rgb(0 0 0 / 0.1)", "label": "Medium" },
        { "value": "0 10px 15px -3px rgb(0 0 0 / 0.1)", "label": "Large" },
        { "value": "0 20px 25px -5px rgb(0 0 0 / 0.1)", "label": "XL" }
      ],
      "default": "0 10px 15px -3px rgb(0 0 0 / 0.1)"
    },
    {
      "type": "range",
      "id": "max_width",
