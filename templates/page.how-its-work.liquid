    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 4,
      "max": 24,
      "step": 2,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#374151"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#4B5563"
    },
    {
      "type": "color",
      "id": "light_text",
      "label": "Light text",
      "default": "#6B7280"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary color",
      "default": "#3B82F6"
    },
    {
      "type": "color",
      "id": "primary_light",
      "label": "Primary light",
      "default": "#EFF6FF"
    },
    {
      "type": "color",
      "id": "secondary_color",
      "label": "Secondary color",
      "default": "#8B5CF6"
    },
    {
      "type": "color",
      "id": "secondary_light",
      "label": "Secondary light",
      "default": "#EDE9FE"
    },
    {
      "type": "color",
      "id": "success_color",
      "label": "Success color",
      "default": "#10B981"
    },
    {
      "type": "color",
      "id": "success_light",
      "label": "Success light",
      "default": "#D1FAE5"
    },
    {
      "type": "color",
      "id": "warning_color",
      "label": "Warning color",
      "default": "#F59E0B"
    },
    {
      "type": "color",
      "id": "warning_light",
      "label": "Warning light",
      "default": "#FEF3C7"
