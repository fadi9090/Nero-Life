{% comment %}
  Icon: Shopping Cart
  Usage: {% render 'icon-cart', size: 6, color: '#000000', show_count: true, count: cart.item_count %}
{% endcomment %}

{%- assign size = size | default: 6 -%}
{%- assign color = color | default: 'currentColor' -%}
{%- assign stroke = stroke_width | default: 1.5 -%}
{%- assign custom_class = class | default: '' -%}
{%- assign show_count = show_count | default: false -%}
{%- assign count = count | default: 0 -%}

<div class="relative inline-flex">
  <svg xmlns="http://www.w3.org/2000/svg" 
       class="w-{{ size }} h-{{ size }} {{ custom_class }}" 
       fill="none" 
       viewBox="0 0 24 24" 
       stroke="{{ color }}" 
       stroke-width="{{ stroke }}">
    <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
  </svg>
  
  {% if show_count and count > 0 %}
    <span class="absolute -top-2 -right-2 bg-red-500 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center">
      {{ count }}
    </span>
  {% endif %}
</div>