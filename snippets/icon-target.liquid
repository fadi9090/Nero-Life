{% comment %}
  Icon: Target / Goals
  Usage: {% render 'icon-target', size: 6, color: '#F59E0B', class: '' %}
{% endcomment %}

{%- assign size = size | default: 6 -%}
{%- assign color = color | default: 'currentColor' -%}
{%- assign stroke = stroke_width | default: 1.5 -%}
{%- assign custom_class = class | default: '' -%}

<svg xmlns="http://www.w3.org/2000/svg" 
     class="w-{{ size }} h-{{ size }} {{ custom_class }}" 
     fill="none" 
     viewBox="0 0 24 24" 
     stroke="{{ color }}" 
     stroke-width="{{ stroke }}">
