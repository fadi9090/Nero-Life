{% comment %}
  Icon: Clock / Time
  Usage: {% render 'icon-clock', size: 6, color: '#000000', class: '', stroke_width: 1.5 %}
{% endcomment %}

{%- assign size = size | default: 6 -%}
{%- assign color = color | default: 'currentColor' -%}
{%- assign stroke = stroke_width | default: 1.5 -%}
{%- assign custom_class = class | default: '' -%}

<svg xmlns="http://www.w3.org/2000/svg" 
     class="w-{{ size }} h-{{ size }} {{ custom_class }}" 
     fill="none" 
     viewBox="0 0 24 24" 
     stroke="{{ color }}" 
     stroke-width="{{ stroke }}">
  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
</svg>