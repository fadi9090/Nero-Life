{% comment %}
  Product Description - Fully customizable with icons
{% endcomment %}

<style>
  #product-desc-{{ section.id }} {
    --desc-bg: {{ section.settings.desc_bg | default: '#FFFFFF' }};
    --desc-border: {{ section.settings.desc_border | default: '#F3F4F6' }};
    --desc-shadow: {{ section.settings.desc_shadow | default: '0 10px 15px -3px rgb(0 0 0 / 0.1)' }};
    --desc-radius: {{ section.settings.desc_radius | default: '12' }}px;
    --desc-padding: {{ section.settings.desc_padding | default: '32' }}px;
    --title-color: {{ section.settings.title_color | default: '#1F2937' }};
    --title-size: {{ section.settings.title_size | default: '24' }}px;
    --text-color: {{ section.settings.text_color | default: '#4B5563' }};
    --text-size: {{ section.settings.text_size | default: '16' }}px;
    --accent-bg: {{ section.settings.accent_bg | default: '#EFF6FF' }};
    --accent-border: {{ section.settings.accent_border | default: '#3B82F6' }};
    --feature-color: {{ section.settings.feature_color | default: '#10B981' }};
    --highlight-color: {{ section.settings.highlight_color | default: '#1F2937' }};
  }

  .desc-section-{{ section.id }} {
    background-color: var(--desc-bg);
    border-radius: var(--desc-radius);
    padding: var(--desc-padding);
    box-shadow: var(--desc-shadow);
    border: 1px solid var(--desc-border);
    max-width: {{ section.settings.max_width | default: '1280' }}px;
    margin: 0 auto;
  }

  .desc-title-{{ section.id }} {
    color: var(--title-color);
    font-size: var(--title-size);
    font-weight: {{ section.settings.title_weight | default: '700' }};
    margin-bottom: {{ section.settings.title_margin | default: '16' }}px;
  }

  .desc-text-{{ section.id }} {
    color: var(--text-color);
    font-size: var(--text-size);
    line-height: {{ section.settings.text_line_height | default: '1.625' }};
  }

  .desc-text-{{ section.id }} p {
    margin-bottom: {{ section.settings.paragraph_margin | default: '16' }}px;
  }

  .highlight-{{ section.id }} {
    color: var(--highlight-color);
    font-weight: {{ section.settings.highlight_weight | default: '600' }};
    background-color: {{ section.settings.highlight_bg | default: '#EFF6FF' }};
    padding: 2px 4px;
    border-radius: 4px;
  }

  .feature-box-{{ section.id }} {
    background-color: var(--accent-bg);
    border-radius: {{ section.settings.feature_radius | default: '8' }}px;
    padding: {{ section.settings.feature_padding | default: '20' }}px;
    margin: {{ section.settings.feature_margin | default: '24' }}px 0;
    border-left: {{ section.settings.feature_border_width | default: '4' }}px solid var(--accent-border);
  }

  .feature-title-{{ section.id }} {
    color: var(--title-color);
    font-size: {{ section.settings.feature_title_size | default: '18' }}px;
    font-weight: {{ section.settings.feature_title_weight | default: '600' }};
    margin-bottom: {{ section.settings.feature_title_margin | default: '12' }}px;
    display: flex;
    align-items: center;
    gap: {{ section.settings.feature_icon_gap | default: '8' }}px;
  }

  .feature-list-{{ section.id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .feature-item-{{ section.id }} {
    display: flex;
    align-items: flex-start;
    gap: {{ section.settings.bullet_gap | default: '8' }}px;
    margin-bottom: {{ section.settings.bullet_spacing | default: '12' }}px;
    color: var(--text-color);
    font-size: var(--text-size);
  }

  .bullet-icon-{{ section.id }} {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .note-box-{{ section.id }} {
    background-color: var(--accent-bg);
    border-radius: {{ section.settings.note_radius | default: '8' }}px;
    padding: {{ section.settings.note_padding | default: '16' }}px;
    border-left: {{ section.settings.note_border_width | default: '4' }}px solid var(--accent-border);
    margin-top: {{ section.settings.note_margin | default: '16' }}px;
    font-style: {{ section.settings.note_style | default: 'normal' }};
  }
</style>

<div id="product-desc-{{ section.id }}" class="desc-section-{{ section.id }}" {{ section.shopify_attributes }}>
  <!-- Title -->
  <h2 class="desc-title-{{ section.id }}">
    {{ section.settings.title | default: 'Product Description' }}
  </h2>

  <!-- Description Content -->
  <div class="desc-text-{{ section.id }}">
    <p>
      {{ section.settings.paragraph_1 | default: 'Bring professional skincare technology into your home with the <span class="highlight-">14™ Silicone Face & Neck Photon Rejuvenation Mask</span>.' }}
    </p>
    
    <p>
      {{ section.settings.paragraph_2 | default: 'Designed with ultra-soft, skin-friendly silicone, this mask fits tightly to the contours of your face and neck — ensuring deep light absorption with minimal light leakage. Its flexible, bendable structure makes it comfortable to wear while sitting, lying down, or moving around.' }}
    </p>
  </div>

  <!-- Features Box -->
  {% if section.settings.show_features %}
    <div class="feature-box-{{ section.id }}">
      <h3 class="feature-title-{{ section.id }}">
        {% render 'icon-star', size: 5, color: '#3B82F6', filled: true %}
        {{ section.settings.feature_box_title | default: 'Key Features' }}
      </h3>
      
      <ul class="feature-list-{{ section.id }}">
        {% for i in (1..section.settings.feature_count) %}
          {% assign feature_text = 'feature_' | append: i %}
          {% if section.settings[feature_text] != blank %}
            <li class="feature-item-{{ section.id }}">
              <span class="bullet-icon-{{ section.id }}">
                {% render 'icon-check-circle', size: 5, color: section.settings.feature_color, class: 'mt-0.5' %}
              </span>
              <span>{{ section.settings[feature_text] }}</span>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  {% endif %}

  <!-- Note Box -->
  {% if section.settings.show_note %}
    <div class="note-box-{{ section.id }}">
      <p class="desc-text-{{ section.id }} m-0">
        {{ section.settings.note_text | default: 'Whether you are looking to brighten your complexion, reduce the appearance of fine lines, or support healthier, firmer skin, the 14™ mask delivers consistent, targeted light therapy.' }}
      </p>
    </div>
  {% endif %}
</div>

