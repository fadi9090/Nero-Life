{% comment %}
  Product Reviews - Customer testimonials with star ratings
  Fully customizable
{% endcomment %}

<style>
  #product-reviews-{{ section.id }} {
    --reviews-bg: {{ section.settings.reviews_bg | default: '#FFFFFF' }};
    --reviews-border: {{ section.settings.reviews_border | default: '#F3F4F6' }};
    --reviews-shadow: {{ section.settings.reviews_shadow | default: '0 10px 15px -3px rgb(0 0 0 / 0.1)' }};
    --reviews-radius: {{ section.settings.reviews_radius | default: '12' }}px;
    --reviews-padding: {{ section.settings.reviews_padding | default: '32' }}px;
    --title-color: {{ section.settings.title_color | default: '#1F2937' }};
    --title-size: {{ section.settings.title_size | default: '24' }}px;
    --card-bg: {{ section.settings.card_bg | default: '#F9FAFB' }};
    --card-border: {{ section.settings.card_border | default: '#E5E7EB' }};
    --card-shadow: {{ section.settings.card_shadow | default: '0 1px 2px 0 rgb(0 0 0 / 0.05)' }};
    --card-radius: {{ section.settings.card_radius | default: '8' }}px;
    --card-padding: {{ section.settings.card_padding | default: '24' }}px;
    --star-color: {{ section.settings.star_color | default: '#FBBF24' }};
    --star-empty-color: {{ section.settings.star_empty_color | default: '#D1D5DB' }};
    --quote-color: {{ section.settings.quote_color | default: '#4B5563' }};
    --author-color: {{ section.settings.author_color | default: '#1F2937' }};
    --note-color: {{ section.settings.note_color | default: '#6B7280' }};
  }

  .reviews-section-{{ section.id }} {
    background-color: var(--reviews-bg);
    border-radius: var(--reviews-radius);
    padding: var(--reviews-padding);
    box-shadow: var(--reviews-shadow);
    border: 1px solid var(--reviews-border);
    max-width: {{ section.settings.max_width | default: '1280' }}px;
    margin: 0 auto;
  }

  .reviews-title-{{ section.id }} {
    color: var(--title-color);
    font-size: var(--title-size);
    font-weight: {{ section.settings.title_weight | default: '700' }};
    margin-bottom: {{ section.settings.title_margin | default: '24' }}px;
  }

  .reviews-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ section.settings.grid_gap | default: '24' }}px;
  }

  @media (min-width: 768px) {
    .reviews-grid-{{ section.id }} {
      grid-template-columns: repeat({{ section.settings.columns | default: '2' }}, 1fr);
    }
  }

  .review-card-{{ section.id }} {
    background-color: var(--card-bg);
    border-radius: var(--card-radius);
    padding: var(--card-padding);
    box-shadow: var(--card-shadow);
    border: 1px solid var(--card-border);
  }

  .review-stars-{{ section.id }} {
    display: flex;
    gap: {{ section.settings.star_gap | default: '2' }}px;
    margin-bottom: {{ section.settings.star_margin | default: '12' }}px;
  }

  .review-quote-{{ section.id }} {
    color: var(--quote-color);
    font-size: {{ section.settings.quote_size | default: '16' }}px;
    line-height: {{ section.settings.quote_line_height | default: '1.6' }};
    font-style: {{ section.settings.quote_style | default: 'italic' }};
    margin-bottom: {{ section.settings.quote_margin | default: '16' }}px;
  }

  .review-author-{{ section.id }} {
    color: var(--author-color);
    font-size: {{ section.settings.author_size | default: '14' }}px;
    font-weight: {{ section.settings.author_weight | default: '600' }};
  }

  .reviews-note-{{ section.id }} {
    color: var(--note-color);
    font-size: {{ section.settings.note_size | default: '14' }}px;
    text-align: center;
    margin-top: {{ section.settings.note_margin | default: '32' }}px;
    padding-top: {{ section.settings.note_padding | default: '16' }}px;
    border-top: 1px solid var(--card-border);
  }
</style>

<div id="product-reviews-{{ section.id }}" class="reviews-section-{{ section.id }}" {{ section.shopify_attributes }}>
  <!-- Title -->
  <h2 class="reviews-title-{{ section.id }}">
    {{ section.settings.title | default: 'Verified Customer Stories' }}
  </h2>

  <!-- Reviews Grid -->
  <div class="reviews-grid-{{ section.id }}">
    {% for i in (1..section.settings.review_count) %}
      {% assign review_rating = 'review_' | append: i | append: '_rating' %}
      {% assign review_text = 'review_' | append: i | append: '_text' %}
      {% assign review_author = 'review_' | append: i | append: '_author' %}
      
      {% if section.settings[review_text] != blank %}
        <div class="review-card-{{ section.id }}">
          <!-- Star Rating -->
          <div class="review-stars-{{ section.id }}">
            {% assign rating = section.settings[review_rating] | default: 5 %}
            {% for star in (1..5) %}
              {% if star <= rating %}
                {% render 'icon-star', size: section.settings.star_size | default: 5, color: section.settings.star_color, filled: true %}
              {% else %}
                {% render 'icon-star', size: section.settings.star_size | default: 5, color: section.settings.star_empty_color, filled: false %}
              {% endif %}
            {% endfor %}
          </div>

          <!-- Review Text -->
          <blockquote class="review-quote-{{ section.id }}">
            "{{ section.settings[review_text] }}"
          </blockquote>

          <!-- Author -->
          <p class="review-author-{{ section.id }}">
            - {{ section.settings[review_author] }}
          </p>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <!-- Note -->
  {% if section.settings.show_note %}
    <p class="reviews-note-{{ section.id }}">
      {{ section.settings.note_text | default: 'Note: For official, real-time reviews, we recommend implementing a dedicated e-commerce review application.' }}
    </p>
  {% endif %}
</div>

