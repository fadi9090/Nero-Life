{% comment %}
  Footer - Fully customizable through Shopify editor
  Features: Brand info, navigation links, newsletter signup, social media icons
{% endcomment %}

<style>
  #footer-{{ section.id }} {
    --footer-bg: {{ section.settings.footer_bg | default: '#000000' }};
    --footer-text: {{ section.settings.footer_text | default: '#FFFFFF' }};
    --footer-text-muted: {{ section.settings.footer_text_muted | default: '#9CA3AF' }};
    --footer-border: {{ section.settings.footer_border | default: '#1F2937' }};
    --footer-link-hover: {{ section.settings.footer_link_hover | default: '#FA8072' }};
    
    --footer-padding-y: {{ section.settings.padding_y | default: '48' }}px;
    --footer-padding-x: {{ section.settings.padding_x | default: '16' }}px;
    --footer-margin-top: {{ section.settings.margin_top | default: '48' }}px;
    
    --brand-title-size: {{ section.settings.brand_title_size | default: '20' }}px;
    --heading-size: {{ section.settings.heading_size | default: '16' }}px;
    --text-size: {{ section.settings.text_size | default: '14' }}px;
    
    --social-icon-size: {{ section.settings.social_icon_size | default: '5' }};
    --social-icon-color: {{ section.settings.social_icon_color | default: '#FFFFFF' }};
    --social-icon-hover: {{ section.settings.social_icon_hover | default: '#FA8072' }};
    
    --newsletter-button-bg: {{ section.settings.newsletter_button_bg | default: '#FA8072' }};
    --newsletter-button-hover: {{ section.settings.newsletter_button_hover | default: '#E57366' }};
    --newsletter-button-text: {{ section.settings.newsletter_button_text | default: '#FFFFFF' }};
    --newsletter-input-bg: {{ section.settings.newsletter_input_bg | default: '#1F2937' }};
    --newsletter-input-text: {{ section.settings.newsletter_input_text | default: '#FFFFFF' }};
    --newsletter-input-border: {{ section.settings.newsletter_input_border | default: '#374151' }};
    --newsletter-focus-ring: {{ section.settings.newsletter_focus_ring | default: '#FA8072' }};
  }

  @media (min-width: 640px) {
    #footer-{{ section.id }} {
      --footer-padding-x: {{ section.settings.padding_x_sm | default: '24' }}px;
    }
  }

  @media (min-width: 1024px) {
    #footer-{{ section.id }} {
      --footer-padding-x: {{ section.settings.padding_x_lg | default: '32' }}px;
    }
  }

  .footer-{{ section.id }} {
    background-color: var(--footer-bg);
    color: var(--footer-text);
    padding: var(--footer-padding-y) var(--footer-padding-x);
    margin-top: var(--footer-margin-top);
  }

  .footer-container-{{ section.id }} {
    max-width: {{ section.settings.max_width | default: '1280' }}px;
    margin: 0 auto;
  }

  .footer-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ section.settings.grid_gap | default: '32' }}px;
  }

  @media (min-width: 768px) {
    .footer-grid-{{ section.id }} {
      grid-template-columns: repeat({{ section.settings.columns | default: '4' }}, 1fr);
    }
  }

  /* Brand Section */
  .brand-title-{{ section.id }} {
    font-size: var(--brand-title-size);
    font-weight: {{ section.settings.brand_title_weight | default: '700' }};
    margin-bottom: {{ section.settings.brand_margin | default: '16' }}px;
    color: var(--footer-text);
  }

  .brand-description-{{ section.id }} {
    color: var(--footer-text-muted);
    font-size: var(--text-size);
    line-height: {{ section.settings.brand_line_height | default: '1.6' }};
    max-width: {{ section.settings.brand_max_width | default: '300' }}px;
  }

  /* Headings */
  .footer-heading-{{ section.id }} {
    font-size: var(--heading-size);
    font-weight: {{ section.settings.heading_weight | default: '500' }};
    margin-bottom: {{ section.settings.heading_margin | default: '16' }}px;
    color: var(--footer-text);
    letter-spacing: {{ section.settings.heading_spacing | default: 'normal' }};
  }

  /* Links */
  .footer-links-{{ section.id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links-{{ section.id }} li {
    margin-bottom: {{ section.settings.link_spacing | default: '8' }}px;
  }

  .footer-link-{{ section.id }} {
    color: var(--footer-text-muted);
    font-size: var(--text-size);
    text-decoration: none;
    transition: color {{ section.settings.transition_speed | default: '200' }}ms ease;
    display: inline-block;
  }

  .footer-link-{{ section.id }}:hover {
    color: var(--footer-link-hover);
  }

  /* Social Icons */
  .social-icons-{{ section.id }} {
    display: flex;
    gap: {{ section.settings.social_icon_gap | default: '12' }}px;
    margin-top: {{ section.settings.social_margin_top | default: '20' }}px;
  }

  .social-icon-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all {{ section.settings.transition_speed | default: '200' }}ms ease;
  }

  .social-icon-{{ section.id }}:hover {
    transform: translateY(-{{ section.settings.social_hover_offset | default: '2' }}px);
  }

  .social-icon-{{ section.id }} svg {
    fill: var(--social-icon-color);
    transition: fill {{ section.settings.transition_speed | default: '200' }}ms ease;
  }

  .social-icon-{{ section.id }}:hover svg {
    fill: var(--social-icon-hover);
  }

  /* Newsletter */
  .newsletter-text-{{ section.id }} {
    color: var(--footer-text-muted);
    font-size: var(--text-size);
    margin-bottom: {{ section.settings.newsletter_text_margin | default: '16' }}px;
    line-height: {{ section.settings.newsletter_line_height | default: '1.5' }};
  }

  .newsletter-form-{{ section.id }} {
    display: flex;
    flex-direction: {% if section.settings.newsletter_layout == 'stacked' %}column{% else %}row{% endif %};
    gap: {{ section.settings.newsletter_gap | default: '8' }}px;
  }

  .newsletter-input-{{ section.id }} {
    flex: 1;
    background-color: var(--newsletter-input-bg);
    color: var(--newsletter-input-text);
    border: 1px solid var(--newsletter-input-border);
    border-radius: {{ section.settings.input_radius | default: '6' }}px;
    padding: {{ section.settings.input_padding_y | default: '8' }}px {{ section.settings.input_padding_x | default: '16' }}px;
    font-size: var(--text-size);
    transition: all {{ section.settings.transition_speed | default: '200' }}ms ease;
  }

  .newsletter-input-{{ section.id }}:focus {
    outline: none;
    border-color: var(--newsletter-focus-ring);
    box-shadow: 0 0 0 2px {{ section.settings.focus_ring_opacity | default: 'rgba(250, 128, 114, 0.2)' }};
  }

  .newsletter-input-{{ section.id }}::placeholder {
    color: {{ section.settings.placeholder_color | default: '#6B7280' }};
  }

  .newsletter-button-{{ section.id }} {
    background-color: var(--newsletter-button-bg);
    color: var(--newsletter-button-text);
    font-weight: {{ section.settings.button_weight | default: '500' }};
    padding: {{ section.settings.button_padding_y | default: '8' }}px {{ section.settings.button_padding_x | default: '16' }}px;
    border: none;
    border-radius: {{ section.settings.button_radius | default: '6' }}px;
    cursor: pointer;
    transition: all {{ section.settings.transition_speed | default: '200' }}ms ease;
    white-space: nowrap;
    font-size: var(--text-size);
    width: {% if section.settings.newsletter_layout == 'stacked' %}100%{% else %}auto{% endif %};
  }

  .newsletter-button-{{ section.id }}:hover {
    background-color: var(--newsletter-button-hover);
    transform: translateY(-{{ section.settings.button_hover_offset | default: '1' }}px);
  }

  /* Copyright */
  .copyright-{{ section.id }} {
    border-top: 1px solid var(--footer-border);
    margin-top: {{ section.settings.copyright_margin_top | default: '48' }}px;
    padding-top: {{ section.settings.copyright_padding_top | default: '32' }}px;
    text-align: {{ section.settings.copyright_align | default: 'center' }};
    color: var(--footer-text-muted);
    font-size: {{ section.settings.copyright_size | default: '14' }}px;
  }

  @media (max-width: 640px) {
    .newsletter-form-{{ section.id }} {
      flex-direction: column;
    }
    
    .newsletter-button-{{ section.id }} {
      width: 100%;
    }
  }
</style>

<footer id="footer-{{ section.id }}" class="footer-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="footer-container-{{ section.id }}">
    <div class="footer-grid-{{ section.id }}">
      
      <!-- Brand Column -->
      <div>
        <h3 class="brand-title-{{ section.id }}">
          {{ section.settings.brand_title | default: 'NERO LIFE' }}
        </h3>
        <p class="brand-description-{{ section.id }}">
          {{ section.settings.brand_description | default: 'Elevating everyday style with timeless pieces and modern elegance.' }}
        </p>
        
        <!-- Social Icons -->
        {% if section.settings.show_social_icons %}
          <div class="social-icons-{{ section.id }}">
            {% if section.settings.social_facebook != blank %}
              <a href="{{ section.settings.social_facebook }}" class="social-icon-{{ section.id }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                {% render 'icon-facebook', 
                  size: section.settings.social_icon_size,
                  color: 'currentColor'
                %}
              </a>
            {% endif %}
            
            {% if section.settings.social_instagram != blank %}
              <a href="{{ section.settings.social_instagram }}" class="social-icon-{{ section.id }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                {% render 'icon-instagram', 
                  size: section.settings.social_icon_size,
                  color: 'currentColor'
                %}
              </a>
            {% endif %}
            
            {% if section.settings.social_twitter != blank %}
              <a href="{{ section.settings.social_twitter }}" class="social-icon-{{ section.id }}" target="_blank" rel="noopener noreferrer" aria-label="Twitter">
                {% render 'icon-twitter', 
                  size: section.settings.social_icon_size,
                  color: 'currentColor'
                %}
              </a>
            {% endif %}
            
            {% if section.settings.social_youtube != blank %}
              <a href="{{ section.settings.social_youtube }}" class="social-icon-{{ section.id }}" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
                {% render 'icon-youtube', 
                  size: section.settings.social_icon_size,
                  color: 'currentColor'
                %}
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>

      <!-- Help Column -->
      <div>
        <h4 class="footer-heading-{{ section.id }}">
          {{ section.settings.help_title | default: 'Help' }}
        </h4>
        <ul class="footer-links-{{ section.id }}">
          {% if section.settings.privacy_link != blank %}
            <li>
              <a href="{{ section.settings.privacy_link }}" class="footer-link-{{ section.id }}">
                {{ section.settings.privacy_text | default: 'Privacy Policy' }}
              </a>
            </li>
          {% endif %}
          
          {% if section.settings.terms_link != blank %}
            <li>
              <a href="{{ section.settings.terms_link }}" class="footer-link-{{ section.id }}">
                {{ section.settings.terms_text | default: 'Terms of Service' }}
              </a>
            </li>
          {% endif %}
          
          {% if section.settings.contact_link != blank %}
            <li>
              <a href="{{ section.settings.contact_link }}" class="footer-link-{{ section.id }}">
                {{ section.settings.contact_text | default: 'Contact Us' }}
              </a>
            </li>
          {% endif %}
          
          {% if section.settings.faq_link != blank %}
            <li>
              <a href="{{ section.settings.faq_link }}" class="footer-link-{{ section.id }}">
                {{ section.settings.faq_text | default: 'FAQ' }}
              </a>
            </li>
          {% endif %}
          
          {% if section.settings.shipping_link != blank %}
            <li>
              <a href="{{ section.settings.shipping_link }}" class="footer-link-{{ section.id }}">
                {{ section.settings.shipping_text | default: 'Shipping Policy' }}
              </a>
            </li>
          {% endif %}
          
          {% if section.settings.returns_link != blank %}
            <li>
              <a href="{{ section.settings.returns_link }}" class="footer-link-{{ section.id }}">
                {{ section.settings.returns_text | default: 'Returns & Exchanges' }}
              </a>
            </li>
          {% endif %}
        </ul>
      </div>

      <!-- Newsletter Column -->
      <div>
        <h4 class="footer-heading-{{ section.id }}">
          {{ section.settings.newsletter_title | default: 'Newsletter' }}
        </h4>
        <p class="newsletter-text-{{ section.id }}">
          {{ section.settings.newsletter_description | default: 'Subscribe for updates and exclusive offers' }}
        </p>
        
        {% form 'customer', id: 'footer-newsletter', class: 'newsletter-form-{{ section.id }}' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          
          <input type="email"
                 name="contact[email]"
                 placeholder="{{ section.settings.newsletter_placeholder | default: 'Your email' }}"
                 class="newsletter-input-{{ section.id }}"
                 aria-label="{{ section.settings.newsletter_aria | default: 'Email address for newsletter' }}"
                 required>
                 
          <button type="submit" class="newsletter-button-{{ section.id }}">
            {{ section.settings.newsletter_button | default: 'Subscribe' }}
          </button>
        {% endform %}

        <!-- Newsletter success message (hidden by default, shown after submission) -->
        {% if form.posted_successfully? %}
          <p class="mt-4 text-green-400 text-sm">
            {{ section.settings.newsletter_success | default: 'Thanks for subscribing!' }}
          </p>
        {% endif %}
      </div>
    </div>

    <!-- Copyright -->
    <div class="copyright-{{ section.id }}">
      <p>
        {{ section.settings.copyright_text | default: '© 2024 Nero Life Sciences. All rights reserved.' | replace: '[year]', 'now' | date: '%Y' }}
      </p>
      
      {% if section.settings.show_payment_icons %}
        <div class="payment-icons-{{ section.id }} mt-4">
          <!-- Add payment icons here if needed -->
          <span class="text-sm">{{ section.settings.payment_text | default: 'Secure payments' }}</span>
        </div>
      {% endif %}
    </div>
  </div>
</footer>

