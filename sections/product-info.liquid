{% comment %}
  Product Information - Fully customizable with discount integration
{% endcomment %}

{% render 'discount' %}

<style>
  #product-info-{{ section.id }} {
    --info-bg: {{ section.settings.info_bg | default: '#FFFFFF' }};
    --info-border: {{ section.settings.info_border | default: '#E5E7EB' }};
    --info-shadow: {{ section.settings.info_shadow | default: '0 1px 2px 0 rgb(0 0 0 / 0.05)' }};
    --info-radius: {{ section.settings.info_radius | default: '12' }}px;
    --info-padding: {{ section.settings.info_padding | default: '24' }}px;
    --title-color: {{ section.settings.title_color | default: '#111827' }};
    --title-size: {{ section.settings.title_size | default: '30' }}px;
    --price-color: {{ section.settings.price_color | default: '#111827' }};
    --sale-color: {{ section.settings.sale_color | default: '#FA8072' }};
    --compare-color: {{ section.settings.compare_color | default: '#6B7280' }};
    --save-color: {{ section.settings.save_color | default: '#16A34A' }};
    --option-border: {{ section.settings.option_border | default: '#E5E7EB' }};
    --option-selected: {{ section.settings.option_selected | default: '#FA8072' }};
    --option-bg: {{ section.settings.option_bg | default: '#FEF2F2' }};
    --button-bg: {{ section.settings.button_bg | default: '#FA8072' }};
    --button-hover: {{ section.settings.button_hover | default: '#E57373' }};
    --button-text: {{ section.settings.button_text | default: '#FFFFFF' }};
  }

  @media (min-width: 1024px) {
    #product-info-{{ section.id }} {
      --title-size: {{ section.settings.title_size_lg | default: '30' }}px;
    }
  }

  .product-info-{{ section.id }} {
    background-color: var(--info-bg);
    border-radius: var(--info-radius);
    padding: var(--info-padding);
    box-shadow: var(--info-shadow);
    border: 1px solid var(--info-border);
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .product-title-{{ section.id }} {
    color: var(--title-color);
    font-size: var(--title-size);
    font-weight: {{ section.settings.title_weight | default: '800' }};
    margin-bottom: {{ section.settings.title_margin | default: '16' }}px;
  }

  .price-container-{{ section.id }} {
    margin-bottom: {{ section.settings.price_margin | default: '24' }}px;
  }

  .sale-price-{{ section.id }} {
    color: var(--sale-color);
    font-size: {{ section.settings.sale_size | default: '20' }}px;
    font-weight: {{ section.settings.price_weight | default: '700' }};
  }

  .compare-price-{{ section.id }} {
    color: var(--compare-color);
    font-size: {{ section.settings.compare_size | default: '16' }}px;
    text-decoration: line-through;
    margin-left: {{ section.settings.compare_spacing | default: '8' }}px;
  }

  .save-badge-{{ section.id }} {
    color: var(--save-color);
    font-size: {{ section.settings.save_size | default: '14' }}px;
    font-weight: {{ section.settings.save_weight | default: '500' }};
    margin-top: {{ section.settings.save_margin | default: '4' }}px;
  }

  .regular-price-{{ section.id }} {
    color: var(--price-color);
    font-size: {{ section.settings.regular_size | default: '20' }}px;
    font-weight: {{ section.settings.price_weight | default: '700' }};
  }

  .package-title-{{ section.id }} {
    color: var(--title-color);
    font-size: {{ section.settings.package_title_size | default: '16' }}px;
    font-weight: {{ section.settings.package_title_weight | default: '600' }};
    margin-bottom: {{ section.settings.package_title_margin | default: '12' }}px;
  }

  .package-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat({{ section.settings.packages_per_row | default: '2' }}, 1fr);
    gap: {{ section.settings.package_gap | default: '12' }}px;
    margin-bottom: {{ section.settings.package_margin | default: '24' }}px;
  }

  .package-option-{{ section.id }} {
    border: 2px solid var(--option-border);
    border-radius: {{ section.settings.option_radius | default: '8' }}px;
    padding: {{ section.settings.option_padding | default: '12' }}px;
    cursor: pointer;
    transition: all {{ section.settings.option_transition | default: '200' }}ms ease;
    position: relative;
  }

  .package-option-{{ section.id }}:hover {
    border-color: var(--option-selected);
    box-shadow: {{ section.settings.option_hover_shadow | default: '0 4px 6px -1px rgb(0 0 0 / 0.1)' }};
  }

  .package-option-{{ section.id }}.selected {
    border-color: var(--option-selected);
    background-color: var(--option-bg);
  }

  .selected-check-{{ section.id }} {
    position: absolute;
    top: -8px;
    right: -8px;
    width: 20px;
    height: 20px;
    background-color: var(--option-selected);
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }

  .add-to-cart-{{ section.id }} {
    width: 100%;
    background-color: var(--button-bg);
    color: var(--button-text);
    font-weight: {{ section.settings.button_weight | default: '700' }};
    padding: {{ section.settings.button_padding | default: '12' }}px;
    border-radius: {{ section.settings.button_radius | default: '8' }}px;
    transition: background-color {{ section.settings.button_transition | default: '200' }}ms ease;
    border: none;
    cursor: pointer;
  }

  .add-to-cart-{{ section.id }}:hover {
    background-color: var(--button-hover);
  }

  .add-to-cart-{{ section.id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>

<div id="product-info-{{ section.id }}" class="product-info-{{ section.id }}" {{ section.shopify_attributes }}>
  <!-- Product Title -->
  <h1 class="product-title-{{ section.id }}">
    {{ product.title }}
  </h1>

  <!-- Price Display -->
  <div class="price-container-{{ section.id }}">
    {% if has_discounts %}
      {% assign discount_multiplier = 100.0 | minus: regular_discount %}
      {% assign single_discounted_price = product.price | times: discount_multiplier | divided_by: 100 %}
      
      <span class="sale-price-{{ section.id }}">
        {{ single_discounted_price | money }}
      </span>
      <span class="compare-price-{{ section.id }}">
        {{ product.price | money }}
      </span>
      
      {% if section.settings.show_save_badge and regular_discount > 0 %}
        <div class="save-badge-{{ section.id }}">
          {% render 'icon-check', size: 4, color: '#16A34A', class: 'inline mr-1' %}
          {{ section.settings.save_text | default: 'Save' }} {{ regular_discount }}%
        </div>
      {% endif %}
    {% else %}
      <span class="regular-price-{{ section.id }}">
        {{ product.price | money }}
      </span>
    {% endif %}
  </div>

  <!-- Package Options -->
  {% if section.settings.show_packages %}
    <div>
      <h3 class="package-title-{{ section.id }}">
        {{ section.settings.packages_title | default: 'Choose Your Package:' }}
      </h3>

      <div class="package-grid-{{ section.id }}">
        {% comment %} Single Package {% endcomment %}
        {% if section.settings.show_single_package %}
          <div class="package-option-{{ section.id }} {% if has_discounts and regular_discount > 0 %}selected{% endif %}"
               data-quantity="1"
               onclick="selectPackage(this, 1)">
            
            {% if has_discounts and regular_discount > 0 and section.settings.show_selected_check %}
              <div class="selected-check-{{ section.id }}">
                {% render 'icon-check', size: 3, color: '#FFFFFF' %}
              </div>
            {% endif %}

            <div class="text-center">
              {% if section.settings.single_image != blank %}
                <img src="{{ section.settings.single_image | image_url: width: 100 }}"
                     alt="{{ section.settings.single_title | default: 'Single Mask' }}"
                     class="w-12 h-12 mx-auto mb-2 object-contain"
                     width="100"
                     height="100"
                     loading="lazy">
              {% else %}
                <div class="w-12 h-12 mx-auto mb-2 bg-gray-100 rounded-lg flex items-center justify-center">
                  <span class="text-lg font-bold text-gray-700">1x</span>
                </div>
              {% endif %}

              <h4 class="text-sm font-medium mb-1">
                {{ section.settings.single_title | default: 'Single Mask' }}
              </h4>
              
              <div class="text-base font-bold {% if has_discounts and regular_discount > 0 %}sale-price-{{ section.id }}{% else %}regular-price-{{ section.id }}{% endif %}">
                {% if has_discounts and regular_discount > 0 %}
                  {{ single_discounted_price | money }}
                {% else %}
                  {{ product.price | money }}
                {% endif %}
              </div>
              
              {% if has_discounts and regular_discount > 0 and section.settings.show_compare %}
                <div class="text-xs compare-price-{{ section.id }}">
                  {{ product.price | money }}
                </div>
              {% endif %}
            </div>
          </div>
        {% endif %}

        {% comment %} Double Package {% endcomment %}
        {% if section.settings.show_double_package %}
          <div class="package-option-{{ section.id }}"
               data-quantity="2"
               onclick="selectPackage(this, 2)">
            
            {% if section.settings.show_selected_check %}
              <div class="selected-check-{{ section.id }} hidden">
                {% render 'icon-check', size: 3, color: '#FFFFFF' %}
              </div>
            {% endif %}

            <div class="text-center">
              {% if section.settings.double_image != blank %}
                <img src="{{ section.settings.double_image | image_url: width: 100 }}"
                     alt="{{ section.settings.double_title | default: 'Double Pack' }}"
                     class="w-12 h-12 mx-auto mb-2 object-contain"
                     width="100"
                     height="100"
                     loading="lazy">
              {% else %}
                <div class="w-12 h-12 mx-auto mb-2 bg-gray-100 rounded-lg flex items-center justify-center">
                  <span class="text-lg font-bold text-gray-700">2x</span>
                </div>
              {% endif %}

              <h4 class="text-sm font-medium mb-1">
                {{ section.settings.double_title | default: 'Double Pack' }}
              </h4>
              
              <div class="text-base font-bold {% if has_discounts and bulk_discount > 0 %}sale-price-{{ section.id }}{% else %}regular-price-{{ section.id }}{% endif %}">
                {% if has_discounts and bulk_discount > 0 %}
                  {% assign bulk_multiplier = 100.0 | minus: bulk_discount %}
                  {% assign bulk_price = product.price | times: bulk_multiplier | divided_by: 100 | times: 2 %}
                  {{ bulk_price | money }}
                {% else %}
                  {{ product.price | times: 2 | money }}
                {% endif %}
              </div>
              
              {% if has_discounts and bulk_discount > 0 and section.settings.show_compare %}
                <div class="text-xs compare-price-{{ section.id }}">
                  {{ product.price | times: 2 | money }}
                </div>
                <div class="text-xs save-badge-{{ section.id }} mt-1">
                  {% render 'icon-check', size: 3, color: '#16A34A', class: 'inline mr-1' %}
                  {{ section.settings.save_text | default: 'Save' }} {{ product.price | times: 2 | minus: bulk_price | money }}
                </div>
              {% endif %}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  {% endif %}

  <!-- Add to Cart Button -->
  <div class="mt-auto pt-6">
    <form method="post" action="{{ routes.cart_add_url }}">
      <input type="hidden" name="id" value="{{ product.variants.first.id }}" id="selectedVariantId">
      <input type="hidden" name="quantity" value="1" id="selectedQuantity">
      <button type="submit" class="add-to-cart-{{ section.id }}" {% unless product.available %}disabled{% endunless %}>
        {% if product.available %}
          {{ section.settings.button_text | default: 'Add to Cart' }}
        {% else %}
          {{ section.settings.sold_out_text | default: 'Sold Out' }}
        {% endif %}
      </button>
    </form>
  </div>
</div>

<script>
  function selectPackage(element, quantity) {
    // Remove selection from all options
    document.querySelectorAll('.package-option-{{ section.id }}').forEach(opt => {
      opt.classList.remove('selected');
      const check = opt.querySelector('.selected-check-{{ section.id }}');
      if (check) check.classList.add('hidden');
    });

    // Add selection to clicked option
    element.classList.add('selected');
    const check = element.querySelector('.selected-check-{{ section.id }}');
    if (check) check.classList.remove('hidden');

    // Update quantity input
    document.getElementById('selectedQuantity').value = quantity;
  }
</script>

