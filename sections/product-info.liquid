{% render 'discount-config' %}

<!-- Product Information - Equal Height -->
<div class="h-full p-6 border rounded-xl shadow-sm bg-white flex flex-col">
  <div class="flex-grow">
    <h1 class="text-3xl font-extrabold mb-4 text-gray-900">
      {{ product.title }}
    </h1>

    <!-- Price Display - Show only if discounts exist -->
    {% if has_discounts %}
      <div class="mt-2 mb-6">
        {% comment %} Calculate prices with different discounts {% endcomment %}
        {% assign single_discounted_price = product.price | times: (100.0 | minus: regular_discount) | divided_by: 100 %}
        {% assign bulk_discounted_price = product.price | times: (100.0 | minus: bulk_discount) | divided_by: 100 %}

        <span class="text-xl font-bold text-gray-900">
          {{ single_discounted_price | money }}
        </span>
        <span class="text-base line-through text-gray-500 ml-2">
          {{ product.price | money }}
        </span>

        {% if regular_discount > 0 %}
          <div class="text-sm text-green-600 font-medium mt-1">Save {{ regular_discount }}% on single</div>
        {% endif %}
        {% if bulk_discount > 0 and bulk_discount != regular_discount %}
          <div class="text-sm text-green-600 font-medium">Save {{ bulk_discount }}% on bulk</div>
        {% endif %}
      </div>
    {% else %}
      <!-- Regular price display when no discounts -->
      <div class="mt-2 mb-6">
        <span class="text-xl font-bold text-gray-900">
          {{ product.price | money }}
        </span>
      </div>
    {% endif %}

    <!-- Smaller Mask Options Section - Only show if discounts exist or always show? -->
    <div class="mb-6">
      <h3 class="text-base font-semibold text-gray-800 mb-3">Choose Your Package:</h3>

      <div class="grid grid-cols-2 gap-3">
        <!-- Single Mask Option -->
        {% if has_discounts and regular_discount > 0 %}
          {% assign single_mask_class = 'mask-option relative border-2 border-[#FA8072] bg-rose-50 rounded-lg p-3 cursor-pointer transition-all duration-200 hover:shadow-md' %}
        {% else %}
          {% assign single_mask_class = 'mask-option relative border-2 border-gray-200 rounded-lg p-3 cursor-pointer transition-all duration-200 hover:shadow-md' %}
        {% endif %}
        <div
          id="singleMaskOption"
          class="{{ single_mask_class }}"
          data-quantity="1"
          data-original-price="{{ product.price | money }}"
          data-discounted-price="{% if regular_discount > 0 %}{{ single_discounted_price | money }}{% else %}{{ product.price | money }}{% endif %}"
          onclick="selectMaskOption(this, 1)"
        >
          <!-- Selected Indicator - Show if discount active -->
          {% if has_discounts and regular_discount > 0 %}
            <div class="absolute -top-2 -right-2 w-5 h-5 bg-[#FA8072] rounded-full flex items-center justify-center">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
            </div>
          {% endif %}

          <div class="flex flex-col items-center text-center">
            <!-- Smaller Mask Image -->
            <div class="package-image w-12 h-12 mb-2 bg-gray-100 rounded-lg flex items-center justify-center">
              <img
                src="{{ 'single.jpg' | asset_url }}"
                alt="Single Face & Neck Mask"
                width="40"
                height="40"
                class="w-10 h-10 object-contain"
                onerror="this.style.display='none'"
              >
              <div class="text-lg font-bold text-gray-700">1x</div>
            </div>

            <!-- Option Details -->
            <h4 class="text-sm font-medium text-gray-900 mb-1">Single Mask</h4>
            <div class="text-base font-bold {% if regular_discount > 0 %}text-[#FA8072]{% else %}text-gray-900{% endif %}">
              {% if regular_discount > 0 %}
                {{ single_discounted_price | money }}
              {% else %}
                {{ product.price | money }}
              {% endif %}
            </div>
            {% if regular_discount > 0 %}
              <div class="text-xs line-through text-gray-500">
                {{ product.price | money }}
              </div>
            {% endif %}
          </div>
        </div>

        <!-- Double Mask Option -->
        <div
          id="doubleMaskOption"
          class="mask-option relative border-2 border-gray-200 rounded-lg p-3 cursor-pointer transition-all duration-200 hover:border-[#FA8072] hover:shadow-md"
          data-quantity="2"
          data-original-price="{{ product.price | times: 2 | money }}"
          data-discounted-price="{% if bulk_discount > 0 %}{{ bulk_discounted_price | times: 2 | money }}{% else %}{{ product.price | times: 2 | money }}{% endif %}"
          onclick="selectMaskOption(this, 2)"
        >
          <!-- Selected Indicator -->
          <div class="absolute -top-2 -right-2 w-5 h-5 bg-[#FA8072] rounded-full flex items-center justify-center hidden">
            <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
          </div>

          <div class="flex flex-col items-center text-center">
            <!-- Smaller Mask Image -->
            <div class="package-image w-12 h-12 mb-2 bg-gray-100 rounded-lg flex items-center justify-center">
              <img
                src="{{ 'double.png' | asset_url }}"
                alt="Two Face & Neck Masks"
                width="40"
                height="40"
                class="w-10 h-10 object-contain"
                onerror="this.style.display='none'"
              >
              <div class="text-lg font-bold text-gray-700">2x</div>
            </div>

            <!-- Option Details -->
            <h4 class="text-sm font-medium text-gray-900 mb-1">Double Pack</h4>
            <div class="text-base font-bold {% if bulk_discount > 0 %}text-[#FA8072]{% else %}text-gray-900{% endif %}">
              {% if bulk_discount > 0 %}
                {{ bulk_discounted_price | times: 2 | money }}
              {% else %}
                {{ product.price | times: 2 | money }}
              {% endif %}
            </div>

            {% if bulk_discount > 0 %}
              <div class="text-xs line-through text-gray-500">
                {{ product.price | times: 2 | money }}
              </div>
              {% assign original_total = product.price | times: 2 %}
              {% assign discounted_total = bulk_discounted_price | times: 2 %}
              {% assign save_amount = original_total | minus: discounted_total %}
              <div class="text-xs text-green-600 font-medium mt-1">Save {{ save_amount | money }}</div>
            {% elsif regular_discount > 0 %}
              {% comment %} If no bulk discount but regular discount exists, show regular discount on double {% endcomment %}
              {% assign original_total = product.price | times: 2 %}
              {% assign discounted_total = single_discounted_price | times: 2 %}
              {% assign save_amount = original_total | minus: discounted_total %}
              <div class="text-xs text-green-600 font-medium mt-1">Save {{ save_amount | money }}</div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Add to Cart Button -->
  <div class="mt-auto pt-6">
    <form method="post" action="{{ routes.cart_add_url }}">
      <input type="hidden" name="id" value="{{ product.variants.first.id }}" id="selectedVariantId">
      <input type="hidden" name="quantity" value="1" id="selectedQuantity">
      <button
        type="submit"
        class="w-full bg-[#FA8072] text-white font-bold py-3 rounded-lg hover:bg-[#e57373] transition-colors duration-200"
      >
        Add to Cart
      </button>
    </form>
  </div>
</div>

<script>
  function selectMaskOption(element, quantity) {
    // Remove selected styling from all options
    document.querySelectorAll('.mask-option').forEach((opt) => {
      opt.classList.remove('border-[#FA8072]', 'bg-rose-50');
      opt.classList.add('border-gray-200');
      opt.querySelector('.absolute.-top-2.-right-2')?.classList.add('hidden');
    });

    // Add selected styling to clicked option
    element.classList.remove('border-gray-200');
    element.classList.add('border-[#FA8072]', 'bg-rose-50');
    element.querySelector('.absolute.-top-2.-right-2')?.classList.remove('hidden');

    // Update quantity input
    document.getElementById('selectedQuantity').value = quantity;
  }
</script>

{% schema %}
{
  "name": "Product Discounts",
  "settings": [
    {
      "type": "number",
      "id": "regular_discount",
      "label": "Regular Discount %",
      "default": 30,
      "info": "Discount for single items"
    },
    {
      "type": "number",
      "id": "bulk_discount",
      "label": "Bulk Discount %",
      "default": 35,
      "info": "Discount for multiple items"
    }
  ]
}
{% endschema %}

{% assign regular_discount = section.settings.regular_discount %}
{% assign bulk_discount = section.settings.bulk_discount %}
