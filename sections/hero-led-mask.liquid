{% comment %}
  Section: Hero LED Mask
  Description: Main hero section with product details and CTA
{% endcomment %}

{% comment %} Load discount configuration - ONCE is enough {% endcomment %}
{% render 'discount' %}

{% comment %} Get the featured product from section settings {% endcomment %}
{% assign featured_product = all_products[section.settings.featured_product] %}

{% comment %} Calculate discounted price only if discount is active {% endcomment %}
{% if regular_discount > 0 %}
  {% assign discount_multiplier = 100.0 | minus: regular_discount %}
  {% assign discounted_price = featured_product.price | times: discount_multiplier | divided_by: 100 %}
  {% assign compare_price = featured_product.compare_at_price | default: featured_product.price %}
{% endif %}

<div class="w-full max-w-7xl mx-auto">
  <div class="rounded-3xl shadow-2xl overflow-hidden">
    <div
      class="relative w-full min-h-[280px] sm:min-h-[300px] lg:min-h-[400px] bg-cover bg-center flex items-center justify-center lg:justify-start p-4 sm:p-6 lg:p-12"
      style="background-image: linear-gradient(to bottom, rgba(120, 0, 45, 0.5), rgba(120, 0, 45, 0.8)), url('{{ section.settings.hero_background_image | image_url: width: 2000 }}');"
    >
      <div class="absolute inset-0 bg-gradient-to-r from-black/30 to-black/20 pointer-events-none z-5"></div>
      <div
        class="absolute inset-0 shadow-[inset_0_0_80px_20px_rgba(220,38,38,0.3)] pointer-events-none mix-blend-overlay z-6"
      ></div>

      <div class="relative z-10 text-white text-center lg:text-left max-w-xl lg:pl-10 w-full">
        {% comment %} Badge - Only show if discount is active {% endcomment %}
        {% if regular_discount > 0 %}
          <div class="inline-block bg-gradient-to-r from-rose-600 to-pink-500 text-white text-xs font-bold px-4 py-2 rounded-full mb-3 sm:mb-4 uppercase tracking-wider shadow-lg border border-rose-400/30">
            {{ section.settings.badge_text | default: 'Limited Time Launch Offer' }}
          </div>
        {% endif %}

        {% comment %} Title {% endcomment %}
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-black uppercase mb-3 sm:mb-4 leading-snug sm:leading-tight tracking-tight drop-shadow-2xl">
          {% if section.settings.hero_title != blank %}
            {{ section.settings.hero_title }}
          {% elsif featured_product.title != blank %}
            {{ featured_product.title }}
          {% else %}
            PROFESSIONAL LED THERAPY FOR FACE & NECK
          {% endif %}
        </h1>

        {% comment %} Description {% endcomment %}
        <p class="text-sm sm:text-base lg:text-lg mb-4 sm:mb-6 leading-relaxed drop-shadow-lg max-w-md mx-auto lg:mx-0 opacity-95 font-medium bg-black/20 backdrop-blur-sm rounded-lg p-3 sm:p-0 sm:bg-transparent sm:backdrop-blur-none">
          {% if section.settings.hero_description != blank %}
            {{ section.settings.hero_description }}
          {% elsif featured_product.description != blank %}
            {{ featured_product.description | truncatewords: 25 }}
          {% else %}
            Advanced 7-wavelength LED technology for comprehensive facial and neck rejuvenation. Visible results in just
            15 minutes daily.
          {% endif %}
        </p>

        {% comment %} Pricing - Conditional display based on discount {% endcomment %}
        <div class="flex items-baseline justify-center lg:justify-start space-x-2 sm:space-x-3 mb-4 sm:mb-6">
          {% if regular_discount > 0 and featured_product.price > 0 %}
            {% comment %} Show discounted price with compare at price {% endcomment %}
            <span class="text-2xl sm:text-3xl lg:text-6xl font-black text-rose-200 drop-shadow-md">
              {{ discounted_price | money_without_trailing_zeros }}
            </span>
            <span class="text-lg sm:text-xl lg:text-4xl font-normal line-through opacity-80 text-rose-100">
              {{ compare_price | money_without_trailing_zeros }}
            </span>
          {% elsif featured_product.price > 0 %}
            {% comment %} Show regular price only {% endcomment %}
            <span class="text-2xl sm:text-3xl lg:text-6xl font-black text-rose-200 drop-shadow-md">
              {{ featured_product.price | money_without_trailing_zeros }}
            </span>
          {% endif %}
        </div>

        {% comment %} CTA Button - Dynamic based on discount {% endcomment %}
        <div class="mb-4 sm:mb-6">
          <a
            href="{% if featured_product.url != blank %}{{ featured_product.url }}{% else %}{{ section.settings.cta_link }}{% endif %}"
            class="inline-block px-6 sm:px-8 py-3 text-sm sm:text-base font-black text-white bg-gradient-to-r from-rose-600 to-pink-500 hover:from-rose-700 hover:to-pink-600 transition-all duration-300 rounded-full shadow-2xl hover:shadow-3xl uppercase tracking-wider transform hover:scale-105 active:scale-95 border border-rose-400/30"
          >
            {% if regular_discount > 0 %}
              {{ section.settings.cta_text_discounted | default: 'GET 35% OFF NOW' }}
            {% else %}
              {{ section.settings.cta_text | default: 'SHOP NOW' }}
            {% endif %}
          </a>
        </div>

        {% comment %} Features - Always show these {% endcomment %}
        <div class="flex flex-col sm:flex-row justify-center lg:justify-start space-y-2 sm:space-y-0 sm:space-x-4 text-xs sm:text-sm font-semibold">
          <div class="flex items-center justify-center lg:justify-start text-white opacity-95 bg-black/20 backdrop-blur-sm rounded-full px-3 py-1 sm:bg-transparent sm:backdrop-blur-none sm:px-0">
            <svg
              class="w-3 h-3 sm:w-4 sm:h-4 text-rose-300 mr-1 sm:mr-2 flex-shrink-0"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span class="text-xs sm:text-sm">{{ section.settings.feature_1 | default: '60-Day Satisfaction' }}</span>
          </div>

          <div class="flex items-center justify-center lg:justify-start text-white opacity-95 bg-black/20 backdrop-blur-sm rounded-full px-3 py-1 sm:bg-transparent sm:backdrop-blur-none sm:px-0">
            <svg
              class="w-3 h-3 sm:w-4 sm:h-4 text-rose-300 mr-1 sm:mr-2 flex-shrink-0"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path fill-rule="evenodd" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" clip-rule="evenodd"></path>
            </svg>
            <span class="text-xs sm:text-sm">{{ section.settings.feature_2 | default: 'Medical-Grade' }}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero LED Mask",
  "settings": [
    {
      "type": "header",
      "content": "Product Settings"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured Product",
      "info": "Select a product to feature in the hero section"
    },
    {
      "type": "header",
      "content": "Hero Content"
    },
    {
      "type": "image_picker",
      "id": "hero_background_image",
      "label": "Hero Background Image",
      "info": "Upload the hero background image"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Limited Time Launch Offer"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero Title",
      "info": "Leave blank to use product title"
    },
    {
      "type": "textarea",
      "id": "hero_description",
      "label": "Hero Description",
      "info": "Leave blank to use product description"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link",
      "info": "Leave blank to use product URL"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text (No Discount)",
      "default": "SHOP NOW"
    },
    {
      "type": "text",
      "id": "cta_text_discounted",
      "label": "CTA Text (With Discount)",
      "default": "GET 35% OFF NOW"
    },
    {
      "type": "header",
      "content": "Feature Badges"
    },
    {
      "type": "text",
      "id": "feature_1",
      "label": "Feature 1",
      "default": "60-Day Satisfaction"
    },
    {
      "type": "text",
      "id": "feature_2",
      "label": "Feature 2",
      "default": "Medical-Grade"
    }
  ],
  "presets": [
    {
      "name": "Hero LED Mask",
      "category": "Hero"
    }
  ]
}
{% endschema %}