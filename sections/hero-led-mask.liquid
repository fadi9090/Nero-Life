    },
    {
      "type": "select",
      "id": "badge_font_weight",
      "label": "Badge font weight",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "medium", "label": "Medium" },
        { "value": "semibold", "label": "Semibold" },
        { "value": "bold", "label": "Bold" }
      ],
      "default": "bold"
    },
    {
      "type": "range",
      "id": "badge_padding_x",
      "label": "Badge horizontal padding",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "badge_padding_y",
      "label": "Badge vertical padding",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "badge_radius",
