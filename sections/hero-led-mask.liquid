{% comment %}
  Section: Hero LED Mask
  Description: Main hero section with product details and CTA
  Fully customizable through theme editor
{% endcomment %}

{% render 'discount' %}
{% assign featured_product = all_products[section.settings.featured_product] %}

{% if regular_discount > 0 and featured_product.price > 0 %}
  {% assign discount_multiplier = 100.0 | minus: regular_discount %}
  {% assign discounted_price = featured_product.price | times: discount_multiplier | divided_by: 100 %}
  {% assign compare_price = featured_product.compare_at_price | default: featured_product.price %}
{% endif %}

<style>
  #hero-{{ section.id }} {
    --hero-min-height: {{ section.settings.hero_height_mobile | default: '280' }}px;
    --hero-bg-overlay: {{ section.settings.overlay_color | default: 'rgba(120, 0, 45, 0.5)' }};
    --hero-text-color: {{ section.settings.text_color | default: '#FFFFFF' }};
    --hero-badge-bg: {{ section.settings.badge_bg | default: 'linear-gradient(to right, #e11d48, #db2777)' }};
    --hero-button-bg: {{ section.settings.button_bg | default: 'linear-gradient(to right, #e11d48, #db2777)' }};
    --hero-button-hover: {{ section.settings.button_hover | default: 'linear-gradient(to right, #be123c, #b81d66)' }};
    --hero-price-color: {{ section.settings.price_color | default: '#fecdd3' }};
  }

  @media (min-width: 640px) {
    #hero-{{ section.id }} {
      --hero-min-height: {{ section.settings.hero_height_sm | default: '300' }}px;
    }
  }

  @media (min-width: 1024px) {
    #hero-{{ section.id }} {
      --hero-min-height: {{ section.settings.hero_height_lg | default: '400' }}px;
    }
  }

  .hero-{{ section.id }} {
    min-height: var(--hero-min-height);
  }

  .hero-badge-{{ section.id }} {
    background: var(--hero-badge-bg);
  }

  .hero-button-{{ section.id }} {
    background: var(--hero-button-bg);
  }

  .hero-button-{{ section.id }}:hover {
    background: var(--hero-button-hover);
  }
</style>

<div class="w-full max-w-7xl mx-auto" {{ section.shopify_attributes }}>
  <div class="rounded-{{ section.settings.border_radius | default: '3xl' }} shadow-{{ section.settings.box_shadow | default: '2xl' }} overflow-hidden">
    <div
      id="hero-{{ section.id }}"
      class="hero-{{ section.id }} relative w-full bg-cover bg-center flex items-center justify-{{ section.settings.content_alignment_mobile | default: 'center' }} lg:justify-{{ section.settings.content_alignment_desktop | default: 'start' }} p-{{ section.settings.padding_mobile | default: '4' }} sm:p-{{ section.settings.padding_sm | default: '6' }} lg:p-{{ section.settings.padding_lg | default: '12' }}"
      style="background-image: linear-gradient(to bottom, var(--hero-bg-overlay), var(--hero-bg-overlay)), url('{% if section.settings.hero_background_image != blank %}{{ section.settings.hero_background_image | image_url: width: 2000 }}{% else %}{{ 'hero-placeholder.jpg' | asset_url }}{% endif %}');"
    >
      {% if section.settings.show_overlay_gradient %}
        <div class="absolute inset-0 bg-gradient-to-r from-black/{{ section.settings.overlay_opacity_start | default: '30' }} to-black/{{ section.settings.overlay_opacity_end | default: '20' }} pointer-events-none"></div>
      {% endif %}
      
      {% if section.settings.show_glow_effect %}
        <div class="absolute inset-0 shadow-[inset_0_0_80px_20px_rgba(220,38,38,0.3)] pointer-events-none mix-blend-overlay"></div>
      {% endif %}

      <div class="relative z-10 text-{% if section.settings.content_alignment_mobile == 'center' %}center{% else %}left{% endif %} lg:text-{{ section.settings.content_alignment_desktop }} max-w-{{ section.settings.content_width | default: 'xl' }} lg:pl-{{ section.settings.content_offset | default: '10' }} w-full" style="color: var(--hero-text-color);">
        {% if section.settings.show_badge and regular_discount > 0 %}
          <div class="hero-badge-{{ section.section.id }} inline-block text-{{ section.settings.badge_text_size | default: 'xs' }} font-{{ section.settings.badge_font_weight | default: 'bold' }} px-{{ section.settings.badge_padding_x | default: '4' }} py-{{ section.settings.badge_padding_y | default: '2' }} rounded-{{ section.settings.badge_radius | default: 'full' }} mb-{{ section.settings.badge_margin | default: '3' }} sm:mb-{{ section.settings.badge_margin_sm | default: '4' }} uppercase tracking-{{ section.settings.badge_tracking | default: 'wider' }} shadow-{{ section.settings.badge_shadow | default: 'lg' }}">
            {{ section.settings.badge_text | default: 'Limited Time Launch Offer' }}
          </div>
        {% endif %}

        <h1 class="text-{{ section.settings.title_size_mobile | default: '2xl' }} sm:text-{{ section.settings.title_size_sm | default: '3xl' }} lg:text-{{ section.settings.title_size_lg | default: '4xl' }} font-{{ section.settings.title_font_weight | default: 'black' }} uppercase mb-{{ section.settings.title_margin | default: '3' }} sm:mb-{{ section.settings.title_margin_sm | default: '4' }} leading-{{ section.settings.title_leading | default: 'snug' }} tracking-{{ section.settings.title_tracking | default: 'tight' }} drop-shadow-{{ section.settings.title_shadow | default: '2xl' }}">
          {% if section.settings.custom_title != blank %}
            {{ section.settings.custom_title }}
          {% elsif featured_product.title != blank %}
            {{ featured_product.title }}
          {% else %}
            {{ section.settings.default_title }}
          {% endif %}
        </h1>

        {% if section.settings.show_description %}
          <p class="text-{{ section.settings.desc_size_mobile | default: 'sm' }} sm:text-{{ section.settings.desc_size_sm | default: 'base' }} lg:text-{{ section.settings.desc_size_lg | default: 'lg' }} mb-{{ section.settings.desc_margin | default: '4' }} sm:mb-{{ section.settings.desc_margin_sm | default: '6' }} leading-{{ section.settings.desc_leading | default: 'relaxed' }} max-w-{{ section.settings.desc_width | default: 'md' }} mx-auto{% if section.settings.content_alignment_desktop == 'start' %} lg:mx-0{% endif %} {% if section.settings.desc_backdrop %}bg-black/20 backdrop-blur-sm rounded-lg p-3 sm:p-0 sm:bg-transparent sm:backdrop-blur-none{% endif %}">
            {% if section.settings.custom_description != blank %}
              {{ section.settings.custom_description }}
            {% elsif featured_product.description != blank %}
              {{ featured_product.description | truncatewords: section.settings.description_words | default: 25 }}
            {% else %}
              {{ section.settings.default_description }}
            {% endif %}
          </p>
        {% endif %}

        {% if section.settings.show_price %}
          <div class="flex items-baseline justify-{% if section.settings.content_alignment_mobile == 'center' %}center{% else %}start{% endif %} lg:justify-{{ section.settings.content_alignment_desktop }} space-x-{{ section.settings.price_spacing | default: '2' }} sm:space-x-{{ section.settings.price_spacing_sm | default: '3' }} mb-{{ section.settings.price_margin | default: '4' }} sm:mb-{{ section.settings.price_margin_sm | default: '6' }}">
            {% if regular_discount > 0 and featured_product.price > 0 %}
              <span class="text-{{ section.settings.discounted_price_size | default: '2xl' }} sm:text-{{ section.settings.discounted_price_size_sm | default: '3xl' }} lg:text-{{ section.settings.discounted_price_size_lg | default: '6xl' }} font-{{ section.settings.price_font_weight | default: 'black' }}" style="color: var(--hero-price-color);">
                {{ discounted_price | money_without_trailing_zeros }}
              </span>
              <span class="text-{{ section.settings.compare_price_size | default: 'lg' }} sm:text-{{ section.settings.compare_price_size_sm | default: 'xl' }} lg:text-{{ section.settings.compare_price_size_lg | default: '4xl' }} font-{{ section.settings.compare_price_weight | default: 'normal' }} line-through opacity-{{ section.settings.compare_price_opacity | default: '80' }}">
                {{ compare_price | money_without_trailing_zeros }}
              </span>
            {% elsif featured_product.price > 0 %}
              <span class="text-{{ section.settings.regular_price_size | default: '2xl' }} sm:text-{{ section.settings.regular_price_size_sm | default: '3xl' }} lg:text-{{ section.settings.regular_price_size_lg | default: '6xl' }} font-{{ section.settings.price_font_weight | default: 'black' }}" style="color: var(--hero-price-color);">
                {{ featured_product.price | money_without_trailing_zeros }}
              </span>
            {% endif %}
          </div>
        {% endif %}

        {% if section.settings.show_cta %}
          <div class="mb-{{ section.settings.cta_margin | default: '4' }} sm:mb-{{ section.settings.cta_margin_sm | default: '6' }}">
            <a
              href="{% if section.settings.cta_link != blank %}{{ section.settings.cta_link }}{% elsif featured_product.url != blank %}{{ featured_product.url }}{% else %}#{% endif %}"
              class="hero-button-{{ section.section.id }} inline-block px-{{ section.settings.button_padding_x | default: '6' }} sm:px-{{ section.settings.button_padding_x_sm | default: '8' }} py-{{ section.settings.button_padding_y | default: '3' }} text-{{ section.settings.button_text_size | default: 'sm' }} sm:text-{{ section.settings.button_text_size_sm | default: 'base' }} font-{{ section.settings.button_font_weight | default: 'black' }} text-white transition-all duration-{{ section.settings.button_transition | default: '300' }} rounded-{{ section.settings.button_radius | default: 'full' }} shadow-{{ section.settings.button_shadow | default: '2xl' }} hover:shadow-{{ section.settings.button_hover_shadow | default: '3xl' }} uppercase tracking-{{ section.settings.button_tracking | default: 'wider' }} transform hover:scale-{{ section.settings.button_hover_scale | default: '105' }} active:scale-95"
            >
              {% if regular_discount > 0 and section.settings.cta_text_discounted != blank %}
                {{ section.settings.cta_text_discounted | replace: '[discount]', regular_discount }}
              {% else %}
                {{ section.settings.cta_text | default: 'SHOP NOW' }}
              {% endif %}
            </a>
          </div>
        {% endif %}

        {% if section.settings.show_features %}
          <div class="flex flex-col sm:flex-row justify-{% if section.settings.content_alignment_mobile == 'center' %}center{% else %}start{% endif %} lg:justify-{{ section.settings.content_alignment_desktop }} space-y-{{ section.settings.features_spacing | default: '2' }} sm:space-y-0 sm:space-x-{{ section.settings.features_spacing_sm | default: '4' }} text-{{ section.settings.features_size | default: 'xs' }} sm:text-{{ section.settings.features_size_sm | default: 'sm' }} font-{{ section.settings.features_weight | default: 'semibold' }}">
            {% for i in (1..4) %}
              {% assign feature_text = 'feature_' | append: i %}
              {% if section.settings[feature_text] != blank %}
                <div class="flex items-center justify-{% if section.settings.content_alignment_mobile == 'center' %}center{% else %}start{% endif %} lg:justify-start {% if section.settings.features_backdrop %}bg-black/20 backdrop-blur-sm rounded-full px-3 py-1 sm:bg-transparent sm:backdrop-blur-none sm:px-0{% endif %}">
                  {% if section.settings.show_feature_icons %}
                    <svg class="w-{{ section.settings.feature_icon_size | default: '3' }} h-{{ section.settings.feature_icon_size | default: '3' }} sm:w-{{ section.settings.feature_icon_size_sm | default: '4' }} sm:h-{{ section.settings.feature_icon_size_sm | default: '4' }} mr-{{ section.settings.feature_icon_spacing | default: '1' }} sm:mr-{{ section.settings.feature_icon_spacing_sm | default: '2' }} flex-shrink-0" style="color: {{ section.settings.feature_icon_color | default: '#fecdd3' }};" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  {% endif %}
                  <span>{{ section.settings[feature_text] }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero LED Mask",
  "settings": [
    {
      "type": "header",
      "content": "Product Settings"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured Product",
      "info": "Select a product to feature"
    },
    {
      "type": "text",
      "id": "default_title",
      "label": "Default Title",
      "default": "PROFESSIONAL LED THERAPY FOR FACE & NECK",
      "info": "Shown when no product is selected"
    },
    {
      "type": "text",
      "id": "custom_title",
      "label": "Custom Title",
      "info": "Leave blank to use product title"
    },
    {
      "type": "textarea",
      "id": "default_description",
      "label": "Default Description",
      "default": "Advanced 7-wavelength LED technology for comprehensive facial and neck rejuvenation. Visible results in just 15 minutes daily."
    },
    {
      "type": "textarea",
      "id": "custom_description",
      "label": "Custom Description",
      "info": "Leave blank to use product description"
    },
    {
      "type": "range",
      "id": "description_words",
      "label": "Description word limit",
      "min": 10,
      "max": 50,
      "step": 5,
      "default": 25
    },
    {
      "type": "header",
      "content": "Hero Image"
    },
    {
      "type": "image_picker",
      "id": "hero_background_image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "hero_height_mobile",
      "label": "Height (mobile)",
      "min": 200,
      "max": 500,
      "step": 20,
      "default": 280,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "hero_height_sm",
      "label": "Height (tablet)",
      "min": 250,
      "max": 600,
      "step": 20,
      "default": 300,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "hero_height_lg",
      "label": "Height (desktop)",
      "min": 300,
      "max": 800,
      "step": 20,
      "default": 400,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "border_radius",
      "label": "Border radius",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "XL" },
        { "value": "2xl", "label": "2XL" },
        { "value": "3xl", "label": "3XL" }
      ],
      "default": "3xl"
    },
    {
      "type": "select",
      "id": "box_shadow",
      "label": "Box shadow",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "XL" },
        { "value": "2xl", "label": "2XL" }
      ],
      "default": "2xl"
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "select",
      "id": "content_alignment_mobile",
      "label": "Content alignment (mobile)",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "start", "label": "Left" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "content_alignment_desktop",
      "label": "Content alignment (desktop)",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "start", "label": "Left" }
      ],
      "default": "start"
    },
    {
      "type": "range",
      "id": "content_offset",
      "label": "Content left offset",
      "min": 0,
      "max": 20,
      "step": 2,
      "default": 10,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "Content max width",
      "options": [
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "XL" },
        { "value": "2xl", "label": "2XL" }
      ],
      "default": "xl"
    },
    {
      "type": "range",
      "id": "padding_mobile",
      "label": "Padding (mobile)",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "unit": "p"
    },
    {
      "type": "range",
      "id": "padding_sm",
      "label": "Padding (tablet)",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 6,
      "unit": "p"
    },
    {
      "type": "range",
      "id": "padding_lg",
      "label": "Padding (desktop)",
      "min": 4,
      "max": 16,
      "step": 2,
      "default": 12,
      "unit": "p"
    },
    {
      "type": "header",
      "content": "Colors & Effects"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price color",
      "default": "#FECDD3"
    },
    {
      "type": "color_background",
      "id": "overlay_color",
      "label": "Background overlay",
