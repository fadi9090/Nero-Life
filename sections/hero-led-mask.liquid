      "step": 5,
      "default": 30,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "overlay_opacity_end",
      "label": "Overlay opacity end",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 20,
      "unit": "%"
    },
    {
      "type": "checkbox",
      "id": "show_glow_effect",
      "label": "Show glow effect",
      "default": true
    },
    {
      "type": "header",
      "content": "Badge Settings"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show discount badge",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
