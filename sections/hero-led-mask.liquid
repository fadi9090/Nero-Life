      "options": [
        { "value": "3xl", "label": "3XL" },
        { "value": "4xl", "label": "4XL" },
        { "value": "5xl", "label": "5XL" }
      ],
      "default": "4xl"
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Title font weight",
      "options": [
        { "value": "bold", "label": "Bold" },
        { "value": "extrabold", "label": "Extra bold" },
        { "value": "black", "label": "Black" }
      ],
      "default": "black"
    },
    {
      "type": "range",
      "id": "title_margin",
      "label": "Title bottom margin (mobile)",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3,
      "unit": "space"
    },
    {
      "type": "range",
      "id": "title_margin_sm",
      "label": "Title bottom margin (desktop)",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 4,
      "unit": "space"
    },
    {
      "type": "select",
      "id": "title_leading",
      "label": "Title line height",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "tight", "label": "Tight" },
        { "value": "snug", "label": "Snug" },
        { "value": "normal", "label": "Normal" }
      ],
      "default": "snug"
    },
    {
      "type": "select",
      "id": "title_tracking",
