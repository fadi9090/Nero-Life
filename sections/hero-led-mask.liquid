    },
    {
      "type": "select",
      "id": "badge_shadow",
      "label": "Badge shadow",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "XL" }
      ],
      "default": "lg"
    },
    {
      "type": "header",
      "content": "Title Settings"
    },
    {
