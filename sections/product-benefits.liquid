{% comment %}
  Product Benefits - 4 reasons with icons
  Fully customizable
{% endcomment %}

<style>
  #product-benefits-{{ section.id }} {
    --benefits-bg: {{ section.settings.benefits_bg | default: '#FFFFFF' }};
    --benefits-border: {{ section.settings.benefits_border | default: '#F3F4F6' }};
    --benefits-shadow: {{ section.settings.benefits_shadow | default: '0 10px 15px -3px rgb(0 0 0 / 0.1)' }};
    --benefits-radius: {{ section.settings.benefits_radius | default: '12' }}px;
    --benefits-padding: {{ section.settings.benefits_padding | default: '32' }}px;
    --title-color: {{ section.settings.title_color | default: '#111827' }};
    --title-size: {{ section.settings.title_size | default: '30' }}px;
    --accent-color: {{ section.settings.accent_color | default: '#DB2777' }};
    --card-bg: {{ section.settings.card_bg | default: '#F9FAFB' }};
    --card-shadow: {{ section.settings.card_shadow | default: '0 1px 2px 0 rgb(0 0 0 / 0.05)' }};
    --card-radius: {{ section.settings.card_radius | default: '8' }}px;
    --card-padding: {{ section.settings.card_padding | default: '24' }}px;
    --icon-color: {{ section.settings.icon_color | default: '#2563EB' }};
    --icon-size: {{ section.settings.icon_size | default: '40' }}px;
    --heading-color: {{ section.settings.heading_color | default: '#1F2937' }};
    --heading-size: {{ section.settings.heading_size | default: '18' }}px;
    --text-color: {{ section.settings.text_color | default: '#4B5563' }};
    --text-size: {{ section.settings.text_size | default: '14' }}px;
  }

  .benefits-section-{{ section.id }} {
    background-color: var(--benefits-bg);
    border-radius: var(--benefits-radius);
    padding: var(--benefits-padding);
    box-shadow: var(--benefits-shadow);
    border: 1px solid var(--benefits-border);
    max-width: {{ section.settings.max_width | default: '1280' }}px;
    margin: 0 auto;
  }

  .benefits-title-{{ section.id }} {
    color: var(--title-color);
    font-size: var(--title-size);
    font-weight: {{ section.settings.title_weight | default: '800' }};
    text-align: center;
    margin-bottom: {{ section.settings.title_margin | default: '32' }}px;
  }

  .benefits-title-{{ section.id }} span {
    color: var(--accent-color);
  }

  .benefits-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_mobile | default: '1' }}, 1fr);
    gap: {{ section.settings.grid_gap | default: '24' }}px;
  }

  @media (min-width: 640px) {
    .benefits-grid-{{ section.id }} {
      grid-template-columns: repeat({{ section.settings.columns_sm | default: '2' }}, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .benefits-grid-{{ section.id }} {
      grid-template-columns: repeat({{ section.settings.columns_lg | default: '4' }}, 1fr);
    }
  }

  .benefit-card-{{ section.id }} {
    background-color: var(--card-bg);
    border-radius: var(--card-radius);
    padding: var(--card-padding);
    box-shadow: var(--card-shadow);
    text-align: center;
    transition: all {{ section.settings.card_transition | default: '300' }}ms ease;
  }

  .benefit-card-{{ section.id }}:hover {
    transform: translateY(-{{ section.settings.hover_offset | default: '4' }}px);
    box-shadow: {{ section.settings.hover_shadow | default: '0 10px 15px -3px rgb(0 0 0 / 0.1)' }};
  }

  .benefit-icon-{{ section.id }} {
    color: var(--icon-color);
    margin-bottom: {{ section.settings.icon_margin | default: '12' }}px;
    display: flex;
    justify-content: center;
  }

  .benefit-heading-{{ section.id }} {
    color: var(--heading-color);
    font-size: var(--heading-size);
    font-weight: {{ section.settings.heading_weight | default: '700' }};
    margin-bottom: {{ section.settings.heading_margin | default: '8' }}px;
  }

  .benefit-text-{{ section.id }} {
    color: var(--text-color);
    font-size: var(--text-size);
    line-height: {{ section.settings.text_line_height | default: '1.5' }};
  }
</style>

<div id="product-benefits-{{ section.id }}" class="benefits-section-{{ section.id }}" {{ section.shopify_attributes }}>
  <!-- Title -->
  <h2 class="benefits-title-{{ section.id }}">
    <span>{{ section.settings.title_prefix | default: '4 Reasons' }}</span>
    {{ section.settings.title_suffix | default: 'Why You Will Love It:' }}
  </h2>

  <!-- Benefits Grid -->
  <div class="benefits-grid-{{ section.id }}">
    {% for i in (1..4) %}
      {% assign benefit_icon = 'benefit_icon_' | append: i %}
      {% assign benefit_title = 'benefit_title_' | append: i %}
      {% assign benefit_text = 'benefit_text_' | append: i %}
      
      <div class="benefit-card-{{ section.id }}">
        <div class="benefit-icon-{{ section.id }}">
          {% case i %}
            {% when 1 %}
              {% render 'icon-clock', size: section.settings.icon_size | divided_by: 4, color: section.settings.icon_color %}
            {% when 2 %}
              {% render 'icon-beaker', size: section.settings.icon_size | divided_by: 4, color: section.settings.icon_color %}
            {% when 3 %}
              {% render 'icon-shield-check', size: section.settings.icon_size | divided_by: 4, color: section.settings.icon_color %}
            {% when 4 %}
              {% render 'icon-check-circle', size: section.settings.icon_size | divided_by: 4, color: section.settings.icon_color %}
          {% endcase %}
        </div>
        <h3 class="benefit-heading-{{ section.id }}">
          {{ section.settings[benefit_title] | default: 'Benefit Title' }}
        </h3>
        <p class="benefit-text-{{ section.id }}">
          {{ section.settings[benefit_text] | default: 'Benefit description goes here.' }}
        </p>
      </div>
    {% endfor %}
  </div>
</div>

