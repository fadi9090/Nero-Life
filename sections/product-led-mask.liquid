{% comment %}
  Section: Product LED Mask
  Description: Product display with gallery and purchase options
  Integrates with discount-config snippet for centralized discount management
{% endcomment %}

{% comment %} Load discount configuration {% endcomment %}
{% render 'discount-config' %}

{% comment %} Get the featured product {% endcomment %}
{% assign featured_product = all_products['14-silicone-face-neck-photon-mask'] %}

{% comment %} Calculate discounted prices based on discount type {% endcomment %}
{% if regular_discount > 0 %}
  {% assign single_discounted_price = featured_product.price | times: (100.0 | minus: regular_discount) | divided_by: 100 %}
{% else %}
  {% assign single_discounted_price = featured_product.price %}
{% endif %}

{% if bulk_discount > 0 %}
  {% assign bulk_discounted_price = featured_product.price | times: (100.0 | minus: bulk_discount) | divided_by: 100 %}
{% else %}
  {% assign bulk_discounted_price = single_discounted_price %}
  {% comment %} Fallback to regular discount or full price {% endcomment %}
{% endif %}

<div class="max-w-7xl mx-auto flex flex-col lg:flex-row lg:justify-between lg:gap-10 mb-8" id="product-section">
  <div class="w-full lg:w-1/2 mb-6 lg:mb-0">
    <div class="bg-white rounded-xl shadow-lg p-4 flex flex-col items-center">
      <div class="w-full h-80 sm:h-96 flex items-center justify-center mb-4">
        <img
          id="media-display"
          src="{{ featured_product.featured_image | img_url: '1024x1024' }}"
          alt="{{ featured_product.featured_image.alt | escape }}"
          class="max-h-full max-w-full object-contain rounded-lg transition-opacity duration-300"
          onerror="this.onerror=null; this.src='https://placehold.co/600x600/f0f0f0/000000?text=Image+Load+Error';"
        >
      </div>

      <div
        id="thumbnails-container"
        class="w-full flex space-x-3 overflow-x-auto no-scrollbar pb-1 justify-start sm:justify-center"
      >
        {% for media in featured_product.media %}
          {% assign is_active = false %}
          {% if forloop.first %}
            {% assign is_active = true %}
          {% endif %}
          <img
            src="{{ media.preview_image | img_url: 'medium' }}"
            alt="{{ media.alt | escape }}"
            data-full-url="{{ media | img_url: '1024x1024' }}"
            data-media-id="{{ media.id }}"
            class="
              media-thumbnail w-16 h-16 flex-shrink-0 object-cover rounded-lg cursor-pointer transition-all duration-200 hover:scale-105 hover:opacity-100
              {% if is_active %}
                  border-blue-600 border-2 ring-2 ring-blue-600/50 shadow-md
              {% else %}
                  border-gray-300 border opacity-75
              {% endif %}
            "
            onclick="swapMedia(this, '{{ media | img_url: '1024x1024' }}')"
          >
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="w-full lg:w-1/2 p-6 border rounded-xl shadow-sm bg-white">
    <h1 class="text-3xl font-extrabold mb-4 text-gray-900">
      {{ featured_product.title }}
    </h1>

    <!-- Price Display - Conditional based on discount -->
    <div class="mt-2 mb-6">
      {% if regular_discount > 0 %}
        <span class="text-xl font-bold text-gray-900">
          {{ single_discounted_price | money_without_trailing_zeros }}
        </span>
        <span class="text-base line-through text-gray-500 ml-2">
          {{ featured_product.price | money_without_trailing_zeros }}
        </span>
        <div class="text-sm text-green-600 font-medium mt-1">Save {{ regular_discount }}% on single</div>
      {% else %}
        <span class="text-xl font-bold text-gray-900">
          {{ featured_product.price | money_without_trailing_zeros }}
        </span>
      {% endif %}
    </div>

    <!-- Package Options -->
    <div class="mb-6">
      <h3 class="text-base font-semibold text-gray-800 mb-3">Choose Your Package:</h3>

      <div class="grid grid-cols-2 gap-3">
        <!-- Single Mask Option -->
        <div
          id="singleMaskOption"
          class="mask-option relative border-2 {% if regular_discount > 0 %}border-[#FA8072] bg-rose-50{% else %}border-gray-200{% endif %} rounded-lg p-3 cursor-pointer transition-all duration-200 hover:shadow-md"
          data-quantity="1"
          data-original-price="{{ featured_product.price | money }}"
          data-discounted-price="{% if regular_discount > 0 %}{{ single_discounted_price | money }}{% else %}{{ featured_product.price | money }}{% endif %}"
          data-discount-type="regular"
          data-discount-value="{{ regular_discount }}"
          onclick="selectMaskOption(this, 1)"
        >
          {% if regular_discount > 0 %}
            <div class="absolute -top-2 -right-2 w-5 h-5 bg-[#FA8072] rounded-full flex items-center justify-center">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
            </div>
          {% endif %}

          <div class="flex flex-col items-center text-center">
            <div class="package-image w-12 h-12 mb-2 bg-gray-100 rounded-lg flex items-center justify-center">
              <img
                src="{{ 'single.jpg' | asset_url }}"
                alt="Single Face & Neck Mask"
                class="w-10 h-10 object-contain"
                onerror="this.style.display='none'; this.parentElement.innerHTML='<div class=\'text-lg font-bold text-gray-700\'>1x</div>';"
              >
              <div class="text-lg font-bold text-gray-700">1x</div>
            </div>

            <h4 class="text-sm font-medium text-gray-900 mb-1">Single Mask</h4>
            <div class="text-base font-bold {% if regular_discount > 0 %}text-[#FA8072]{% else %}text-gray-900{% endif %}">
              {% if regular_discount > 0 %}
                {{ single_discounted_price | money }}
              {% else %}
                {{ featured_product.price | money }}
              {% endif %}
            </div>
            {% if regular_discount > 0 %}
              <div class="text-xs line-through text-gray-500">
                {{ featured_product.price | money }}
              </div>
            {% endif %}
          </div>
        </div>

        <!-- Double Mask Option -->
        <div
          id="doubleMaskOption"
          class="mask-option relative border-2 border-gray-200 rounded-lg p-3 cursor-pointer transition-all duration-200 hover:border-[#FA8072] hover:shadow-md"
          data-quantity="2"
          data-original-price="{{ featured_product.price | times: 2 | money }}"
          data-discounted-price="{% if bulk_discount > 0 %}{{ bulk_discounted_price | times: 2 | money }}{% else %}{{ featured_product.price | times: 2 | money }}{% endif %}"
          data-discount-type="bulk"
          data-discount-value="{{ bulk_discount }}"
          onclick="selectMaskOption(this, 2)"
        >
          <div class="absolute -top-2 -right-2 w-5 h-5 bg-[#FA8072] rounded-full flex items-center justify-center hidden">
            <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
          </div>

          <div class="flex flex-col items-center text-center">
            <div class="package-image w-12 h-12 mb-2 bg-gray-100 rounded-lg flex items-center justify-center">
              <img
                src="{{ 'double.png' | asset_url }}"
                alt="Two Face & Neck Masks"
                class="w-10 h-10 object-contain"
                onerror="this.style.display='none'; this.parentElement.innerHTML='<div class=\'text-lg font-bold text-gray-700\'>2x</div>';"
              >
              <div class="text-lg font-bold text-gray-700">2x</div>
            </div>

            <h4 class="text-sm font-medium text-gray-900 mb-1">Double Pack</h4>
            <div class="text-base font-bold {% if bulk_discount > 0 %}text-[#FA8072]{% else %}text-gray-900{% endif %}">
              {% if bulk_discount > 0 %}
                {{ bulk_discounted_price | times: 2 | money }}
              {% else %}
                {{ featured_product.price | times: 2 | money }}
              {% endif %}
            </div>

            {% if bulk_discount > 0 %}
              <div class="text-xs line-through text-gray-500">
                {{ featured_product.price | times: 2 | money }}
              </div>
              {% assign original_total = featured_product.price | times: 2 %}
              {% assign discounted_total = bulk_discounted_price | times: 2 %}
              {% assign save_amount = original_total | minus: discounted_total %}
              <div class="text-xs text-green-600 font-medium mt-1">Save {{ save_amount | money }}</div>
            {% elsif regular_discount > 0 %}
              {% comment %} If no bulk discount but regular discount exists, show regular discount savings {% endcomment %}
              {% assign original_total = featured_product.price | times: 2 %}
              {% assign discounted_total = single_discounted_price | times: 2 %}
              {% assign save_amount = original_total | minus: discounted_total %}
              <div class="text-xs text-green-600 font-medium mt-1">
                Save {{ save_amount | money }} ({{ regular_discount }}% each)
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>

    <!-- Add to Cart Form -->
    <div class="mt-6">
      <form method="post" action="/cart/add" id="addToCartForm">
        <input
          type="hidden"
          name="id"
          value="{{ featured_product.selected_or_first_available_variant.id }}"
          id="selectedVariantId"
        >
        <input type="hidden" name="quantity" value="1" id="selectedQuantity">
        <input type="hidden" name="return_to" value="/cart">

        <button
          type="submit"
          id="addToCartButton"
          class="bg-[#FA8072] text-white p-3 rounded-xl w-full text-base font-semibold shadow-md hover:bg-[#E57365] transition duration-200"
        >
          Add to Cart - <span class="quantity-text">1 Mask</span>
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  // Product-specific JavaScript
  (function () {
    // Global variables for cart state
    let selectedQuantity = 1;
    let selectedPackageElement = null;

    // --- Media Swapping Functionality ---
    window.swapMedia = function (thumbnail, fullImageUrl) {
      const mediaDisplay = document.getElementById('media-display');
      const thumbnails = document.querySelectorAll('.media-thumbnail');

      // Update main image
      mediaDisplay.style.opacity = '0';
      setTimeout(() => {
        mediaDisplay.src = fullImageUrl;
        mediaDisplay.style.opacity = '1';
      }, 150);

      // Update thumbnail states
      thumbnails.forEach((thumb) => {
        thumb.classList.remove('border-blue-600', 'ring-2', 'ring-blue-600/50', 'shadow-md');
        thumb.classList.add('border-gray-300', 'opacity-75');
      });

      // Activate clicked thumbnail
      thumbnail.classList.add('border-blue-600', 'ring-2', 'ring-blue-600/50', 'shadow-md');
      thumbnail.classList.remove('border-gray-300', 'opacity-75');
    };

    // --- Mask Option Selection Functionality ---
    window.selectMaskOption = function (element, quantity) {
      // Remove selection from all options
      document.querySelectorAll('.mask-option').forEach((option) => {
        option.classList.remove('border-[#FA8072]', 'bg-rose-50');
        option.classList.add('border-gray-200');
        const checkmark = option.querySelector('.absolute.-top-2.-right-2');
        if (checkmark) checkmark.classList.add('hidden');
      });

      // Add selection to clicked option
      element.classList.add('border-[#FA8072]', 'bg-rose-50');
      element.classList.remove('border-gray-200');
      const checkmark = element.querySelector('.absolute.-top-2.-right-2');
      if (checkmark) checkmark.classList.remove('hidden');

      // Update selected quantity and store selected element
      selectedQuantity = quantity;
      selectedPackageElement = element;

      // Update hidden quantity input
      document.getElementById('selectedQuantity').value = quantity;

      // Update button text
      const button = document.getElementById('addToCartButton');
      const quantityText = button.querySelector('.quantity-text');
      quantityText.textContent = `${quantity} Mask${quantity > 1 ? 's' : ''}`;

      // Update the main price display
      updateMainPriceDisplay(element);
    };

    // Function to update the main price display
    function updateMainPriceDisplay(selectedElement) {
      const priceDisplay = document.querySelector('.mt-2.mb-6');
      if (!priceDisplay) return;

      const quantity = parseInt(selectedElement.getAttribute('data-quantity'));
      const originalPrice = selectedElement.getAttribute('data-original-price');
      const discountedPrice = selectedElement.getAttribute('data-discounted-price');
      const discountType = selectedElement.getAttribute('data-discount-type');
      const discountValue = selectedElement.getAttribute('data-discount-value');

      let priceHTML = '';

      // Check if there's a discount applied to this option
      if (discountValue > 0) {
        priceHTML = `
                    <span class="text-xl font-bold text-gray-900">
                        ${discountedPrice}
                    </span>
                    <span class="text-base line-through text-gray-500 ml-2">
                        ${originalPrice}
                    </span>
                `;

        // Add appropriate save message
        if (quantity === 1) {
          priceHTML += `<div class="text-sm text-green-600 font-medium mt-1">Save ${discountValue}%</div>`;
        } else {
          const saveElement = selectedElement.querySelector('.text-green-600');
          if (saveElement) {
            priceHTML += `<div class="text-sm text-green-600 font-medium mt-1">${saveElement.textContent}</div>`;
          }
        }
      } else {
        // No discount - just show regular price
        priceHTML = `
                    <span class="text-xl font-bold text-gray-900">
                        ${originalPrice}
                    </span>
                `;
      }

      priceDisplay.innerHTML = priceHTML;
    }

    // --- Event Listeners and Initialization ---
    document.addEventListener('DOMContentLoaded', function () {
      // 1. Initialize with single mask selected
      const singleMaskOption = document.querySelector('.mask-option[data-quantity="1"]');
      if (singleMaskOption) {
        const discountValue = singleMaskOption.getAttribute('data-discount-value');
        if (discountValue > 0) {
          selectMaskOption(singleMaskOption, 1);
        } else {
          // Even without discount, select it as default
          selectedPackageElement = singleMaskOption;
          selectedQuantity = 1;

          // Update hidden input
          document.getElementById('selectedQuantity').value = 1;

          // Update button text
          const button = document.getElementById('addToCartButton');
          const quantityText = button.querySelector('.quantity-text');
          quantityText.textContent = '1 Mask';
        }
        selectedPackageElement = singleMaskOption;
      }

      // 2. Form submission will handle adding to cart naturally
      // No need for additional event listeners - the form handles it!
    });
  })();
</script>

{% schema %}
{
  "name": "Product LED Mask",
  "settings": [
    {
      "type": "header",
      "content": "Product Settings"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured Product",
      "info": "Select a product to display"
    },
    {
      "type": "header",
      "content": "Display Settings"
    },
    {
      "type": "checkbox",
      "id": "show_packages",
      "label": "Show package options",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_thumbnails",
      "label": "Show image thumbnails",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Product LED Mask",
      "category": "Product"
    }
  ]
}
{% endschema %}
