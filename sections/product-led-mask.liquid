{% comment %}
  Section: Product LED Mask
  Description: Product display with gallery and purchase options
  Fully customizable through theme editor
{% endcomment %}

{% render 'discount' %}
{% assign featured_product = all_products[section.settings.featured_product] %}

{% if regular_discount > 0 and featured_product.price > 0 %}
  {% assign discount_multiplier = 100.0 | minus: regular_discount %}
  {% assign single_discounted_price = featured_product.price | times: discount_multiplier | divided_by: 100 %}
{% else %}
  {% assign single_discounted_price = featured_product.price %}
{% endif %}

{% if bulk_discount > 0 and featured_product.price > 0 %}
  {% assign bulk_discount_multiplier = 100.0 | minus: bulk_discount %}
  {% assign bulk_discounted_price = featured_product.price | times: bulk_discount_multiplier | divided_by: 100 %}
{% else %}
  {% assign bulk_discounted_price = single_discounted_price %}
{% endif %}

<style>
  #product-{{ section.id }} {
    --product-bg: {{ section.settings.product_bg | default: '#FFFFFF' }};
    --product-border: {{ section.settings.product_border | default: '#E5E7EB' }};
    --product-title-color: {{ section.settings.title_color | default: '#111827' }};
    --product-price-color: {{ section.settings.price_color | default: '#111827' }};
    --product-sale-price-color: {{ section.settings.sale_price_color | default: '#FA8072' }};
    --product-compare-color: {{ section.settings.compare_color | default: '#6B7280' }};
    --product-save-color: {{ section.settings.save_color | default: '#16A34A' }};
    --product-option-border: {{ section.settings.option_border | default: '#E5E7EB' }};
    --product-option-selected: {{ section.settings.option_selected | default: '#FA8072' }};
    --product-option-bg: {{ section.settings.option_bg | default: '#FEF2F2' }};
    --product-button-bg: {{ section.settings.button_bg | default: '#FA8072' }};
    --product-button-hover: {{ section.settings.button_hover | default: '#E57365' }};
    --product-button-text: {{ section.settings.button_text | default: '#FFFFFF' }};
    --product-gallery-border: {{ section.settings.gallery_border | default: '#3B82F6' }};
    --thumbnail-size: {{ section.settings.thumbnail_size | default: '64' }}px;
    --main-image-height: {{ section.settings.main_image_height | default: '384' }}px;
  }

  @media (min-width: 640px) {
    #product-{{ section.id }} {
      --main-image-height: {{ section.settings.main_image_height_sm | default: '384' }}px;
    }
  }

  @media (min-width: 1024px) {
    #product-{{ section.id }} {
      --main-image-height: {{ section.settings.main_image_height_lg | default: '384' }}px;
    }
  }

  .product-section-{{ section.id }} {
    background-color: var(--product-bg);
    border-color: var(--product-border);
  }

  .product-title-{{ section.id }} {
    color: var(--product-title-color);
    font-size: {{ section.settings.title_size | default: '3xl' }};
    font-weight: {{ section.settings.title_weight | default: '800' }};
  }

  @media (min-width: 1024px) {
    .product-title-{{ section.id }} {
      font-size: {{ section.settings.title_size_lg | default: '3xl' }};
    }
  }

  .product-price-{{ section.id }} {
    color: var(--product-price-color);
  }

  .product-sale-price-{{ section.id }} {
    color: var(--product-sale-price-color);
  }

  .product-compare-price-{{ section.id }} {
    color: var(--product-compare-color);
  }

  .product-save-badge-{{ section.id }} {
    color: var(--product-save-color);
  }

  .product-option-{{ section.id }} {
    border-color: var(--product-option-border);
  }

  .product-option-{{ section.id }}.selected {
    border-color: var(--product-option-selected);
    background-color: var(--product-option-bg);
  }

  .product-button-{{ section.id }} {
    background-color: var(--product-button-bg);
    color: var(--product-button-text);
    transition: all {{ section.settings.button_transition | default: '200' }}ms ease;
  }

  .product-button-{{ section.id }}:hover:not(:disabled) {
    background-color: var(--product-button-hover);
  }

  .product-button-{{ section.id }}:disabled {
    opacity: {{ section.settings.button_disabled_opacity | default: '0.5' }};
    cursor: not-allowed;
  }

  .media-display-{{ section.id }} {
    height: var(--main-image-height);
  }

  .media-thumbnail-{{ section.id }} {
    width: var(--thumbnail-size);
    height: var(--thumbnail-size);
  }

  .media-thumbnail-{{ section.id }}.active {
    border-color: var(--product-gallery-border);
    border-width: {{ section.settings.thumbnail_border_width | default: '2' }}px;
    --tw-ring-color: var(--product-gallery-border);
  }

  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<div id="product-{{ section.id }}" class="max-w-7xl mx-auto flex flex-col lg:flex-row lg:justify-between lg:gap-{{ section.settings.gap | default: '10' }} mb-8" {{ section.shopify_attributes }}>
  
  <!-- Gallery Section -->
  <div class="w-full lg:w-1/2 mb-6 lg:mb-0">
    <div class="product-section-{{ section.id }} rounded-{{ section.settings.gallery_radius | default: 'xl' }} shadow-{{ section.settings.gallery_shadow | default: 'lg' }} p-{{ section.settings.gallery_padding | default: '4' }} flex flex-col items-center">
      
      <!-- Main Image -->
      <div class="media-display-{{ section.id }} w-full flex items-center justify-center mb-4">
        <img
          id="media-display"
          src="{% if featured_product.featured_image != blank %}{{ featured_product.featured_image | image_url: width: 1024, height: 1024 }}{% elsif section.settings.fallback_image != blank %}{{ section.settings.fallback_image | image_url: width: 1024, height: 1024 }}{% else %}{{ 'placeholder-image' | asset_url }}{% endif %}"
          alt="{% if featured_product.featured_image != blank %}{{ featured_product.featured_image.alt | escape }}{% else %}{{ section.settings.fallback_title }}{% endif %}"
          class="max-h-full max-w-full object-contain rounded-{{ section.settings.image_radius | default: 'lg' }} transition-opacity duration-{{ section.settings.image_transition | default: '300' }}"
          width="1024"
          height="1024"
          loading="lazy"
          style="opacity: 1;"
        >
      </div>

      <!-- Thumbnails -->
      {% if section.settings.show_thumbnails and featured_product.media.size > 0 %}
        <div class="w-full flex space-x-{{ section.settings.thumbnail_spacing | default: '3' }} overflow-x-auto no-scrollbar pb-1 justify-start sm:justify-center">
          {% for media in featured_product.media %}
            {% assign is_active = false %}
            {% if forloop.first %}
              {% assign is_active = true %}
            {% endif %}
            <img
              src="{{ media.preview_image | image_url: width: 64, height: 64 }}"
              alt="{{ media.alt | escape }}"
              data-full-url="{{ media | image_url: width: 1024, height: 1024 }}"
              data-media-id="{{ media.id }}"
              class="media-thumbnail-{{ section.id }} flex-shrink-0 object-cover rounded-{{ section.settings.thumbnail_radius | default: 'lg' }} cursor-pointer transition-all duration-{{ section.settings.thumbnail_transition | default: '200' }} hover:scale-{{ section.settings.thumbnail_hover_scale | default: '105' }} {% if is_active %}active{% else %}opacity-{{ section.settings.thumbnail_inactive_opacity | default: '75' }}{% endif %}"
              width="64"
              height="64"
              onclick="swapMedia(this, '{{ media | image_url: width: 1024, height: 1024 }}')"
              loading="lazy"
            >
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>

  <!-- Product Info Section -->
  <div class="w-full lg:w-1/2 p-{{ section.settings.info_padding | default: '6' }} border rounded-{{ section.settings.info_radius | default: 'xl' }} shadow-{{ section.settings.info_shadow | default: 'sm' }} product-section-{{ section.id }}">
    
    <!-- Product Title -->
    <h1 class="product-title-{{ section.id }} font-{{ section.settings.title_weight | default: '800' }} mb-{{ section.settings.title_margin | default: '4' }}">
      {{ featured_product.title | default: section.settings.fallback_title }}
    </h1>

    <!-- Price Display -->
    <div class="mt-{{ section.settings.price_margin_top | default: '2' }} mb-{{ section.settings.price_margin_bottom | default: '6' }}">
      {% if regular_discount > 0 and featured_product.price > 0 %}
        <span class="product-sale-price-{{ section.id }} text-{{ section.settings.sale_price_size | default: 'xl' }} font-{{ section.settings.price_weight | default: 'bold' }}">
          {{ single_discounted_price | money_without_trailing_zeros }}
        </span>
        <span class="product-compare-price-{{ section.id }} text-{{ section.settings.compare_size | default: 'base' }} line-through ml-{{ section.settings.compare_spacing | default: '2' }}">
          {{ featured_product.price | money_without_trailing_zeros }}
        </span>
        {% if section.settings.show_save_badge %}
          <div class="product-save-badge-{{ section.id }} text-{{ section.settings.save_size | default: 'sm' }} font-{{ section.settings.save_weight | default: '500' }} mt-{{ section.settings.save_margin | default: '1' }}">
            {{ section.settings.save_text | default: 'Save' }} {{ regular_discount }}%
          </div>
        {% endif %}
      {% elsif featured_product.price > 0 %}
        <span class="product-price-{{ section.id }} text-{{ section.settings.regular_price_size | default: 'xl' }} font-{{ section.settings.price_weight | default: 'bold' }}">
          {{ featured_product.price | money_without_trailing_zeros }}
        </span>
      {% endif %}
    </div>

    <!-- Package Options -->
    {% if section.settings.show_packages %}
      <div class="mb-{{ section.settings.packages_margin | default: '6' }}">
        <h3 class="text-{{ section.settings.packages_title_size | default: 'base' }} font-{{ section.settings.packages_title_weight | default: '600' }} text-gray-800 mb-{{ section.settings.packages_title_margin | default: '3' }}">
          {{ section.settings.packages_title | default: 'Choose Your Package:' }}
        </h3>

        <div class="grid grid-cols-{{ section.settings.packages_per_row | default: '2' }} gap-{{ section.settings.packages_gap | default: '3' }}">
          
          <!-- Single Mask Option -->
          <div
            class="product-option-{{ section.id }} relative border-2 {% if regular_discount > 0 %}selected{% endif %} rounded-{{ section.settings.option_radius | default: 'lg' }} p-{{ section.settings.option_padding | default: '3' }} cursor-pointer transition-all duration-{{ section.settings.option_transition | default: '200' }} hover:shadow-{{ section.settings.option_hover_shadow | default: 'md' }}"
            data-quantity="1"
            data-original-price="{{ featured_product.price | money }}"
            data-discounted-price="{% if regular_discount > 0 %}{{ single_discounted_price | money }}{% else %}{{ featured_product.price | money }}{% endif %}"
            data-discount-type="regular"
            data-discount-value="{{ regular_discount }}"
            onclick="selectMaskOption(this, 1)"
          >
            {% if regular_discount > 0 and section.settings.show_selected_check %}
              <div class="absolute -top-2 -right-2 w-5 h-5 bg-[var(--product-option-selected)] rounded-full flex items-center justify-center">
                <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
              </div>
            {% endif %}

            <div class="flex flex-col items-center text-center">
              <div class="package-image w-{{ section.settings.package_icon_size | default: '12' }} h-{{ section.settings.package_icon_size | default: '12' }} mb-{{ section.settings.package_icon_margin | default: '2' }} bg-gray-100 rounded-{{ section.settings.package_icon_radius | default: 'lg' }} flex items-center justify-center">
                {% if section.settings.single_package_image != blank %}
                  <img
                    src="{{ section.settings.single_package_image | image_url: width: 100, height: 100 }}"
                    alt="{{ section.settings.single_package_title | default: 'Single Mask' }}"
                    class="w-{{ section.settings.package_icon_size | minus: 2 | default: '10' }} h-{{ section.settings.package_icon_size | minus: 2 | default: '10' }} object-contain"
                    width="100"
                    height="100"
                    loading="lazy"
                  >
                {% else %}
                  <div class="text-{{ section.settings.package_fallback_size | default: 'lg' }} font-{{ section.settings.package_fallback_weight | default: 'bold' }} text-gray-700">1x</div>
                {% endif %}
              </div>

              <h4 class="text-{{ section.settings.package_title_size | default: 'sm' }} font-{{ section.settings.package_title_weight | default: '500' }} text-gray-900 mb-{{ section.settings.package_title_margin | default: '1' }}">
                {{ section.settings.single_package_title | default: 'Single Mask' }}
              </h4>
              
              <div class="text-{{ section.settings.package_price_size | default: 'base' }} font-{{ section.settings.package_price_weight | default: 'bold' }} {% if regular_discount > 0 %}product-sale-price-{{ section.id }}{% else %}product-price-{{ section.id }}{% endif %}">
                {% if regular_discount > 0 %}
                  {{ single_discounted_price | money }}
                {% else %}
                  {{ featured_product.price | money }}
                {% endif %}
              </div>
              
              {% if regular_discount > 0 and section.settings.show_package_compare %}
                <div class="product-compare-price-{{ section.id }} text-{{ section.settings.package_compare_size | default: 'xs' }} line-through">
                  {{ featured_product.price | money }}
                </div>
              {% endif %}
            </div>
          </div>

          <!-- Double Mask Option -->
          <div
            class="product-option-{{ section.id }} relative border-2 border-gray-200 rounded-{{ section.settings.option_radius | default: 'lg' }} p-{{ section.settings.option_padding | default: '3' }} cursor-pointer transition-all duration-{{ section.settings.option_transition | default: '200' }} hover:border-[var(--product-option-selected)] hover:shadow-{{ section.settings.option_hover_shadow | default: 'md' }}"
            data-quantity="2"
            data-original-price="{{ featured_product.price | times: 2 | money }}"
            data-discounted-price="{% if bulk_discount > 0 %}{{ bulk_discounted_price | times: 2 | money }}{% else %}{{ featured_product.price | times: 2 | money }}{% endif %}"
            data-discount-type="bulk"
            data-discount-value="{{ bulk_discount }}"
            onclick="selectMaskOption(this, 2)"
          >
            {% if section.settings.show_selected_check %}
              <div class="absolute -top-2 -right-2 w-5 h-5 bg-[var(--product-option-selected)] rounded-full flex items-center justify-center hidden">
                <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
              </div>
            {% endif %}

            <div class="flex flex-col items-center text-center">
              <div class="package-image w-{{ section.settings.package_icon_size | default: '12' }} h-{{ section.settings.package_icon_size | default: '12' }} mb-{{ section.settings.package_icon_margin | default: '2' }} bg-gray-100 rounded-{{ section.settings.package_icon_radius | default: 'lg' }} flex items-center justify-center">
                {% if section.settings.double_package_image != blank %}
                  <img
                    src="{{ section.settings.double_package_image | image_url: width: 100, height: 100 }}"
                    alt="{{ section.settings.double_package_title | default: 'Double Pack' }}"
                    class="w-{{ section.settings.package_icon_size | minus: 2 | default: '10' }} h-{{ section.settings.package_icon_size | minus: 2 | default: '10' }} object-contain"
                    width="100"
                    height="100"
                    loading="lazy"
                  >
                {% else %}
                  <div class="text-{{ section.settings.package_fallback_size | default: 'lg' }} font-{{ section.settings.package_fallback_weight | default: 'bold' }} text-gray-700">2x</div>
                {% endif %}
              </div>

              <h4 class="text-{{ section.settings.package_title_size | default: 'sm' }} font-{{ section.settings.package_title_weight | default: '500' }} text-gray-900 mb-{{ section.settings.package_title_margin | default: '1' }}">
                {{ section.settings.double_package_title | default: 'Double Pack' }}
              </h4>
              
              <div class="text-{{ section.settings.package_price_size | default: 'base' }} font-{{ section.settings.package_price_weight | default: 'bold' }} {% if bulk_discount > 0 %}product-sale-price-{{ section.id }}{% else %}product-price-{{ section.id }}{% endif %}">
                {% if bulk_discount > 0 %}
                  {{ bulk_discounted_price | times: 2 | money }}
                {% else %}
                  {{ featured_product.price | times: 2 | money }}
                {% endif %}
              </div>

              {% if bulk_discount > 0 and section.settings.show_package_compare %}
                <div class="product-compare-price-{{ section.id }} text-{{ section.settings.package_compare_size | default: 'xs' }} line-through">
                  {{ featured_product.price | times: 2 | money }}
                </div>
                {% assign original_total = featured_product.price | times: 2 %}
                {% assign discounted_total = bulk_discounted_price | times: 2 %}
                {% assign save_amount = original_total | minus: discounted_total %}
                <div class="product-save-badge-{{ section.id }} text-{{ section.settings.package_save_size | default: 'xs' }} font-{{ section.settings.package_save_weight | default: '500' }} mt-{{ section.settings.package_save_margin | default: '1' }}">
                  {{ section.settings.save_text | default: 'Save' }} {{ save_amount | money }}
                </div>
              {% elsif regular_discount > 0 and section.settings.show_package_save %}
                {% assign original_total = featured_product.price | times: 2 %}
                {% assign discounted_total = single_discounted_price | times: 2 %}
                {% assign save_amount = original_total | minus: discounted_total %}
                <div class="product-save-badge-{{ section.id }} text-{{ section.settings.package_save_size | default: 'xs' }} font-{{ section.settings.package_save_weight | default: '500' }} mt-{{ section.settings.package_save_margin | default: '1' }}">
                  {{ section.settings.save_text | default: 'Save' }} {{ save_amount | money }} ({{ regular_discount }}% each)
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    {% endif %}

    <!-- Add to Cart Form -->
    <div class="mt-{{ section.settings.form_margin_top | default: '6' }}">
      <form method="post" action="/cart/add" id="addToCartForm">
        <input
          type="hidden"
          name="id"
          value="{{ featured_product.selected_or_first_available_variant.id }}"
          id="selectedVariantId"
        >
        <input type="hidden" name="quantity" value="1" id="selectedQuantity">
        <input type="hidden" name="return_to" value="/cart">

        <button
          type="submit"
          id="addToCartButton"
          class="product-button-{{ section.id }} w-full p-{{ section.settings.button_padding | default: '3' }} rounded-{{ section.settings.button_radius | default: 'xl' }} text-{{ section.settings.button_text_size | default: 'base' }} font-{{ section.settings.button_weight | default: '600' }} shadow-{{ section.settings.button_shadow | default: 'md' }}"
          {% unless featured_product.available %}disabled{% endunless %}
        >
          {% if featured_product.available %}
            {{ section.settings.button_text | default: 'Add to Cart' }} - <span class="quantity-text">{{ section.settings.button_text_single | default: '1 Mask' }}</span>
          {% else %}
            {{ section.settings.sold_out_text | default: 'Sold Out' }}
          {% endif %}
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  (function () {
    let selectedQuantity = 1;
    let selectedPackageElement = null;

    window.swapMedia = function (thumbnail, fullImageUrl) {
      const mediaDisplay = document.getElementById('media-display');
      const thumbnails = document.querySelectorAll('.media-thumbnail-{{ section.id }}');

      if (!mediaDisplay) return;

      mediaDisplay.style.opacity = '0';
      setTimeout(() => {
        mediaDisplay.src = fullImageUrl;
        mediaDisplay.style.opacity = '1';
      }, {{ section.settings.image_transition | default: '300' }});

      thumbnails.forEach((thumb) => {
        thumb.classList.remove('active', 'border-{{ section.settings.gallery_border_color | default: "blue-600" }}', 'ring-2', 'ring-{{ section.settings.gallery_border_color | default: "blue-600" }}/50', 'shadow-md');
        thumb.style.opacity = '{{ section.settings.thumbnail_inactive_opacity | default: "0.75" }}';
      });

      thumbnail.classList.add('active');
      thumbnail.style.opacity = '1';
    };

    window.selectMaskOption = function (element, quantity) {
      document.querySelectorAll('.product-option-{{ section.id }}').forEach((option) => {
        option.classList.remove('selected');
        const checkmark = option.querySelector('.absolute.-top-2.-right-2');
        if (checkmark) checkmark.classList.add('hidden');
      });

      element.classList.add('selected');
      const checkmark = element.querySelector('.absolute.-top-2.-right-2');
      if (checkmark) checkmark.classList.remove('hidden');

      selectedQuantity = quantity;
      selectedPackageElement = element;

      const quantityInput = document.getElementById('selectedQuantity');
      if (quantityInput) quantityInput.value = quantity;

      const button = document.getElementById('addToCartButton');
      if (button) {
        const quantityText = button.querySelector('.quantity-text');
        if (quantityText) {
          quantityText.textContent = `${quantity} {{ section.settings.button_text_unit | default: 'Mask' }}${quantity > 1 ? 's' : ''}`;
        }
      }

      updateMainPriceDisplay(element);
    };

    function updateMainPriceDisplay(selectedElement) {
      const priceDisplay = document.querySelector('.mt-2.mb-6');
      if (!priceDisplay) return;

      const originalPrice = selectedElement.getAttribute('data-original-price');
      const discountedPrice = selectedElement.getAttribute('data-discounted-price');
      const discountValue = selectedElement.getAttribute('data-discount-value');

      let priceHTML = '';

      if (discountValue > 0) {
        priceHTML = `
          <span class="product-sale-price-{{ section.id }} text-{{ section.settings.sale_price_size | default: 'xl' }} font-{{ section.settings.price_weight | default: 'bold' }}">
            ${discountedPrice}
          </span>
          <span class="product-compare-price-{{ section.id }} text-{{ section.settings.compare_size | default: 'base' }} line-through ml-{{ section.settings.compare_spacing | default: '2' }}">
            ${originalPrice}
          </span>
        `;
      } else {
        priceHTML = `
          <span class="product-price-{{ section.id }} text-{{ section.settings.regular_price_size | default: 'xl' }} font-{{ section.settings.price_weight | default: 'bold' }}">
            ${originalPrice}
          </span>
        `;
      }

      priceDisplay.innerHTML = priceHTML;
    }

    document.addEventListener('DOMContentLoaded', function () {
      const singleMaskOption = document.querySelector('.product-option-{{ section.id }}[data-quantity="1"]');
      if (singleMaskOption) {
        selectMaskOption(singleMaskOption, 1);
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Product LED Mask",
  "settings": [
    {
      "type": "header",
      "content": "Product Settings"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured Product",
      "info": "Select a product to display"
    },
    {
      "type": "text",
      "id": "fallback_title",
      "label": "Fallback Title",
      "default": "LED Face & Neck Mask"
    },
    {
      "type": "image_picker",
      "id": "fallback_image",
      "label": "Fallback Image"
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between sections",
      "min": 4,
      "max": 16,
      "step": 2,
      "default": 10,
      "unit": "space"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "product_bg",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "product_border",
      "label": "Border color",
      "default": "#E5E7EB"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Regular price color",
