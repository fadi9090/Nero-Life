{% comment %}
  Section: Benefits LED Mask
  Description: Key benefits and features section
{% endcomment %}

<div class="w-full p-6 sm:p-8 md:p-12 bg-gradient-to-br from-white to-gray-50 rounded-3xl shadow-2xl">
    <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black text-gray-900 mb-6 sm:mb-8 border-b-2 border-rose-100 pb-3 sm:pb-4">{{ section.settings.section_title | default: 'Why Our LED Mask Stands Out' }}</h2>
    
    <!-- Desktop Layout: Benefits and Stats Side by Side -->
    <div class="lg:flex lg:space-x-8">
        <!-- Benefits List -->
        <div class="lg:w-1/2">
            <ul class="space-y-4 sm:space-y-5 mb-8 sm:mb-0">
                <li class="flex items-start group">
                    <div class="flex-shrink-0 w-8 h-8 sm:w-10 sm:h-10 bg-gradient-to-r from-rose-500 to-pink-500 rounded-full flex items-center justify-center mr-3 sm:mr-4 group-hover:scale-110 transition-transform duration-300">
                        <svg class="w-4 h-4 sm:w-5 sm:h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                        </svg>
                    </div>
                    <span class="text-gray-800 text-base sm:text-lg font-medium pt-1 sm:pt-2">{{ section.settings.benefit_1 | default: 'Dual-area treatment for face and neck simultaneously' }}</span>
                </li>
                <li class="flex items-start group">
                    <div class="flex-shrink-0 w-8 h-8 sm:w-10 sm:h-10 bg-gradient-to-r from-rose-500 to-pink-500 rounded-full flex items-center justify-center mr-3 sm:mr-4 group-hover:scale-110 transition-transform duration-300">
                        <svg class="w-4 h-4 sm:w-5 sm:h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"></path>
                        </svg>
                    </div>
                    <span class="text-gray-800 text-base sm:text-lg font-medium pt-1 sm:pt-2">{{ section.settings.benefit_2 | default: '7 specialized light wavelengths for different skin concerns' }}</span>
                </li>
                <li class="flex items-start group">
                    <div class="flex-shrink-0 w-8 h-8 sm:w-10 sm:h-10 bg-gradient-to-r from-rose-500 to-pink-500 rounded-full flex items-center justify-center mr-3 sm:mr-4 group-hover:scale-110 transition-transform duration-300">
                        <svg class="w-4 h-4 sm:w-5 sm:h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                    </div>
                    <span class="text-gray-800 text-base sm:text-lg font-medium pt-1 sm:pt-2">{{ section.settings.benefit_3 | default: 'Clinically tested technology with proven safety standards' }}</span>
                </li>
                <li class="flex items-start group">
                    <div class="flex-shrink-0 w-8 h-8 sm:w-10 sm:h-10 bg-gradient-to-r from-rose-500 to-pink-500 rounded-full flex items-center justify-center mr-3 sm:mr-4 group-hover:scale-110 transition-transform duration-300">
                        <svg class="w-4 h-4 sm:w-5 sm:h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path>
                        </svg>
                    </div>
                    <span class="text-gray-800 text-base sm:text-lg font-medium pt-1 sm:pt-2">{{ section.settings.benefit_4 | default: 'Ergonomic design fits all face shapes and neck contours' }}</span>
                </li>
            </ul>
        </div>
        
        <!-- Stats Grid -->
        <div class="lg:w-1/2">
            <div class="grid grid-cols-2 gap-4 sm:gap-5">
                <div class="bg-white rounded-xl sm:rounded-2xl p-4 sm:p-5 text-center border border-rose-100 shadow-lg">
                    <div class="text-2xl sm:text-3xl font-black text-rose-600">{{ section.settings.stat_1_value | default: '94%' }}</div>
                    <div class="text-sm text-gray-600 mt-2 font-medium">{{ section.settings.stat_1_label | default: 'Users See Results' }}</div>
                </div>
                <div class="bg-white rounded-xl sm:rounded-2xl p-4 sm:p-5 text-center border border-rose-100 shadow-lg">
                    <div class="text-2xl sm:text-3xl font-black text-rose-600">{{ section.settings.stat_2_value | default: '12min' }}</div>
                    <div class="text-sm text-gray-600 mt-2 font-medium">{{ section.settings.stat_2_label | default: 'Daily Treatment' }}</div>
                </div>
                <div class="bg-white rounded-xl sm:rounded-2xl p-4 sm:p-5 text-center border border-rose-100 shadow-lg">
                    <div class="text-2xl sm:text-3xl font-black text-rose-600">{{ section.settings.stat_3_value | default: '7-in-1' }}</div>
                    <div class="text-sm text-gray-600 mt-2 font-medium">{{ section.settings.stat_3_label | default: 'Light Therapy' }}</div>
                </div>
                <div class="bg-white rounded-xl sm:rounded-2xl p-4 sm:p-5 text-center border border-rose-100 shadow-lg">
                    <div class="text-2xl sm:text-3xl font-black text-rose-600">{{ section.settings.stat_4_value | default: '30D+' }}<span class="text-lg">*</span></div>
                    <div class="text-sm text-gray-600 mt-2 font-medium">
                        <div>{{ section.settings.stat_4_label | default: 'Warranty' }}</div>
                        <div class="text-xs text-rose-500 mt-1">{{ section.settings.warranty_upsell | default: '+2Y for $10' }}</div>
                    </div>
                </div>
            </div>
            
            <!-- Warranty Note -->
            <div class="mt-4 sm:mt-5 p-3 sm:p-4 bg-rose-50 rounded-lg border border-rose-100">
                <p class="text-xs sm:text-sm text-gray-700">
                    <span class="font-semibold text-rose-600">{{ section.settings.warranty_note_label | default: 'Warranty Details:' }}</span> 
                    {{ section.settings.warranty_note | default: '30-day warranty from Manyfatcor included. Add 2-year extended guarantee for just $10 at checkout.' }}
                </p>
            </div>
        </div>
    </div>
</div>

