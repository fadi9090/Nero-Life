{% comment %}
  Visible Results Timeline - Fully customizable with images
{% endcomment %}

<style>
  #results-{{ section.id }} {
    --results-bg: {{ section.settings.results_bg | default: '#F9FAFB' }};
    --results-radius: {{ section.settings.results_radius | default: '12' }}px;
    --results-padding: {{ section.settings.results_padding | default: '48' }}px;
    --title-color: {{ section.settings.title_color | default: '#111827' }};
    --title-size: {{ section.settings.title_size | default: '30' }}px;
    --subtitle-color: {{ section.settings.subtitle_color | default: '#4B5563' }};
    --subtitle-size: {{ section.settings.subtitle_size | default: '20' }}px;
    --card-bg: {{ section.settings.card_bg | default: '#FFFFFF' }};
    --card-border: {{ section.settings.card_border | default: '#F3F4F6' }};
    --card-shadow: {{ section.settings.card_shadow | default: '0 10px 15px -3px rgb(0 0 0 / 0.1)' }};
    --card-radius: {{ section.settings.card_radius | default: '16' }}px;
    --week-badge-bg: {{ section.settings.week_badge_bg | default: '#FDF2F8' }};
    --week-badge-color: {{ section.settings.week_badge_color | default: '#BE185D' }};
    --progress-1: {{ section.settings.progress_1_color | default: '#EC4899' }};
    --progress-2: {{ section.settings.progress_2_color | default: '#8B5CF6' }};
    --progress-3: {{ section.settings.progress_3_color | default: '#3B82F6' }};
    --connector-1: {{ section.settings.connector_1 | default: '#FBCFE8' }};
    --connector-2: {{ section.settings.connector_2 | default: '#DDD6FE' }};
  }

  .results-section-{{ section.id }} {
    background-color: var(--results-bg);
    border-radius: var(--results-radius);
    padding: var(--results-padding);
    max-width: {{ section.settings.max_width | default: '1280' }}px;
    margin: 0 auto;
  }

  .results-header-{{ section.id }} {
    text-align: center;
    margin-bottom: {{ section.settings.header_margin | default: '64' }}px;
  }

  .results-title-{{ section.id }} {
    color: var(--title-color);
    font-size: var(--title-size);
    font-weight: {{ section.settings.title_weight | default: '800' }};
    margin-bottom: {{ section.settings.title_margin | default: '16' }}px;
  }

  .results-subtitle-{{ section.id }} {
    color: var(--subtitle-color);
    font-size: var(--subtitle-size);
    max-width: {{ section.settings.subtitle_width | default: '768' }}px;
    margin: 0 auto;
    line-height: {{ section.settings.subtitle_line_height | default: '1.5' }};
  }

  .results-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ section.settings.grid_gap | default: '32' }}px;
    position: relative;
  }

  @media (min-width: 768px) {
    .results-grid-{{ section.id }} {
      grid-template-columns: repeat({{ section.settings.columns | default: '3' }}, 1fr);
    }
  }

  .result-card-{{ section.id }} {
    background-color: var(--card-bg);
    border-radius: var(--card-radius);
    overflow: hidden;
    box-shadow: var(--card-shadow);
    border: 1px solid var(--card-border);
    transition: all {{ section.settings.card_transition | default: '300' }}ms ease;
    position: relative;
  }

  .result-card-{{ section.id }}:hover {
    transform: translateY(-{{ section.settings.hover_offset | default: '8' }}px);
    box-shadow: {{ section.settings.hover_shadow | default: '0 20px 25px -5px rgb(0 0 0 / 0.15)' }};
  }

  {% if section.settings.show_connectors %}
    @media (min-width: 768px) {
      .result-card-{{ section.id }}:not(:last-child)::after {
        content: '';
        position: absolute;
        top: 25%;
        right: -{{ section.settings.connector_offset | default: '16' }}px;
        width: {{ section.settings.connector_width | default: '32' }}px;
        height: {{ section.settings.connector_height | default: '2' }}px;
        background: linear-gradient(to right, var(--connector-1), var(--connector-2));
        z-index: 1;
      }
    }
  {% endif %}

  .week-badge-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    padding: {{ section.settings.badge_padding_y | default: '8' }}px {{ section.settings.badge_padding_x | default: '16' }}px;
    background-color: var(--week-badge-bg);
    color: var(--week-badge-color);
    border-radius: {{ section.settings.badge_radius | default: '9999' }}px;
    font-size: {{ section.settings.badge_size | default: '14' }}px;
    font-weight: {{ section.settings.badge_weight | default: '600' }};
    border: 1px solid {{ section.settings.badge_border | default: '#FBCFE8' }};
  }

  .image-container-{{ section.id }} {
    position: relative;
    margin: {{ section.settings.image_margin | default: '16' }}px 0;
    aspect-ratio: {{ section.settings.image_aspect | default: '1 / 1' }};
    overflow: hidden;
    border-radius: {{ section.settings.image_radius | default: '12' }}px;
  }

  .result-image-{{ section.id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform {{ section.settings.image_transition | default: '500' }}ms ease;
  }

  .result-card-{{ section.id }}:hover .result-image-{{ section.id }} {
    transform: scale({{ section.settings.image_hover_scale | default: '1.05' }});
  }

  .image-caption-{{ section.id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
    padding: {{ section.settings.caption_padding | default: '16' }}px;
    color: white;
    font-size: {{ section.settings.caption_size | default: '14' }}px;
    font-weight: {{ section.settings.caption_weight | default: '500' }};
  }

  .card-content-{{ section.id }} {
    padding: {{ section.settings.content_padding | default: '24' }}px;
  }

  .card-title-{{ section.id }} {
    color: var(--title-color);
    font-size: {{ section.settings.card_title_size | default: '20' }}px;
    font-weight: {{ section.settings.card_title_weight | default: '700' }};
    margin-bottom: {{ section.settings.card_title_margin | default: '12' }}px;
  }

  .card-text-{{ section.id }} {
    color: var(--subtitle-color);
    font-size: {{ section.settings.card_text_size | default: '16' }}px;
    line-height: {{ section.settings.card_text_line_height | default: '1.6' }};
    margin-bottom: {{ section.settings.card_text_margin | default: '24' }}px;
  }

  .progress-container-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: {{ section.settings.progress_gap | default: '16' }}px;
  }

  .progress-circle-{{ section.id }} {
    width: {{ section.settings.progress_size | default: '64' }}px;
    height: {{ section.settings.progress_size | default: '64' }}px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: {{ section.settings.progress_weight | default: '700' }};
    color: white;
  }

  .progress-circle-1-{{ section.id }} {
    background: linear-gradient(to bottom right, var(--progress-1), {{ section.settings.progress_1_light | default: '#F9A8D4' }});
  }

  .progress-circle-2-{{ section.id }} {
    background: linear-gradient(to bottom right, var(--progress-2), {{ section.settings.progress_2_light | default: '#C4B5FD' }});
  }

  .progress-circle-3-{{ section.id }} {
    background: linear-gradient(to bottom right, var(--progress-3), {{ section.settings.progress_3_light | default: '#93C5FD' }});
  }

  .progress-text-{{ section.id }} {
    flex: 1;
  }

  .progress-label-{{ section.id }} {
    color: var(--title-color);
    font-weight: {{ section.settings.progress_label_weight | default: '600' }};
    font-size: {{ section.settings.progress_label_size | default: '16' }}px;
    margin-bottom: {{ section.settings.progress_label_margin | default: '4' }}px;
  }

  .progress-desc-{{ section.id }} {
    color: var(--subtitle-color);
    font-size: {{ section.settings.progress_desc_size | default: '14' }}px;
  }

  .placeholder-{{ section.id }} {
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom right, {{ section.settings.placeholder_start | default: '#FCE7F3' }}, {{ section.settings.placeholder_end | default: '#FBCFE8' }});
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 8px;
    color: {{ section.settings.placeholder_text | default: '#9D174D' }};
  }
</style>

<div id="results-{{ section.id }}" class="results-section-{{ section.id }}" {{ section.shopify_attributes }}>
  <!-- Header -->
  <div class="results-header-{{ section.id }}">
    <h2 class="results-title-{{ section.id }}">
      {{ section.settings.title | default: 'See The Transformation' }}
    </h2>
    <p class="results-subtitle-{{ section.id }}">
      {{ section.settings.subtitle | default: 'Real results from real customers. Watch as skin transforms with regular use of our mask over 4 weeks.' }}
    </p>
  </div>

  <!-- Timeline Grid -->
  <div class="results-grid-{{ section.id }}">
    <!-- Week 1 -->
    <div class="result-card-{{ section.id }}">
      <div class="px-6 pt-6">
        <span class="week-badge-{{ section.id }}">
          {{ section.settings.week_1_badge | default: 'Week 1' }}
        </span>
      </div>
      
      <div class="image-container-{{ section.id }} px-6">
        {% if section.settings.week1_image != blank %}
          <img src="{{ section.settings.week1_image | image_url: width: 600 }}"
               alt="{{ section.settings.week1_alt | default: 'Results after 1 week' }}"
               class="result-image-{{ section.id }}"
               width="600"
               height="600"
               loading="lazy">
        {% else %}
          <div class="placeholder-{{ section.id }}">
            <span class="text-5xl">📸</span>
            <p>{{ section.settings.week1_placeholder | default: 'Week 1 Results' }}</p>
          </div>
        {% endif %}
        <div class="image-caption-{{ section.id }}">
          {{ section.settings.week1_caption | default: 'First Signs of Improvement' }}
        </div>
      </div>
      
      <div class="card-content-{{ section.id }}">
        <h3 class="card-title-{{ section.id }}">
          {{ section.settings.week1_title | default: 'Initial Brightening' }}
        </h3>
        <p class="card-text-{{ section.id }}">
          {{ section.settings.week1_text | default: 'Skin appears fresher and more hydrated with initial reduction in dullness. Texture begins to improve.' }}
        </p>
        
        <div class="progress-container-{{ section.id }}">
          <div class="progress-circle-{{ section.id }} progress-circle-1-{{ section.id }}">
            {{ section.settings.week1_progress | default: '25%' }}
          </div>
          <div class="progress-text-{{ section.id }}">
            <div class="progress-label-{{ section.id }}">{{ section.settings.week1_progress_label | default: 'Progress Achieved' }}</div>
            <div class="progress-desc-{{ section.id }}">{{ section.settings.week1_progress_desc | default: 'Visible hydration & brightness' }}</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Week 2 -->
    <div class="result-card-{{ section.id }}">
      <div class="px-6 pt-6">
        <span class="week-badge-{{ section.id }}">
          {{ section.settings.week_2_badge | default: 'Week 2' }}
        </span>
      </div>
      
      <div class="image-container-{{ section.id }} px-6">
        {% if section.settings.week2_image != blank %}
          <img src="{{ section.settings.week2_image | image_url: width: 600 }}"
               alt="{{ section.settings.week2_alt | default: 'Results after 2 weeks' }}"
               class="result-image-{{ section.id }}"
               width="600"
               height="600"
               loading="lazy">
        {% else %}
          <div class="placeholder-{{ section.id }}" style="background: linear-gradient(to bottom right, #EDE9FE, #DDD6FE);">
            <span class="text-5xl">✨</span>
            <p>{{ section.settings.week2_placeholder | default: 'Week 2 Results' }}</p>
          </div>
        {% endif %}
        <div class="image-caption-{{ section.id }}">
          {{ section.settings.week2_caption | default: 'Texture Refinement' }}
        </div>
      </div>
      
      <div class="card-content-{{ section.id }}">
        <h3 class="card-title-{{ section.id }}">
          {{ section.settings.week2_title | default: 'Smoother Skin' }}
        </h3>
        <p class="card-text-{{ section.id }}">
          {{ section.settings.week2_text | default: 'Pores appear minimized, texture becomes visibly smoother, and complexion looks more even.' }}
        </p>
        
        <div class="progress-container-{{ section.id }}">
          <div class="progress-circle-{{ section.id }} progress-circle-2-{{ section.id }}">
            {{ section.settings.week2_progress | default: '60%' }}
          </div>
          <div class="progress-text-{{ section.id }}">
            <div class="progress-label-{{ section.id }}">{{ section.settings.week2_progress_label | default: 'Progress Achieved' }}</div>
            <div class="progress-desc-{{ section.id }}">{{ section.settings.week2_progress_desc | default: 'Texture & pore improvement' }}</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Week 4 -->
    <div class="result-card-{{ section.id }}">
      <div class="px-6 pt-6">
        <span class="week-badge-{{ section.id }}">
          {{ section.settings.week_4_badge | default: 'Week 4' }}
        </span>
      </div>
      
      <div class="image-container-{{ section.id }} px-6">
        {% if section.settings.week4_image != blank %}
          <img src="{{ section.settings.week4_image | image_url: width: 600 }}"
               alt="{{ section.settings.week4_alt | default: 'Results after 4 weeks' }}"
               class="result-image-{{ section.id }}"
               width="600"
               height="600"
               loading="lazy">
        {% else %}
          <div class="placeholder-{{ section.id }}" style="background: linear-gradient(to bottom right, #DBEAFE, #BFDBFE);">
            <span class="text-5xl">🌟</span>
            <p>{{ section.settings.week4_placeholder | default: 'Week 4 Results' }}</p>
          </div>
        {% endif %}
        <div class="image-caption-{{ section.id }}">
          {{ section.settings.week4_caption | default: 'Radiant Glow' }}
        </div>
      </div>
      
      <div class="card-content-{{ section.id }}">
        <h3 class="card-title-{{ section.id }}">
          {{ section.settings.week4_title | default: 'Radiant Glow' }}
        </h3>
        <p class="card-text-{{ section.id }}">
          {{ section.settings.week4_text | default: 'Skin achieves a healthy, natural glow with visibly reduced imperfections and a more youthful appearance.' }}
        </p>
        
        <div class="progress-container-{{ section.id }}">
          <div class="progress-circle-{{ section.id }} progress-circle-3-{{ section.id }}">
            {{ section.settings.week4_progress | default: '100%' }}
          </div>
          <div class="progress-text-{{ section.id }}">
            <div class="progress-label-{{ section.id }}">{{ section.settings.week4_progress_label | default: 'Full Transformation' }}</div>
            <div class="progress-desc-{{ section.id }}">{{ section.settings.week4_progress_desc | default: 'Glowing, healthy skin' }}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Results Timeline",
  "settings": [
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "color",
      "id": "results_bg",
      "label": "Background color",
      "default": "#F9FAFB"
    },
    {
      "type": "range",
      "id": "results_padding",
      "label": "Section padding",
      "min": 24,
      "max": 80,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "results_radius",
      "label": "Section radius",
      "min": 4,
      "max": 32,
      "step": 2,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "default": 1280,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns on desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Gap between cards",
      "min": 16,
      "max": 48,
      "step": 4,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Connectors"
    },
    {
      "type": "checkbox",
      "id": "show_connectors",
      "label": "Show timeline connectors",
      "default": true
    },
    {
      "type": "range",
      "id": "connector_offset",
      "label": "Connector offset",
      "min": 8,
      "max": 32,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "connector_width",
      "label": "Connector width",
      "min": 16,
      "max": 64,
      "step": 2,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "connector_height",
      "label": "Connector height",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "connector_1",
      "label": "Connector start color",
      "default": "#FBCFE8"
    },
    {
      "type": "color",
      "id": "connector_2",
      "label": "Connector end color",
      "default": "#DDD6FE"
    },
    {
      "type": "header",
      "content": "Header Settings"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "See The Transformation"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#111827"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 24,
      "max": 48,
      "step": 2,
      "default": 30,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Title weight",
      "options": [
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra bold" },
        { "value": "900", "label": "Black" }
      ],
      "default": "800"
    },
    {
      "type": "range",
      "id": "title_margin",
      "label": "Title bottom margin",
      "min": 8,
      "max": 32,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Real results from real customers. Watch as skin transforms with regular use of our mask over 4 weeks."
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#4B5563"
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Subtitle size",
      "min": 16,
      "max": 28,
      "step": 1,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "subtitle_width",
      "label": "Subtitle max width",
      "min": 400,
      "max": 1000,
      "step": 50,
      "default": 768,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "subtitle_line_height",
      "label": "Subtitle line height",
      "min": 1.2,
      "max": 2,
      "step": 0.1,
      "default": 1.5
    },
    {
      "type": "range",
      "id": "header_margin",
      "label": "Header bottom margin",
      "min": 24,
      "max": 96,
      "step": 4,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Card Settings"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Card border",
      "default": "#F3F4F6"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card radius",
      "min": 4,
      "max": 32,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "card_shadow",
      "label": "Card shadow",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "0 4px 6px -1px rgb(0 0 0 / 0.1)", "label": "Medium" },
        { "value": "0 10px 15px -3px rgb(0 0 0 / 0.1)", "label": "Large" },
        { "value": "0 20px 25px -5px rgb(0 0 0 / 0.1)", "label": "XL" }
      ],
      "default": "0 10px 15px -3px rgb(0 0 0 / 0.1)"
    },
    {
      "type": "range",
      "id": "card_transition",
      "label": "Card transition speed",
      "min": 200,
      "max": 500,
      "step": 50,
      "default": 300,
      "unit": "ms"
    },
    {
      "type": "range",
      "id": "hover_offset",
      "label": "Hover lift",
      "min": 2,
      "max": 16,
      "step": 1,
      "default": 8,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "hover_shadow",
      "label": "Hover shadow",
      "options": [
        { "value": "0 10px 15px -3px rgb(0 0 0 / 0.1)", "label": "Large" },
        { "value": "0 20px 25px -5px rgb(0 0 0 / 0.1)", "label": "XL" },
        { "value": "0 25px 50px -12px rgb(0 0 0 / 0.25)", "label": "2XL" }
      ],
      "default": "0 20px 25px -5px rgb(0 0 0 / 0.15)"
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Content padding",
      "min": 16,
      "max": 40,
      "step": 2,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Week Badge"
    },
    {
      "type": "color",
      "id": "week_badge_bg",
      "label": "Badge background",
      "default": "#FDF2F8"
    },
    {
      "type": "color",
      "id": "week_badge_color",
      "label": "Badge text color",
      "default": "#BE185D"
    },
    {
      "type": "color",
      "id": "badge_border",
      "label": "Badge border",
      "default": "#FBCFE8"
    },
    {
      "type": "range",
      "id": "badge_padding_x",
      "label": "Badge horizontal padding",
      "min": 8,
      "max": 24,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "badge_padding_y",
      "label": "Badge vertical padding",
      "min": 4,
      "max": 16,
      "step": 2,
      "default": 8,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "badge_size",
      "label": "Badge font size",
      "min": 12,
