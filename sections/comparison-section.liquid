{% comment %}
  Section: Comparison Section
  Description: Comparison between home use vs clinic treatments
{% endcomment %}

<div class="w-full max-w-7xl mx-auto">
    <div class="bg-gradient-to-br from-white to-gray-50 rounded-3xl shadow-2xl p-6 sm:p-8 lg:p-12">
        <div class="text-center mb-8 sm:mb-12">
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-gray-900 mb-4 leading-tight">
                {{ section.settings.main_title | default: 'REVOLUTIONIZE YOUR SKIN CARE ROUTINE' }}
            </h2>
            <p class="text-lg sm:text-xl text-gray-600 max-w-3xl mx-auto">
                {{ section.settings.main_subtitle | default: 'Experience professional-grade LED therapy at home versus traditional clinic treatments' }}
            </p>
        </div>

        <!-- Three Cards Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
            <!-- Card 1: Your LED Mask -->
            <div class="bg-white rounded-2xl shadow-xl p-6 sm:p-8 flex flex-col border-2 border-rose-100 transform hover:-translate-y-2 transition-all duration-300">
                <div class="flex-shrink-0 mb-6 text-center">
                    <div class="w-20 h-20 sm:w-24 sm:h-24 bg-gradient-to-r from-rose-500 to-pink-500 rounded-2xl flex items-center justify-center mx-auto shadow-lg">
                        <svg class="w-8 h-8 sm:w-10 sm:h-10 text-white" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 1.944A11.954 11.954 0 012.166 5C2.056 5.649 2 6.319 2 7c0 5.225 3.34 9.67 8 11.317C14.66 16.67 18 12.225 18 7c0-.682-.057-1.35-.166-2.001A11.954 11.954 0 0110 1.944zM11 14a1 1 0 11-2 0 1 1 0 012 0zm0-7a1 1 0 10-2 0v3a1 1 0 102 0V7z" clip-rule="evenodd"></path>
                        </svg>
                    </div>
                </div>
                <h3 class="text-2xl sm:text-3xl font-black text-gray-900 mb-6 text-center">
                    {{ section.settings.card_1_title | default: 'LUMINA LED MASK' }}
                </h3>
                <ul class="space-y-3 sm:space-y-4 mb-6 sm:mb-8 flex-grow">
                    <li class="flex items-start text-gray-700 text-base sm:text-lg">
                        <svg class="w-5 h-5 sm:w-6 sm:h-6 text-rose-500 mr-3 sm:mr-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                        </svg>
                        {{ section.settings.card_1_bullet_1 | default: 'Use anytime at your convenience' }}
                    </li>
                    <li class="flex items-start text-gray-700 text-base sm:text-lg">
                        <svg class="w-5 h-5 sm:w-6 sm:h-6 text-rose-500 mr-3 sm:mr-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                        </svg>
                        {{ section.settings.card_1_bullet_2 | default: 'One-time investment for lasting care' }}
                    </li>
                    <li class="flex items-start text-gray-700 text-base sm:text-lg">
                        <svg class="w-5 h-5 sm:w-6 sm:h-6 text-rose-500 mr-3 sm:mr-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                        </svg>
                        {{ section.settings.card_1_bullet_3 | default: 'Treat both face and neck areas' }}
                    </li>
                    <li class="flex items-start text-gray-700 text-base sm:text-lg">
                        <svg class="w-5 h-5 sm:w-6 sm:h-6 text-rose-500 mr-3 sm:mr-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                        </svg>
                        {{ section.settings.card_1_bullet_4 | default: 'No scheduling or travel required' }}
                    </li>
                </ul>
                <div class="mt-auto">
                    <div class="bg-gradient-to-r from-rose-500 to-pink-500 text-white text-center py-3 sm:py-4 rounded-xl font-bold text-base sm:text-lg shadow-lg">
                        {{ section.settings.card_1_badge | default: 'SMART INVESTMENT' }}
                    </div>
                </div>
            </div>

            <!-- Card 2: Professional Clinic -->
            <div class="bg-white rounded-2xl shadow-xl p-6 sm:p-8 flex flex-col border-2 border-gray-200 transform hover:-translate-y-2 transition-all duration-300 relative overflow-hidden">
                <div class="absolute inset-0 bg-cover bg-center opacity-5" style="background-image: url('{{ section.settings.clinic_bg_image | image_url: width: 800 | default: 'https://images.unsplash.com/photo-1600334089607-1e0e4c53c0a7?ixlib=rb-4.0.3&auto=format&fit=crop&w=1170&q=80' }}');"></div>
                <div class="relative z-10">
                    <div class="flex-shrink-0 mb-6 text-center">
                        <div class="w-20 h-20 sm:w-24 sm:h-24 bg-gradient-to-r from-gray-500 to-gray-700 rounded-2xl flex items-center justify-center mx-auto shadow-lg">
                            <svg class="w-8 h-8 sm:w-10 sm:h-10 text-white" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h8a2 2 0 012 2v12a1 1 0 110 2h-3a1 1 0 01-1-1v-2a1 1 0 00-1-1H9a1 1 0 00-1 1v2a1 1 0 01-1 1H4a1 1 0 110-2V4zm3 1h2v2H7V5zm2 4H7v2h2V9zm2-4h2v2h-2V5zm2 4h-2v2h2V9z" clip-rule="evenodd"></path>
                            </svg>
                        </div>
                    </div>
                    <h3 class="text-2xl sm:text-3xl font-black text-gray-900 mb-6 text-center">
                        {{ section.settings.card_2_title | default: 'CLINIC TREATMENTS' }}
                    </h3>
                    <ul class="space-y-3 sm:space-y-4 mb-6 sm:mb-8 flex-grow">
                        <li class="flex items-start text-gray-700 text-base sm:text-lg">
                            <svg class="w-5 h-5 sm:w-6 sm:h-6 text-red-500 mr-3 sm:mr-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                            </svg>
                            {{ section.settings.card_2_bullet_1 | default: 'Requires advance appointments' }}
                        </li>
                        <li class="flex items-start text-gray-700 text-base sm:text-lg">
                            <svg class="w-5 h-5 sm:w-6 sm:h-6 text-red-500 mr-3 sm:mr-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                            </svg>
                            {{ section.settings.card_2_bullet_2 | default: 'Only facial treatment available' }}
                        </li>
                        <li class="flex items-start text-gray-700 text-base sm:text-lg">
                            <svg class="w-5 h-5 sm:w-6 sm:h-6 text-red-500 mr-3 sm:mr-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                            </svg>
                            {{ section.settings.card_2_bullet_3 | default: 'Repeated expensive sessions' }}
                        </li>
                        <li class="flex items-start text-gray-700 text-base sm:text-lg">
                            <svg class="w-5 h-5 sm:w-6 sm:h-6 text-red-500 mr-3 sm:mr-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                            </svg>
                            {{ section.settings.card_2_bullet_4 | default: 'Temporary results only' }}
                        </li>
                    </ul>
                    <div class="mt-auto">
                        <div class="bg-gradient-to-r from-gray-500 to-gray-700 text-white text-center py-3 sm:py-4 rounded-xl font-bold text-base sm:text-lg shadow-lg">
                            {{ section.settings.card_2_badge | default: 'COSTLY OPTION' }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card 3: Advanced Technology -->
            <div class="bg-white rounded-2xl shadow-xl p-6 sm:p-8 flex flex-col border-2 border-blue-100 transform hover:-translate-y-2 transition-all duration-300">
                <div class="flex-shrink-0 mb-6 text-center">
                    <div class="w-20 h-20 sm:w-24 sm:h-24 bg-gradient-to-r from-blue-500 to-purple-500 rounded-2xl flex items-center justify-center mx-auto shadow-lg">
                        <svg class="w-8 h-8 sm:w-10 sm:h-10 text-white" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" clip-rule="evenodd"></path>
                        </svg>
                    </div>
                </div>
                <h3 class="text-2xl sm:text-3xl font-black text-gray-900 mb-6 text-center">
                    {{ section.settings.card_3_title | default: 'ADVANCED FEATURES' }}
                </h3>
                <ul class="space-y-3 sm:space-y-4 mb-6 sm:mb-8 flex-grow">
                    <li class="flex items-start text-gray-700 text-base sm:text-lg">
                        <svg class="w-5 h-5 sm:w-6 sm:h-6 text-blue-500 mr-3 sm:mr-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                        </svg>
                        {{ section.settings.card_3_bullet_1 | default: '420 Medical-grade LED diodes' }}
                    </li>
                    <li class="flex items-start text-gray-700 text-base sm:text-lg">
                        <svg class="w-5 h-5 sm:w-6 sm:h-6 text-blue-500 mr-3 sm:mr-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                        </svg>
                        {{ section.settings.card_3_bullet_2 | default: '7 specialized wavelength settings' }}
                    </li>
                    <li class="flex items-start text-gray-700 text-base sm:text-lg">
                        <svg class="w-5 h-5 sm:w-6 sm:h-6 text-blue-500 mr-3 sm:mr-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                        </svg>
                        {{ section.settings.card_3_bullet_3 | default: '8 adjustable intensity levels' }}
                    </li>
                    <li class="flex items-start text-gray-700 text-base sm:text-lg">
                        <svg class="w-5 h-5 sm:w-6 sm:h-6 text-blue-500 mr-3 sm:mr-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                        </svg>
                        {{ section.settings.card_3_bullet_4 | default: 'Flexible medical-grade silicone' }}
                    </li>
                </ul>
                <div class="mt-auto">
                    <div class="bg-gradient-to-r from-blue-500 to-purple-500 text-white text-center py-3 sm:py-4 rounded-xl font-bold text-base sm:text-lg shadow-lg">
                        {{ section.settings.card_3_badge | default: 'CUTTING-EDGE' }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

