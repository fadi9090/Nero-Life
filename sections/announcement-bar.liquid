<style>
  @keyframes scroll-left {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .scrolling-banner {
    animation: scroll-left 30s linear infinite;
    white-space: nowrap;
    display: inline-flex;
    gap: 3rem;
    will-change: transform;
  }

  .banner-container {
    overflow: hidden;
    width: 100%;
  }

  .scrolling-banner:hover {
    animation-play-state: paused;
  }

  @media (max-width: 640px) {
    .scrolling-banner {
      animation-duration: 20s;
      gap: 2rem;
    }
  }
</style>

{% comment %} Load discount configuration - notice it's 'discount' not 'discount-config' {% endcomment %}
{% render 'discount' %}

{% if has_discounts and section.settings.show_banner %}
  {% capture banner_content %}
    <span class="inline-block py-2 text-sm md:text-base font-bold">
      ✨ {% if section.settings.message_1 != blank %}
        {{ section.settings.message_1 | replace: '[discount]', regular_discount }}
      {% else %}
        {{ regular_discount }}% OFF! On all Orders.
      {% endif %}
    </span>
    
    <span class="inline-block py-1 text-xs md:text-sm font-bold">
      🚚 {% if section.settings.message_2 != blank %}
        {{ section.settings.message_2 }}
      {% else %}
        Free Shipping on Orders.
      {% endif %}
    </span>
  {% endcapture %}

  <div class="bg-[#FA8072] text-[#F5F5DC] overflow-hidden font-sans sticky top-0 z-50 banner-container">
    <div class="scrolling-banner">
      {{ banner_content }}
      {{ banner_content }}
      {{ banner_content }}
      {{ banner_content }}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_banner",
      "label": "Show Announcement Banner",
      "default": true
    },
    {
      "type": "text",
      "id": "message_1",
      "label": "First Banner Message",
      "default": "[discount]% OFF! On all Orders.",
      "info": "Use [discount] to show the current discount percentage"
    },
    {
      "type": "text",
      "id": "message_2",
      "label": "Second Banner Message",
      "default": "Free Shipping on Orders.",
      "info": "Second message that alternates in the banner"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "category": "Promotional"
    }
  ]
}
{% endschema %}