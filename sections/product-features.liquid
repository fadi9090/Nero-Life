{% comment %}
  Product Features - Side by side layout with image
  Fully customizable
{% endcomment %}

<style>
  #product-features-{{ section.id }} {
    --features-bg: {{ section.settings.features_bg | default: '#F9FAFB' }};
    --features-radius: {{ section.settings.features_radius | default: '12' }}px;
    --features-padding: {{ section.settings.features_padding | default: '48' }}px;
    --title-color: {{ section.settings.title_color | default: '#1F2937' }};
    --title-size: {{ section.settings.title_size | default: '24' }}px;
    --text-color: {{ section.settings.text_color | default: '#4B5563' }};
    --check-bg: {{ section.settings.check_bg | default: '#2563EB' }};
    --check-color: {{ section.settings.check_color | default: '#FFFFFF' }};
    --heading-color: {{ section.settings.heading_color | default: '#374151' }};
    --heading-size: {{ section.settings.heading_size | default: '16' }}px;
    --desc-size: {{ section.settings.desc_size | default: '14' }}px;
    --icon-size: {{ section.settings.icon_size | default: '20' }}px;
  }

  .features-section-{{ section.id }} {
    background-color: var(--features-bg);
    border-radius: var(--features-radius);
    padding: var(--features-padding);
    max-width: {{ section.settings.max_width | default: '1280' }}px;
    margin: 0 auto;
  }

  .features-container-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ section.settings.container_gap | default: '32' }}px;
  }

  @media (min-width: 1024px) {
    .features-container-{{ section.id }} {
      flex-direction: row;
      gap: {{ section.settings.container_gap_lg | default: '48' }}px;
    }
  }

  .features-image-{{ section.id }} {
    width: 100%;
    max-width: {{ section.settings.image_max_width | default: '500' }}px;
    display: flex;
    justify-content: {% if section.settings.image_alignment == 'left' %}flex-start{% else %}center{% endif %};
    order: {{ section.settings.image_order | default: '1' }};
  }

  @media (min-width: 1024px) {
    .features-image-{{ section.id }} {
      width: 50%;
    }
  }

  .features-image-{{ section.id }} img {
    width: 100%;
    height: auto;
    max-width: 100%;
    border-radius: {{ section.settings.image_radius | default: '8' }}px;
    box-shadow: {{ section.settings.image_shadow | default: '0 4px 6px -1px rgb(0 0 0 / 0.1)' }};
  }

  .features-content-{{ section.id }} {
    width: 100%;
    max-width: {{ section.settings.content_max_width | default: '500' }}px;
    order: {{ section.settings.content_order | default: '2' }};
  }

  @media (min-width: 1024px) {
    .features-content-{{ section.id }} {
      width: 50%;
    }
  }

  .features-title-{{ section.id }} {
    color: var(--title-color);
    font-size: var(--title-size);
    font-weight: {{ section.settings.title_weight | default: '600' }};
    margin-bottom: {{ section.settings.title_margin | default: '24' }}px;
    text-align: {{ section.settings.title_align | default: 'left' }};
    line-height: {{ section.settings.title_line_height | default: '1.2' }};
  }

  .features-list-{{ section.id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .feature-item-{{ section.id }} {
    display: flex;
    align-items: flex-start;
    gap: {{ section.settings.item_gap | default: '12' }}px;
    margin-bottom: {{ section.settings.item_spacing | default: '16' }}px;
  }

  .feature-check-{{ section.id }} {
    flex-shrink: 0;
    width: var(--icon-size);
    height: var(--icon-size);
    background-color: var(--check-bg);
    color: var(--check-color);
    border-radius: {{ section.settings.check_radius | default: '9999' }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: {{ section.settings.check_weight | default: '700' }};
    font-size: {{ section.settings.check_font_size | default: '12' }}px;
    margin-top: 2px;
  }

  .feature-text-{{ section.id }} {
    flex: 1;
  }

  .feature-heading-{{ section.id }} {
    color: var(--heading-color);
    font-size: var(--heading-size);
    font-weight: {{ section.settings.heading_weight | default: '500' }};
    margin-bottom: {{ section.settings.heading_margin | default: '4' }}px;
  }

  .feature-description-{{ section.id }} {
    color: var(--text-color);
    font-size: var(--desc-size);
    line-height: {{ section.settings.desc_line_height | default: '1.5' }};
  }
</style>

<div id="product-features-{{ section.id }}" class="features-section-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="features-container-{{ section.id }}">
    <!-- Image Side -->
    <div class="features-image-{{ section.id }}">
      {% if section.settings.feature_image != blank %}
        <img src="{{ section.settings.feature_image | image_url: width: 800 }}"
             alt="{{ section.settings.image_alt | default: 'LED Facial and Neck Mask showing skin rejuvenation benefits' }}"
             width="{{ section.settings.image_width | default: '500' }}"
             height="{{ section.settings.image_height | default: '400' }}"
             loading="lazy">
      {% else %}
        <img src="{{ 'assets/skin-effect.png' | asset_url }}"
             alt="LED Facial and Neck Mask"
             width="500"
             height="400"
             loading="lazy">
      {% endif %}
    </div>

    <!-- Content Side -->
    <div class="features-content-{{ section.id }}">
      <h2 class="features-title-{{ section.id }}">
        {{ section.settings.title | default: 'Professional-Grade LED Therapy At Home' }}
      </h2>

      <ul class="features-list-{{ section.id }}">
        {% for i in (1..section.settings.feature_count) %}
          {% assign feature_heading = 'feature_heading_' | append: i %}
          {% assign feature_desc = 'feature_desc_' | append: i %}
          
          {% if section.settings[feature_heading] != blank %}
            <li class="feature-item-{{ section.id }}">
              <span class="feature-check-{{ section.id }}">
                {% if section.settings.check_style == 'icon' %}
                  {% render 'icon-check', size: 3, color: '#FFFFFF' %}
                {% else %}
                  ✓
                {% endif %}
              </span>
              <div class="feature-text-{{ section.id }}">
                <h3 class="feature-heading-{{ section.id }}">
                  {{ section.settings[feature_heading] }}
                </h3>
                <p class="feature-description-{{ section.id }}">
                  {{ section.settings[feature_desc] }}
                </p>
              </div>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  </div>
</div>

