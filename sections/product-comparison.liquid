{% comment %}
  Product Comparison Table - Fully customizable with icons
{% endcomment %}

<style>
  #comparison-table-{{ section.id }} {
    --comp-bg: {{ section.settings.comp_bg | default: '#FFFFFF' }};
    --comp-border: {{ section.settings.comp_border | default: '#F3F4F6' }};
    --comp-shadow: {{ section.settings.comp_shadow | default: '0 10px 15px -3px rgb(0 0 0 / 0.1)' }};
    --comp-radius: {{ section.settings.comp_radius | default: '12' }}px;
    --comp-padding: {{ section.settings.comp_padding | default: '32' }}px;
    --title-color: {{ section.settings.title_color | default: '#111827' }};
    --title-size: {{ section.settings.title_size | default: '30' }}px;
    --text-color: {{ section.settings.text_color | default: '#4B5563' }};
    --text-size: {{ section.settings.text_size | default: '18' }}px;
    --header-bg: {{ section.settings.header_bg | default: '#F5F5DC' }};
    --header-our-bg: {{ section.settings.header_our_bg | default: '#F5F5DC' }};
    --header-other-bg: {{ section.settings.header_other_bg | default: '#EF4444' }};
    --header-our-color: {{ section.settings.header_our_color | default: '#166534' }};
    --header-other-color: {{ section.settings.header_other_color | default: '#FFFFFF' }};
    --row-bg: {{ section.settings.row_bg | default: '#FFFFFF' }};
    --row-border: {{ section.settings.row_border | default: '#E5E7EB' }};
    --check-color: {{ section.settings.check_color | default: '#10B981' }};
    --x-color: {{ section.settings.x_color | default: '#EF4444' }};
    --benefit-color: {{ section.settings.benefit_color | default: '#1F2937' }};
    --benefit-weight: {{ section.settings.benefit_weight | default: '600' }};
  }

  .comparison-section-{{ section.id }} {
    background-color: var(--comp-bg);
    border-radius: var(--comp-radius);
    padding: var(--comp-padding);
    box-shadow: var(--comp-shadow);
    border: 1px solid var(--comp-border);
    max-width: {{ section.settings.max_width | default: '1280' }}px;
    margin: 0 auto;
  }

  .comparison-title-{{ section.id }} {
    color: var(--title-color);
    font-size: var(--title-size);
    font-weight: {{ section.settings.title_weight | default: '800' }};
    text-align: center;
    margin-bottom: {{ section.settings.title_margin | default: '32' }}px;
  }

  .comparison-subtitle-{{ section.id }} {
    color: var(--text-color);
    font-size: var(--text-size);
    text-align: center;
    max-width: {{ section.settings.subtitle_width | default: '768' }}px;
    margin: 0 auto {{ section.settings.subtitle_margin | default: '40' }}px;
    line-height: {{ section.settings.subtitle_line_height | default: '1.6' }};
  }

  .table-container-{{ section.id }} {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .comparison-table-{{ section.id }} {
    width: 100%;
    max-width: {{ section.settings.table_width | default: '768' }}px;
    border: {{ section.settings.table_border_width | default: '1' }}px solid var(--row-border);
    border-radius: {{ section.settings.table_radius | default: '12' }}px;
    overflow: hidden;
    box-shadow: {{ section.settings.table_shadow | default: '0 4px 6px -1px rgb(0 0 0 / 0.1)' }};
  }

  .table-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: {{ section.settings.first_col_width | default: '1.5fr' }} {{ section.settings.second_col_width | default: '1fr' }} {{ section.settings.third_col_width | default: '1fr' }};
  }

  .table-header-{{ section.id }} {
    background-color: var(--header-bg);
    font-weight: {{ section.settings.header_weight | default: '700' }};
    padding: {{ section.settings.header_padding | default: '16' }}px;
    text-align: {{ section.settings.header_align | default: 'left' }};
  }

  .table-header-our-{{ section.id }} {
    background-color: var(--header-our-bg);
    color: var(--header-our-color);
    text-align: center;
    padding: {{ section.settings.header_padding | default: '16' }}px;
    font-weight: {{ section.settings.header_weight | default: '700' }};
  }

  .table-header-other-{{ section.id }} {
    background-color: var(--header-other-bg);
    color: var(--header-other-color);
    text-align: center;
    padding: {{ section.settings.header_padding | default: '16' }}px;
    font-weight: {{ section.settings.header_weight | default: '700' }};
  }

  .table-cell-{{ section.id }} {
    padding: {{ section.settings.cell_padding | default: '16' }}px;
    border-top: 1px solid var(--row-border);
    background-color: var(--row-bg);
  }

  .table-cell-benefit-{{ section.id }} {
    color: var(--benefit-color);
    font-weight: var(--benefit-weight);
  }

  .table-cell-center-{{ section.id }} {
    text-align: center;
    border-top: 1px solid var(--row-border);
    background-color: {{ section.settings.our_col_bg | default: '#F5F5DC' }};
    padding: {{ section.settings.cell_padding | default: '16' }}px;
  }

  .table-cell-other-{{ section.id }} {
    text-align: center;
    border-top: 1px solid var(--row-border);
    background-color: {{ section.settings.other_col_bg | default: '#FEE2E2' }};
    padding: {{ section.settings.cell_padding | default: '16' }}px;
  }

  .check-icon-{{ section.id }} {
    color: var(--check-color);
    margin: 0 auto;
  }

  .x-icon-{{ section.id }} {
    color: var(--x-color);
    margin: 0 auto;
  }

  @media (max-width: 640px) {
    .table-grid-{{ section.id }} {
      font-size: {{ section.settings.mobile_font_size | default: '14' }}px;
    }
    
    .table-header-{{ section.id }},
    .table-header-our-{{ section.id }},
    .table-header-other-{{ section.id }},
    .table-cell-{{ section.id }},
    .table-cell-center-{{ section.id }},
    .table-cell-other-{{ section.id }} {
      padding: {{ section.settings.mobile_padding | default: '8' }}px;
    }
  }
</style>

<div id="comparison-table-{{ section.id }}" class="comparison-section-{{ section.id }}" {{ section.shopify_attributes }}>
  <!-- Title -->
  <h2 class="comparison-title-{{ section.id }}">
    {{ section.settings.title | default: 'Why Choose Our LED Mask?' }}
  </h2>
  
  <!-- Subtitle -->
  {% if section.settings.show_subtitle %}
    <p class="comparison-subtitle-{{ section.id }}">
      {{ section.settings.subtitle | default: 'Experience revolutionary skincare with our advanced LED Light Therapy Mask. Featuring medical-grade technology in a comfortable, flexible design, our mask delivers professional results from home.' }}
    </p>
  {% endif %}

  <!-- Comparison Table -->
  <div class="table-container-{{ section.id }}">
    <div class="comparison-table-{{ section.id }}">
      <div class="table-grid-{{ section.id }}">
        <!-- Header Row -->
        <div class="table-header-{{ section.id }}">
          {{ section.settings.benefit_header | default: 'Benefit' }}
        </div>
        <div class="table-header-our-{{ section.id }}">
          {{ section.settings.our_header | default: 'Our LED Mask' }}
        </div>
        <div class="table-header-other-{{ section.id }}">
          {{ section.settings.other_header | default: 'Others' }}
        </div>

        <!-- Dynamic Rows -->
        {% for i in (1..section.settings.row_count) %}
          {% assign benefit_text = 'benefit_' | append: i %}
          {% if section.settings[benefit_text] != blank %}
            <!-- Benefit Cell -->
            <div class="table-cell-{{ section.id }} table-cell-benefit-{{ section.id }}">
              {{ section.settings[benefit_text] }}
            </div>
            
            <!-- Our Mask Cell (Checkmark) -->
            <div class="table-cell-center-{{ section.id }}">
              <div class="check-icon-{{ section.id }}">
                {% render 'icon-check-circle', size: section.settings.icon_size | default: 6, color: section.settings.check_color %}
              </div>
            </div>
            
            <!-- Others Cell (X Mark) -->
            <div class="table-cell-other-{{ section.id }}">
              <div class="x-icon-{{ section.id }}">
                {% render 'icon-x-circle', size: section.settings.icon_size | default: 6, color: section.settings.x_color %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

