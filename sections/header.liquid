{%- assign main_menu_linklist = linklists[section.settings.menu].links -%}
{% assign logo_image = section.settings.logo %}

<style>
  :root {
    --header-bg: {{ section.settings.header_bg_color | default: '#FFFFFF' }};
    --header-text: {{ section.settings.header_text_color | default: '#000000' }};
    --header-hover: {{ section.settings.header_hover_color | default: '#0077B6' }};
    --header-height: {{ section.settings.header_height | default: '64' }}px;
    --logo-max-height: {{ section.settings.logo_max_height | default: '60' }}px;
    --icon-size: {{ section.settings.icon_size | default: '6' }};
    --mobile-menu-bg: {{ section.settings.mobile_menu_bg | default: '#FFFFFF' }};
  }

  .header-logo {
    max-height: var(--logo-max-height);
    width: auto;
    vertical-align: middle;
  }

  .header-logo-container {
    display: flex;
    align-items: center;
  }

  .section-header {
    position: relative;
    z-index: 100;
    background: var(--header-bg);
    width: 100%;
    height: var(--header-height);
  }

  .header-wrapper {
    position: {% if section.settings.sticky_header %}sticky{% else %}relative{% endif %};
    top: 0;
    z-index: 100;
  }

  .nav-link {
    color: var(--header-text);
    font-size: {{ section.settings.nav_font_size | default: 'base' }};
    font-weight: {{ section.settings.nav_font_weight | default: '500' }};
    transition: color 0.15s ease;
  }

  .nav-link:hover {
    color: var(--header-hover);
  }

  .cart-icon-btn {
    color: var(--header-text);
  }

  .cart-icon-btn:hover {
    color: var(--header-hover);
  }

  .mobile-menu-btn {
    color: var(--header-text);
  }

  .mobile-menu-btn:hover {
    color: var(--header-hover);
  }

  .mobile-menu {
    background: var(--mobile-menu-bg);
  }

  .mobile-menu-link {
    color: var(--header-text);
    font-size: {{ section.settings.mobile_nav_font_size | default: 'base' }};
    transition: color 0.15s ease;
  }

  .mobile-menu-link:hover {
    color: var(--header-hover);
  }

  /* Responsive padding */
  .header-container {
    padding-left: {{ section.settings.header_padding_x | default: '16' }}px;
    padding-right: {{ section.settings.header_padding_x | default: '16' }}px;
  }

  @media (min-width: 640px) {
    .header-container {
      padding-left: {{ section.settings.header_padding_x_sm | default: '24' }}px;
      padding-right: {{ section.settings.header_padding_x_sm | default: '24' }}px;
    }
  }

  @media (min-width: 1024px) {
    .header-container {
      padding-left: {{ section.settings.header_padding_x_lg | default: '32' }}px;
      padding-right: {{ section.settings.header_padding_x_lg | default: '32' }}px;
    }
  }

  /* Cart count badge */
  .cart-count-badge {
    background-color: {{ section.settings.cart_badge_bg | default: '#EF4444' }};
    color: {{ section.settings.cart_badge_text | default: '#FFFFFF' }};
    font-size: {{ section.settings.cart_badge_size | default: 'xs' }};
  }
</style>

<!-- Header Wrapper -->
<div class="header-wrapper">
  <div x-data="{ mobileMenu: false }" class="section-header shadow-{{ section.settings.header_shadow | default: 'md' }}">
    <div class="mx-auto header-container">
      <div class="flex justify-between items-center" style="height: var(--header-height);">
        <!-- Mobile menu button -->
        {% if section.settings.show_mobile_menu %}
          <div class="{{ section.settings.mobile_menu_breakpoint | default: 'md' }}:hidden">
            <button
              @click="mobileMenu = !mobileMenu"
              type="button"
              class="mobile-menu-btn p-2 rounded-md focus:outline-none focus:ring-2 focus:ring-inset focus:ring-gray-600"
              aria-label="Toggle menu"
            >
              {% render 'icon-menu', 
                size: section.settings.icon_size | default: 6,
                color: section.settings.icon_color | default: 'currentColor',
                stroke_width: section.settings.icon_stroke | default: 1.5
              %}
            </button>
          </div>
        {% endif %}

        <!-- Logo -->
        <div class="header-logo-container flex-1 flex {% if section.settings.logo_alignment_mobile == 'center' %}justify-center{% else %}justify-start{% endif %} {{ section.settings.mobile_menu_breakpoint | default: 'md' }}:flex-none {{ section.settings.mobile_menu_breakpoint | default: 'md' }}:justify-{{ section.settings.logo_alignment_desktop | default: 'start' }} truncate">
          <a href="{{ routes.root_url }}" class="flex items-center">
            {% if logo_image != blank %}
              <div class="header-logo-container">
                {{ logo_image | image_url: height: section.settings.logo_max_height | image_tag: 
                  alt: shop.name, 
                  class: 'header-logo',
                  loading: 'lazy'
                }}
              </div>
            {% else %}
              <h1 class="text-{{ section.settings.logo_font_size | default: 'lg' }} font-{{ section.settings.logo_font_weight | default: 'bold' }}" style="color: var(--header-text);">
                {{ shop.name }}
              </h1>
            {% endif %}
          </a>
        </div>

        <!-- Desktop Navigation -->
        {% if section.settings.show_desktop_menu %}
          <nav class="hidden {{ section.settings.mobile_menu_breakpoint | default: 'md' }}:flex {{ section.settings.mobile_menu_breakpoint | default: 'md' }}:flex-1 {{ section.settings.mobile_menu_breakpoint | default: 'md' }}:justify-{{ section.settings.nav_alignment | default: 'center' }} {{ section.settings.mobile_menu_breakpoint | default: 'md' }}:space-x-{{ section.settings.nav_spacing | default: '10' }}">
            {% for link in main_menu_linklist %}
              <div class="relative">
                <a
                  href="{{ link.url }}"
                  class="nav-link inline-block py-{{ section.settings.nav_padding_y | default: '2' }} px-{{ section.settings.nav_padding_x | default: '0' }} whitespace-nowrap"
                >
                  {{ link.title }}
                </a>
                
                {% if section.settings.show_menu_underline and link.current %}
                  <span class="absolute bottom-0 left-0 w-full h-0.5" style="background-color: var(--header-hover);"></span>
                {% endif %}
              </div>
            {% endfor %}
          </nav>
        {% endif %}

        <!-- Right Icons -->
        <div class="flex items-center space-x-{{ section.settings.icon_spacing | default: '2' }}">
          <!-- Search Icon -->
          {% if section.settings.show_search %}
            <a
              href="/search"
              class="p-2 rounded-md text-{{ section.settings.icon_color | default: 'currentColor' }} hover:text-[var(--header-hover)]"
              aria-label="Search"
            >
              {% render 'icon-search', 
                size: section.settings.icon_size | default: 6,
                color: section.settings.icon_color | default: 'currentColor',
                stroke_width: section.settings.icon_stroke | default: 1.5
              %}
            </a>
          {% endif %}

          <!-- Account Icon -->
          {% if section.settings.show_account %}
            <a
              href="{{ routes.account_url }}"
              class="p-2 rounded-md text-{{ section.settings.icon_color | default: 'currentColor' }} hover:text-[var(--header-hover)]"
              aria-label="Account"
            >
              {% render 'icon-user', 
                size: section.settings.icon_size | default: 6,
                color: section.settings.icon_color | default: 'currentColor',
                stroke_width: section.settings.icon_stroke | default: 1.5
              %}
            </a>
          {% endif %}

          <!-- Wishlist Icon -->
          {% if section.settings.show_wishlist %}
            <a
              href="{{ routes.wishlist_url | default: '#' }}"
              class="p-2 rounded-md text-{{ section.settings.icon_color | default: 'currentColor' }} hover:text-[var(--header-hover)]"
              aria-label="Wishlist"
            >
              {% render 'icon-heart', 
                size: section.settings.icon_size | default: 6,
                color: section.settings.icon_color | default: 'currentColor',
                filled: section.settings.wishlist_filled | default: false,
                stroke_width: section.settings.icon_stroke | default: 1.5
              %}
            </a>
          {% endif %}

          <!-- Cart Icon -->
          {% if section.settings.show_cart %}
            <a
              href="{{ routes.cart_url }}"
              class="cart-icon-btn p-2 rounded-md whitespace-nowrap relative"
              aria-label="Cart"
            >
              {% render 'icon-cart', 
                size: section.settings.icon_size | default: 6,
                color: section.settings.icon_color | default: 'currentColor',
                stroke_width: section.settings.icon_stroke | default: 1.5
              %}
              
              {% if section.settings.show_cart_count %}
                <span id="CartCountWrapper" class="absolute -top-1 -right-1">
                  {% if cart.item_count > 0 %}
                    <span
                      id="CartCount"
                      class="cart-count-badge text-{{ section.settings.cart_badge_size | default: 'xs' }} font-bold rounded-full w-5 h-5 flex items-center justify-center"
                    >
                      {{- cart.item_count -}}
                    </span>
                  {% endif %}
                </span>
              {% endif %}
            </a>
          {% endif %}
        </div>
      </div>
    </div>

    <!-- Mobile Menu -->
    {% if section.settings.show_mobile_menu %}
      <div
        x-show="mobileMenu"
        @click.away="mobileMenu = false"
        x-transition:enter="duration-200 ease-out"
        x-transition:enter-start="opacity-0 scale-95"
        x-transition:enter-end="opacity-100 scale-100"
        x-transition:leave="duration-100 ease-in"
        x-transition:leave-start="opacity-100 scale-100"
        x-transition:leave-end="opacity-0 scale-95"
        class="absolute z-50 top-[var(--header-height)] inset-x-0 p-2 transform origin-top-left {{ section.settings.mobile_menu_breakpoint | default: 'md' }}:hidden"
      >
        <div class="mobile-menu shadow-{{ section.settings.mobile_menu_shadow | default: 'lg' }} rounded-{{ section.settings.mobile_menu_radius | default: 'lg' }} ring-1 ring-black ring-opacity-5 w-full">
          <div class="p-{{ section.settings.mobile_menu_padding | default: '5' }} divide-y-2 divide-gray-100">
            <div class="flex items-center justify-between pb-3">
              <h2 class="text-{{ section.settings.mobile_menu_title_size | default: 'lg' }} font-{{ section.settings.mobile_menu_title_weight | default: 'bold' }}" style="color: var(--header-text);">
                {{ section.settings.mobile_menu_title | default: 'Menu' }}
              </h2>
              <button 
                @click="mobileMenu = false" 
                type="button" 
                class="mobile-menu-btn rounded-md p-2"
                aria-label="Close menu"
              >
                {% render 'icon-close', 
                  size: section.settings.icon_size | default: 5,
                  color: section.settings.icon_color | default: 'currentColor',
                  stroke_width: section.settings.icon_stroke | default: 1.5
                %}
              </button>
            </div>

            <div class="pt-{{ section.settings.mobile_menu_padding | default: '3' }}">
              <nav class="grid gap-y-{{ section.settings.mobile_menu_spacing | default: '2' }}">
                {% for link in main_menu_linklist %}
                  <a
                    href="{{ link.url }}"
                    class="mobile-menu-link -m-3 p-3 flex items-center rounded-{{ section.settings.mobile_link_radius | default: 'md' }}"
                  >
                    {{ link.title }}
                  </a>
                {% endfor %}
                
                <!-- Mobile menu extra links -->
                {% if section.settings.show_mobile_extra_links %}
                  <div class="border-t border-gray-200 mt-4 pt-4">                    
                    {% if section.settings.show_mobile_wishlist %}
                      <a href="{{ routes.wishlist_url | default: '#' }}" class="mobile-menu-link -m-3 p-3 flex items-center">
                        {% render 'icon-heart', size: 5, class: 'mr-3' %}
                        Wishlist
                      </a>
                    {% endif %}
                  </div>
                {% endif %}
              </nav>
            </div>
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</div>

<script>
  // --- AJAX Cart Update Functions for Header ---
  function updateHeaderCartCount(newCount) {
    const countElement = document.getElementById('CartCount');
    const wrapper = document.getElementById('CartCountWrapper');

    if (newCount > 0) {
      if (!countElement) {
        const newCountSpan = document.createElement('span');
        newCountSpan.id = 'CartCount';
        newCountSpan.className = 'cart-count-badge text-{{ section.settings.cart_badge_size | default: "xs" }} font-bold rounded-full w-5 h-5 flex items-center justify-center';
        newCountSpan.textContent = newCount;
        if (wrapper) {
          wrapper.innerHTML = '';
          wrapper.appendChild(newCountSpan);
        }
      } else {
        countElement.textContent = newCount;
        
        // Add animation
        countElement.animate([
          { transform: 'scale(1.2)' },
          { transform: 'scale(1)' }
        ], {
          duration: 300,
          easing: 'ease-out'
        });
      }
    } else {
      if (wrapper) wrapper.innerHTML = '';
    }
  }

  function getCartDataAndRefresh() {
    fetch(`${window.Shopify.routes.root}cart.js`)
      .then(response => response.json())
      .then(cart => updateHeaderCartCount(cart.item_count))
      .catch(error => console.error('Error fetching cart data:', error));
  }

  document.addEventListener('cart:add-success', getCartDataAndRefresh);
  
  // Listen for theme editor events
  document.addEventListener('shopify:section:load', function() {
    getCartDataAndRefresh();
  });
</script>

